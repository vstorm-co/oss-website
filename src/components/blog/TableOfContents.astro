---
interface Props {
  headings: { depth: number; slug: string; text: string }[];
  label: string;
}

const { headings, label } = Astro.props;
const filtered = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

{filtered.length > 0 && (
  <nav id="toc-nav">
    <h3 class="mb-3 text-xs font-semibold uppercase tracking-wider text-text-tertiary">
      {label}
    </h3>
    <ul class="space-y-1 text-sm">
      {filtered.map((heading) => (
        <li class={heading.depth === 3 ? "pl-4" : ""}>
          <a
            href={`#${heading.slug}`}
            data-toc-link={heading.slug}
            class="toc-link block py-1 text-text-tertiary hover:text-accent transition-colors border-l-2 border-transparent pl-3 -ml-px"
          >
            {heading.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}

<style>
  .toc-link.active {
    color: var(--color-accent);
    border-left-color: var(--color-accent);
  }
</style>

<script is:inline>
  document.addEventListener('astro:page-load', function() {
    var links = document.querySelectorAll('[data-toc-link]');
    if (!links.length) return;

    var slugs = [];
    links.forEach(function(l) { slugs.push(l.getAttribute('data-toc-link')); });

    var headings = slugs.map(function(s) { return document.getElementById(s); }).filter(Boolean);
    if (!headings.length) return;

    var current = null;

    function update() {
      var found = null;

      for (var i = headings.length - 1; i >= 0; i--) {
        if (headings[i].getBoundingClientRect().top <= 100) {
          found = headings[i].id;
          break;
        }
      }

      if (found !== current) {
        current = found;
        links.forEach(function(l) {
          if (l.getAttribute('data-toc-link') === current) {
            l.classList.add('active');
          } else {
            l.classList.remove('active');
          }
        });
      }
    }

    window.addEventListener('scroll', update, { passive: true });
    update();
  });
</script>
