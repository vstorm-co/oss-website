---
{
  /* @mdx-label Carousel */
}
{
  /* @mdx-description Swipeable slider for images or cards. Supports captions, keyboard, and touch. */
}
{
  /* @mdx-snippet
<Carousel
  items={[
    { src: "/images/photo1.jpg", alt: "First slide", caption: "Caption here" },
    { src: "/images/photo2.jpg", alt: "Second slide" },
    { src: "/images/photo3.jpg", alt: "Third slide", caption: "Another caption" },
  ]}
/>
*/
}
{
  /* @mdx-preview
<div style="background:#18181b;border-radius:10px;overflow:hidden;border:1px solid #27272a;padding:12px">
  <div style="display:flex;gap:6px;margin-bottom:8px">
    <div style="flex:1;height:80px;background:#27272a;border-radius:6px"></div>
    <div style="flex:1;height:80px;background:#1e1e24;border-radius:6px;opacity:0.5"></div>
    <div style="flex:1;height:80px;background:#1e1e24;border-radius:6px;opacity:0.3"></div>
  </div>
  <div style="display:flex;justify-content:center;gap:4px">
    <div style="width:6px;height:6px;background:#7c5cff;border-radius:50%"></div>
    <div style="width:6px;height:6px;background:#3f3f46;border-radius:50%"></div>
    <div style="width:6px;height:6px;background:#3f3f46;border-radius:50%"></div>
  </div>
</div>
*/
}

export interface CarouselItem {
  src: string;
  alt: string;
  caption?: string;
  href?: string;
}

export interface Props {
  items: CarouselItem[];
  aspectRatio?: string;
  loop?: boolean;
}

const { items, aspectRatio = "16/9", loop = true } = Astro.props;
const id = `cr-${Math.random().toString(36).slice(2, 8)}`;
---

<div class="carousel" id={id} data-loop={loop ? "true" : "false"} aria-roledescription="carousel">
  <div class="carousel-track" aria-live="polite">
    {
      items.map((item, i) => (
        <div
          class="carousel-slide"
          role="group"
          aria-roledescription="slide"
          aria-label={`${i + 1} of ${items.length}`}
          aria-hidden={i !== 0}
          style={`aspect-ratio:${aspectRatio}`}
        >
          {item.href ? (
            <a href={item.href} class="carousel-link" tabindex={i === 0 ? 0 : -1}>
              <img
                src={item.src}
                alt={item.alt}
                class="carousel-img"
                loading={i === 0 ? "eager" : "lazy"}
                decoding="async"
              />
            </a>
          ) : (
            <img
              src={item.src}
              alt={item.alt}
              class="carousel-img"
              loading={i === 0 ? "eager" : "lazy"}
              decoding="async"
            />
          )}
          {item.caption && <p class="carousel-caption">{item.caption}</p>}
        </div>
      ))
    }
  </div>

  <button class="carousel-btn carousel-prev" aria-label="Previous slide" data-dir="-1">
    <svg
      width="20"
      height="20"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden
    >
      <path d="M15 18l-6-6 6-6"></path>
    </svg>
  </button>
  <button class="carousel-btn carousel-next" aria-label="Next slide" data-dir="1">
    <svg
      width="20"
      height="20"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      aria-hidden
    >
      <path d="M9 18l6-6-6-6"></path>
    </svg>
  </button>

  <div class="carousel-dots" role="tablist" aria-label="Slides">
    {
      items.map((_, i) => (
        <button
          class:list={["carousel-dot", { active: i === 0 }]}
          role="tab"
          aria-label={`Go to slide ${i + 1}`}
          aria-selected={i === 0}
          data-slide={i}
        />
      ))
    }
  </div>
</div>

<style>
  .carousel {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: 12px;
    border: 1px solid var(--color-border);
    margin: 1.5em 0;
    background: var(--color-surface);
    user-select: none;
  }
  .carousel-track {
    display: flex;
    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    will-change: transform;
  }
  .carousel-slide {
    flex: 0 0 100%;
    min-width: 0;
    position: relative;
    overflow: hidden;
  }
  .carousel-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .carousel-link {
    display: block;
    width: 100%;
    height: 100%;
  }
  .carousel-caption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    margin: 0;
    padding: 0.6rem 1rem;
    background: linear-gradient(transparent, rgba(0, 0, 0, 0.7));
    color: #fff;
    font-size: 0.85rem;
    line-height: 1.4;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.5);
  }
  .carousel-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(4px);
    border: 1px solid rgba(255, 255, 255, 0.15);
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.15s;
    z-index: 2;
  }
  .carousel-btn:hover {
    background: rgba(0, 0, 0, 0.75);
    transform: translateY(-50%) scale(1.08);
  }
  .carousel-btn:disabled {
    opacity: 0.3;
    cursor: default;
  }
  .carousel-prev {
    left: 10px;
  }
  .carousel-next {
    right: 10px;
  }
  .carousel-dots {
    position: absolute;
    bottom: 10px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 6px;
    z-index: 2;
  }
  .carousel-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.4);
    border: none;
    padding: 0;
    cursor: pointer;
    transition: all 0.2s;
  }
  .carousel-dot.active {
    background: #fff;
    transform: scale(1.3);
  }
</style>

<script is:inline>
  (function () {
    function initCarousel(el) {
      if (el._carouselInit) return;
      el._carouselInit = true;

      const track = el.querySelector(".carousel-track");
      const slides = el.querySelectorAll(".carousel-slide");
      const dots = el.querySelectorAll(".carousel-dot");
      const prevBtn = el.querySelector(".carousel-prev");
      const nextBtn = el.querySelector(".carousel-next");
      const total = slides.length;
      let current = 0;
      const loop = el.getAttribute("data-loop") === "true";

      function go(n) {
        if (!loop) n = Math.max(0, Math.min(total - 1, n));
        else n = ((n % total) + total) % total;
        current = n;
        track.style.transform = "translateX(-" + current * 100 + "%)";
        slides.forEach(function (s, i) {
          s.setAttribute("aria-hidden", i !== current ? "true" : "false");
          const a = s.querySelector(".carousel-link");
          if (a) a.tabIndex = i === current ? 0 : -1;
        });
        dots.forEach(function (d, i) {
          d.classList.toggle("active", i === current);
          d.setAttribute("aria-selected", i === current ? "true" : "false");
        });
        if (!loop) {
          prevBtn.disabled = current === 0;
          nextBtn.disabled = current === total - 1;
        }
      }

      prevBtn.addEventListener("click", function () {
        go(current - 1);
      });
      nextBtn.addEventListener("click", function () {
        go(current + 1);
      });
      dots.forEach(function (d, i) {
        d.addEventListener("click", function () {
          go(i);
        });
      });

      // Keyboard
      el.addEventListener("keydown", function (e) {
        if (e.key === "ArrowLeft") go(current - 1);
        if (e.key === "ArrowRight") go(current + 1);
      });

      // Touch/swipe
      let startX = 0;
      el.addEventListener(
        "touchstart",
        function (e) {
          startX = e.touches[0].clientX;
        },
        { passive: true },
      );
      el.addEventListener(
        "touchend",
        function (e) {
          const dx = e.changedTouches[0].clientX - startX;
          if (Math.abs(dx) > 40) go(current + (dx < 0 ? 1 : -1));
        },
        { passive: true },
      );

      go(0);
    }

    function initAll() {
      document.querySelectorAll(".carousel").forEach(initCarousel);
    }

    if (document.readyState === "loading") document.addEventListener("DOMContentLoaded", initAll);
    else initAll();
    document.addEventListener("astro:page-load", initAll);
  })();
</script>
