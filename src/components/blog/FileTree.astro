---
export interface FileTreeItem {
  label: string;
  children?: FileTreeItem[];
}
export interface Props {
  items: FileTreeItem[];
}

const { items } = Astro.props;

function esc(s: string): string {
  return s.replace(/[&<>]/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;" })[c] ?? c);
}

function buildHtml(nodes: FileTreeItem[]): string {
  const lines: string[] = ["<ul>"];
  for (const n of nodes) {
    const isDir = !!n.children && n.children.length > 0;
    lines.push(
      `<li><span class="${isDir ? "ft-dir" : ""}">${esc(n.label)}${isDir ? "/" : ""}</span>`,
    );
    if (isDir) lines.push(buildHtml(n.children!));
    lines.push("</li>");
  }
  lines.push("</ul>");
  return lines.join("");
}

const html = buildHtml(items);
---

{/* @mdx-label FileTree */}
{/* @mdx-description Visual directory listing. Pass a nested `items` array. */}
