<div class="file-tree" set:html={html} />

<style>
  .file-tree {
    margin: 1.5rem 0;
    padding: 0.8rem 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 10px;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-text);
    line-height: 1.7;
  }
  .file-tree :global(ul) {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .file-tree :global(li) {
    position: relative;
    padding-left: 1.3rem;
  }
  .file-tree :global(li)::before {
    content: "├─";
    position: absolute;
    left: 0;
    color: var(--color-text-tertiary);
  }
  .file-tree :global(li:last-child)::before {
    content: "└─";
  }
  .file-tree :global(li ul) {
    padding-left: 1rem;
    border-left: 1px solid var(--color-border);
    margin-left: -0.3rem;
    margin-top: 0.2rem;
  }
  .file-tree :global(.ft-dir) {
    color: var(--color-accent);
    font-weight: 500;
  }
</style>
