---
export interface Props {
  variant?: "ornament" | "rule";
}
const { variant = "ornament" } = Astro.props;
---

{/* @mdx-label Divider */}
{/* @mdx-description Section separator. Variants: `ornament` (✧) or `rule` (plain line). */}
{
  /* @mdx-snippet
<Divider />
*/
}
{
  /* @mdx-preview
<div style="display:flex;flex-direction:column;gap:12px;padding:4px 0">
  <div style="text-align:center;font-size:13px;color:#3f3f46;letter-spacing:.2em">— ✧ —</div>
  <hr style="border:none;border-top:1px solid #27272a;margin:0"/>
</div>
*/
}

{
  variant === "ornament" ? (
    <div class="divider divider-ornament" role="separator">
      — ✧ —
    </div>
  ) : (
    <hr class="divider divider-rule" />
  )
}

<style>
  .divider {
    margin: 3rem 0;
  }
  .divider-ornament {
    text-align: center;
    color: var(--color-text-tertiary);
    letter-spacing: 0.25em;
    font-size: 0.9rem;
  }
  .divider-rule {
    border: 0;
    border-top: 1px solid var(--color-border);
  }
</style>
