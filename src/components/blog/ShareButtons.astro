---
interface Props {
  title: string;
  url: string;
  t: Record<string, string>;
}

const { title, url, t } = Astro.props;

const twitterUrl = `https://twitter.com/intent/tweet?text=${encodeURIComponent(title)}&url=${encodeURIComponent(url)}`;
const linkedInUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(url)}`;
---

<div class="border-border mt-12 flex flex-wrap items-center gap-3 border-t pt-6">
  <span class="text-text-secondary text-sm font-medium">{t["blog.share"]}</span>

  <a
    href={twitterUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="border-border text-text-tertiary hover:text-accent hover:border-accent/40 inline-flex h-9 w-9 items-center justify-center rounded-lg border transition-colors"
    aria-label="Share on X/Twitter"
  >
    <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
      <path
        d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"
      ></path>
    </svg>
  </a>

  <a
    href={linkedInUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="border-border text-text-tertiary hover:text-accent hover:border-accent/40 inline-flex h-9 w-9 items-center justify-center rounded-lg border transition-colors"
    aria-label="Share on LinkedIn"
  >
    <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
      <path
        d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
      ></path>
    </svg>
  </a>

  <button
    id="copy-link-btn"
    class="border-border text-text-tertiary hover:text-accent hover:border-accent/40 inline-flex h-9 w-9 items-center justify-center rounded-lg border transition-colors"
    aria-label="Copy link"
    data-url={url}
    data-copied-text={t["blog.share.copied"]}
  >
    <svg
      class="h-4 w-4"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
    >
      <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path>
      <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path>
    </svg>
  </button>
</div>

<!-- Copied toast -->
<div
  id="copy-toast"
  class="bg-accent pointer-events-none fixed bottom-6 left-1/2 z-50 -translate-x-1/2 rounded-lg px-4 py-2 text-sm font-medium text-white opacity-0 shadow-lg transition-opacity duration-300"
>
</div>

<script is:inline>
  document.addEventListener("astro:page-load", function () {
    const btn = document.getElementById("copy-link-btn");
    const toast = document.getElementById("copy-toast");
    if (!btn || !toast) return;

    btn.addEventListener("click", function () {
      const url = btn.getAttribute("data-url");
      const text = btn.getAttribute("data-copied-text") || "Copied!";

      navigator.clipboard.writeText(url).then(function () {
        toast.textContent = text;
        toast.style.opacity = "1";
        setTimeout(function () {
          toast.style.opacity = "0";
        }, 2000);
      });
    });
  });
</script>
