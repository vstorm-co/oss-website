<ol class="steps">
  {
    items.map((item, i) => (
      <li class="step">
        <span class="step-index" aria-hidden>
          {i + 1}
        </span>
        <div class="step-body">
          <p class="step-title">{item.title}</p>
          {item.body && <p class="step-desc">{item.body}</p>}
        </div>
      </li>
    ))
  }
</ol>

<style>
  .steps {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }
  .step {
    display: flex;
    gap: 0.9rem;
    padding: 0.85rem 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 10px;
  }
  .step-index {
    flex-shrink: 0;
    width: 2rem;
    height: 2rem;
    border-radius: 9999px;
    border: 1px solid var(--color-accent);
    color: var(--color-accent);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    font-size: 0.9rem;
  }
  .step-title {
    font-weight: 500;
    color: var(--color-text);
    margin: 0.25rem 0 0.2rem;
  }
  .step-desc {
    margin: 0;
    color: var(--color-text-secondary);
    font-size: 0.95rem;
  }
</style>
