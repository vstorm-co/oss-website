---
interface Props {
  currentPage: number;
  lastPage: number;
  basePath: string;
  t: Record<string, string>;
}

const { currentPage, lastPage, basePath, t } = Astro.props;

if (lastPage <= 1) return;

function pageHref(page: number) {
  return page === 1 ? `${basePath}/` : `${basePath}/${page}/`;
}

// Build page numbers with ellipsis
const pages: (number | "...")[] = [];
for (let i = 1; i <= lastPage; i++) {
  if (i === 1 || i === lastPage || Math.abs(i - currentPage) <= 1) {
    pages.push(i);
  } else if (pages[pages.length - 1] !== "...") {
    pages.push("...");
  }
}
---

<nav
  class="pagination-nav mt-12 flex items-center justify-center gap-2"
  aria-label="Blog pagination"
>
  {
    currentPage > 1 && (
      <a
        href={pageHref(currentPage - 1)}
        class="border-border text-text-secondary hover:text-text hover:border-border-hover flex items-center gap-1 rounded-lg border px-3 py-2 text-sm transition-colors"
      >
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
        </svg>
        {t["blog.pagination.prev"]}
      </a>
    )
  }

  <div class="flex items-center gap-1">
    {
      pages.map((p) =>
        p === "..." ? (
          <span class="text-text-tertiary px-2">...</span>
        ) : p === currentPage ? (
          <span class="bg-accent flex h-9 w-9 items-center justify-center rounded-lg text-sm font-medium text-white">
            {p}
          </span>
        ) : (
          <a
            href={pageHref(p)}
            class="border-border text-text-secondary hover:text-text hover:border-border-hover flex h-9 w-9 items-center justify-center rounded-lg border text-sm transition-colors"
          >
            {p}
          </a>
        ),
      )
    }
  </div>

  {
    currentPage < lastPage && (
      <a
        href={pageHref(currentPage + 1)}
        class="border-border text-text-secondary hover:text-text hover:border-border-hover flex items-center gap-1 rounded-lg border px-3 py-2 text-sm transition-colors"
      >
        {t["blog.pagination.next"]}
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
        </svg>
      </a>
    )
  }
</nav>
