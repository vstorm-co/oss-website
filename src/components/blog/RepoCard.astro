---
export interface Props {
  /** Format: "owner/repo" e.g. "vstorm-co/pydantic-deepagents" */
  repo: string;
  description: string;
  stars?: number | string;
  language?: string;
  /** Custom call-to-action label (default: "View on GitHub") */
  ctaLabel?: string;
}

const { repo, description, stars, language, ctaLabel = "View on GitHub" } = Astro.props;
const url = `https://github.com/${repo}`;
const [owner, name] = repo.split("/");
---

{/* @mdx-label RepoCard */}
{
  /* @mdx-description Embed a GitHub repo card with stars, language, and CTA — ideal for promoting an OSS project mid-article. */
}
{
  /* @mdx-snippet
<RepoCard
  repo="vstorm-co/pydantic-deepagents"
  description="Production-ready Python framework for autonomous AI agents — Claude Code architecture, open source."
  stars="1.2k"
  language="Python"
/>
*/
}

<a href={url} target="_blank" rel="noopener noreferrer" class="repo-card">
  <div class="repo-card-header">
    <svg
      class="repo-card-icon"
      viewBox="0 0 16 16"
      width="20"
      height="20"
      fill="currentColor"
      aria-hidden="true"
    >
      <path
        d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0016 8c0-4.42-3.58-8-8-8z"
      ></path>
    </svg>
    <span class="repo-card-owner">{owner}/</span><span class="repo-card-name">{name}</span>
  </div>
  <p class="repo-card-description">{description}</p>
  <div class="repo-card-footer">
    {
      language && (
        <span class="repo-card-meta">
          <span
            class={`lang-dot lang-${(language ?? "").toLowerCase().replace(/[^a-z0-9]/g, "-")}`}
          />
          {language}
        </span>
      )
    }
    {
      stars && (
        <span class="repo-card-meta">
          <svg viewBox="0 0 16 16" width="14" height="14" fill="currentColor" aria-hidden="true">
            <path d="M8 .25a.75.75 0 01.673.418l1.882 3.815 4.21.612a.75.75 0 01.416 1.279l-3.046 2.97.719 4.192a.75.75 0 01-1.088.791L8 12.347l-3.766 1.98a.75.75 0 01-1.088-.79l.72-4.194L.818 6.374a.75.75 0 01.416-1.28l4.21-.611L7.327.668A.75.75 0 018 .25z" />
          </svg>
          {stars}
        </span>
      )
    }
    <span class="repo-card-cta">{ctaLabel} →</span>
  </div>
</a>

<style>
  .repo-card {
    display: block;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.125rem 1.25rem;
    text-decoration: none;
    color: inherit;
    transition: all 0.18s ease;
    margin: 1.75rem 0;
  }
  .repo-card:hover {
    border-color: var(--color-accent);
    transform: translateY(-1px);
    box-shadow: 0 8px 24px -12px color-mix(in srgb, var(--color-accent) 40%, transparent);
  }
  .repo-card-header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.95rem;
    font-weight: 600;
  }
  .repo-card-icon {
    color: var(--color-text-tertiary);
    flex-shrink: 0;
  }
  .repo-card-owner {
    color: var(--color-text-tertiary);
    font-weight: 400;
  }
  .repo-card-name {
    color: var(--color-accent);
  }
  .repo-card-description {
    margin: 0.5rem 0 0;
    font-size: 0.875rem;
    line-height: 1.5;
    color: var(--color-text-secondary);
  }
  .repo-card-footer {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-top: 0.875rem;
    font-size: 0.75rem;
    color: var(--color-text-tertiary);
  }
  .repo-card-meta {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
  }
  .repo-card-cta {
    margin-left: auto;
    color: var(--color-accent);
    font-weight: 600;
  }
  .lang-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #999;
  }
  .lang-python {
    background: #3572a5;
  }
  .lang-typescript {
    background: #2b7489;
  }
  .lang-javascript {
    /* Bright yellow vanishes on white — darken so it stays visible. */
    background: #d4b30a;
  }
  .lang-go {
    background: #00add8;
  }
  .lang-rust {
    background: #dea584;
  }
</style>
