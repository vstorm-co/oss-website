---
export interface Props {
  src: string;
  title?: string;
}

export function toEmbedUrl(url: string): string {
  const yt1 = url.match(/youtube\.com\/watch\?v=([\w-]{6,})/);
  if (yt1) return `https://www.youtube.com/embed/${yt1[1]}`;
  const yt2 = url.match(/youtu\.be\/([\w-]{6,})/);
  if (yt2) return `https://www.youtube.com/embed/${yt2[1]}`;
  const vimeo = url.match(/vimeo\.com\/(\d+)/);
  if (vimeo) return `https://player.vimeo.com/video/${vimeo[1]}`;
  const loom = url.match(/loom\.com\/share\/([\w]+)/);
  if (loom) return `https://www.loom.com/embed/${loom[1]}`;
  return url;
}

const { src, title = "Embedded video" } = Astro.props;
const embed = toEmbedUrl(src);
---

