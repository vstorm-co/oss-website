*/
}

<div class="video-embed">
  <iframe
    src={embed}
    title={title}
    loading="lazy"
    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
    allowfullscreen></iframe>
</div>

<style>
  .video-embed {
    position: relative;
    aspect-ratio: 16 / 9;
    margin: 1.5rem 0;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid var(--color-border);
  }
  .video-embed iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
  }
</style>
