---
{
  /* @mdx-label Accordion */
}
{
  /* @mdx-description Multi-panel FAQ with animated expand/collapse. Better than Details when you have many questions. */
}
{
  /* @mdx-snippet
<Accordion
  items={[
    { title: "How does it work?", content: "Click a heading to expand the answer. Each panel can be opened independently." },
    { title: "Can multiple panels be open?", content: "Yes — each item opens independently." },
    { title: "Third question", content: "And here is the answer to the third question." },
  ]}
/>
*/
}
{
  /* @mdx-preview
<div style="border:1px solid #27272a;border-radius:10px;overflow:hidden">
  <div style="padding:12px 16px;border-bottom:1px solid #27272a;display:flex;justify-content:space-between;align-items:center;background:#18181b">
    <span style="font-size:13px;font-weight:500;color:#fafafa">How does it work?</span>
    <span style="color:#7c5cff;font-size:16px">▾</span>
  </div>
  <div style="padding:10px 16px;font-size:12px;color:#a1a1aa;background:#0e0e11">Click a heading to expand the answer.</div>
  <div style="padding:12px 16px;border-top:1px solid #27272a;display:flex;justify-content:space-between;align-items:center">
