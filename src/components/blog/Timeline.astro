*/
}

<ol class="timeline">
  {
    items.map((item) => (
      <li>
        <div class="timeline-dot" aria-hidden />
        <time class="timeline-date">{item.date}</time>
        <p class="timeline-title">{item.title}</p>
        {item.body && <p class="timeline-body">{item.body}</p>}
      </li>
    ))
  }
</ol>

<style>
  .timeline {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0;
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .timeline::before {
    content: "";
    position: absolute;
    left: 0.5rem;
    top: 0.3rem;
    bottom: 0.3rem;
    width: 1px;
    background: var(--color-border);
  }
  .timeline li {
    position: relative;
    padding-left: 2rem;
  }
  .timeline-dot {
    position: absolute;
    left: 0.125rem;
    top: 0.45rem;
    width: 0.75rem;
    height: 0.75rem;
    border-radius: 9999px;
    border: 2px solid var(--color-accent);
    background: var(--color-bg);
  }
  .timeline-date {
    display: block;
    font-size: 0.75rem;
    color: var(--color-text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin-bottom: 0.1rem;
  }
  .timeline-title {
    margin: 0;
    font-weight: 500;
    color: var(--color-text);
  }
  .timeline-body {
    margin: 0.2rem 0 0;
    color: var(--color-text-secondary);
    font-size: 0.95rem;
  }
</style>
