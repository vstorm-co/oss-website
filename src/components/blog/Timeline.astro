---
export interface TimelineItem {
  date: string;
  title: string;
  body?: string;
}
export interface Props {
  items: TimelineItem[];
}
const { items } = Astro.props;
---

{/* @mdx-label Timeline */}
{/* @mdx-description Vertical chronological list — ideal for changelogs and release notes. */}
{
  /* @mdx-snippet
<Timeline items={[
  { date: "2026-04-24", title: "v1.0 shipped", body: "Public release." },
  { date: "2026-04-01", title: "Beta closed", body: "200 testers onboarded." },
  { date: "2026-03-15", title: "Project kick-off" },
]} />
*/
}
{
  /* @mdx-preview
<div style="display:flex;flex-direction:column;gap:0;padding-left:20px;border-left:2px solid #27272a">
  <div style="position:relative;padding:0 0 14px 14px">
    <span style="position:absolute;left:-7px;top:3px;width:12px;height:12px;border-radius:50%;background:#7c5cff;border:2px solid #09090b"></span>
    <p style="font-size:10px;color:#71717a;margin:0 0 2px;font-family:monospace">2024-01</p>
    <p style="font-size:12px;font-weight:600;color:#fafafa;margin:0 0 2px">First milestone</p>
