  </div>
  <div style="position:relative;padding:0 0 0 14px">
    <span style="position:absolute;left:-7px;top:3px;width:12px;height:12px;border-radius:50%;background:#27272a;border:2px solid #09090b"></span>
    <p style="font-size:10px;color:#71717a;margin:0 0 2px;font-family:monospace">2024-06</p>
