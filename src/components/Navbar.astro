---
import { translations } from "../i18n/translations";
import type { Project } from "../data/projects";
import { projects, getProjectsByCategory } from "../data/projects";

interface Props {
  project?: Project | null;
}

const { project } = Astro.props;
const currentLang = "en" as const;
const t = translations.en;
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith("/") ? rawBase : rawBase + "/";

const homeHref = "/";
const projectsHref = "/projects/";
const blogHref = "/blog/";
const compareHref = "/compare/";
const usecasesHref = "/use-cases/";
const guidesHref = "/guides/";
const toolsHref = "/tools/";
const aboutHref = "/about/";

const pathname = Astro.url.pathname;
const isProjects = pathname.includes("/projects");
const isBlog = pathname.includes("/blog");
const isCompare = pathname.includes("/compare");
const isUseCases = pathname.includes("/use-cases");
const isGuides = pathname.includes("/guides");
const isTools = pathname.includes("/tools");
const isAbout = pathname.includes("/about");

const githubHref = project?.github
  ? `https://github.com/${project.github}`
  : "https://github.com/vstorm-co";

// Mega-menu: featured projects + categories
const featured = projects.filter((p) => p.hasCustomLanding && p.status === "released").slice(0, 2);
const grouped = getProjectsByCategory(currentLang);

const getProjectHref = (slug: string) => `/projects/${slug}/`;
---

<nav
  class="navbar-beam force-dark fixed right-3 left-3 z-40 mx-auto max-w-5xl rounded-2xl shadow-xl backdrop-blur-2xl sm:right-4 sm:left-4"
  style="top: calc(0.75rem + var(--announcement-h, 0px))"
>
  <div class="flex h-14 items-center justify-between px-4 sm:px-6">
    <!-- Left: Logo -->
    <div class="flex min-w-0 items-center gap-2">
      <a
        href={homeHref}
        class="text-text hover:text-accent flex shrink-0 items-center gap-2.5 transition-colors"
        aria-label="Vstorm OSS Home"
      >
        <img src={`${base}favicon.png`} alt="Vstorm OSS" class="h-7 w-7" width="28" height="28" />
        <span class="hidden text-[15px] font-bold tracking-tight sm:inline" aria-hidden="true"
          >Vstorm OSS</span
        >
      </a>
    </div>

    <!-- Center: Links (hidden on mobile) -->
    <div class="hidden items-center gap-0.5 lg:flex">
      <!-- Projects dropdown trigger -->
      <div class="relative" id="projects-dropdown-trigger">
        <button
          type="button"
          data-nav-section="projects"
          class:list={[
            "flex cursor-pointer items-center gap-1 rounded-xl px-2 py-2 text-xs font-medium whitespace-nowrap transition-colors hover:bg-white/[0.06]",
            isProjects ? "text-accent" : "text-text-secondary hover:text-text",
          ]}
          aria-expanded="false"
          aria-haspopup="true"
        >
          {t["nav.projects"]}
          <svg
            class="h-3.5 w-3.5 transition-transform duration-200"
            id="projects-chevron"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5"
            ></path>
          </svg>
        </button>
      </div>

      <a
        href={blogHref}
        data-nav-section="blog"
        class:list={[
          "rounded-xl px-2 py-2 text-xs font-medium whitespace-nowrap transition-colors hover:bg-white/[0.06]",
          isBlog ? "text-accent" : "text-text-secondary hover:text-text",
        ]}
      >
        {t["nav.blog"]}
      </a>
      <a
        href={usecasesHref}
        data-nav-section="use-cases"
        class:list={[
          "rounded-xl px-2 py-2 text-xs font-medium whitespace-nowrap transition-colors hover:bg-white/[0.06]",
          isUseCases ? "text-accent" : "text-text-secondary hover:text-text",
        ]}
      >
        {t["nav.usecases"] ?? "Use Cases"}
      </a>
      <a
        href={guidesHref}
        data-nav-section="guides"
        class:list={[
          "rounded-xl px-2 py-2 text-xs font-medium whitespace-nowrap transition-colors hover:bg-white/[0.06]",
          isGuides ? "text-accent" : "text-text-secondary hover:text-text",
        ]}
      >
        {t["nav.guides"] ?? "Guides"}
      </a>
      <a
        href={toolsHref}
        data-nav-section="tools"
        class:list={[
          "rounded-xl px-2 py-2 text-xs font-medium whitespace-nowrap transition-colors hover:bg-white/[0.06]",
          isTools ? "text-accent" : "text-text-secondary hover:text-text",
        ]}
      >
        {t["nav.tools"] ?? "Free Tools"}
      </a>
      <a
        href={compareHref}
        data-nav-section="compare"
        class:list={[
          "rounded-xl px-2 py-2 text-xs font-medium whitespace-nowrap transition-colors hover:bg-white/[0.06]",
          isCompare ? "text-accent" : "text-text-secondary hover:text-text",
        ]}
      >
        {t["nav.compare"] ?? "Compare"}
      </a>
      <a
        href={aboutHref}
        data-nav-section="about"
        class:list={[
          "rounded-xl px-2 py-2 text-xs font-medium whitespace-nowrap transition-colors hover:bg-white/[0.06]",
          isAbout ? "text-accent" : "text-text-secondary hover:text-text",
        ]}
      >
        {t["nav.about"]}
      </a>
    </div>

    <!-- Right: GitHub + Contact CTA + Language + Hamburger -->
    <div class="flex items-center gap-2">
      <a
        href={githubHref}
        target="_blank"
        rel="noopener noreferrer"
        class="text-text-secondary hover:text-text hidden h-9 w-9 items-center justify-center rounded-xl transition-colors hover:bg-white/[0.06] lg:flex"
        aria-label="GitHub"
      >
        <svg class="h-[18px] w-[18px]" viewBox="0 0 24 24" fill="currentColor"
          ><path
            d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"
          ></path></svg
        >
      </a>
      <a
        href="https://vstorm.co/contact-us/"
        target="_blank"
        rel="noopener noreferrer"
        class="bg-accent hover:bg-accent-hover hover:shadow-accent/20 hidden items-center rounded-full px-3 py-1.5 text-xs font-semibold whitespace-nowrap text-white transition-all hover:shadow-lg lg:inline-flex"
      >
        {t["footer.cta.button"]}
      </a>
      <!-- Hamburger (mobile only) -->
      <button
        id="mobile-menu-btn"
        class="text-text-secondary hover:text-text flex h-9 w-9 items-center justify-center rounded-xl transition-colors hover:bg-white/[0.06] lg:hidden"
        aria-label="Open menu"
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"></path>
        </svg>
      </button>
    </div>
  </div>

  <!-- Projects Mega Menu -->
  <div
    id="projects-mega-menu"
    class="mega-menu force-dark absolute top-full right-0 left-0 mx-3 mt-2 hidden overflow-hidden rounded-2xl border border-white/[0.08] bg-[#18181b] shadow-2xl sm:mx-4"
  >
    <div class="p-5 sm:p-6">
      <!-- Featured row -->
      <div class="mb-5 grid gap-4 sm:grid-cols-2">
        {
          featured.map((p) => (
            <a
              href={getProjectHref(p.slug)}
              class="group border-border hover:border-accent/40 card-hover flex gap-4 rounded-xl border p-4 transition-all hover:shadow-md"
            >
              <div class="bg-accent/10 text-accent icon-hover flex h-10 w-10 shrink-0 items-center justify-center rounded-xl">
                {p.slug === "full-stack-ai-agent-template" ? (
                  <svg
                    class="h-5 w-5"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="1.5"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M6.75 7.5l3 2.25-3 2.25m4.5 0h3m-9 8.25h13.5A2.25 2.25 0 0021 18V6a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 6v12a2.25 2.25 0 002.25 2.25z"
                    />
                  </svg>
                ) : (
                  <svg
                    class="h-5 w-5"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="1.5"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456z"
                    />
                  </svg>
                )}
              </div>
              <div class="min-w-0 flex-1">
                <div class="flex items-center gap-2">
                  <span class="group-hover:text-accent text-sm font-semibold transition-colors">
                    {p.name}
                  </span>
                  <svg
                    class="text-text-tertiary group-hover:text-accent h-3.5 w-3.5 transition-transform group-hover:translate-x-0.5"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"
                    />
                  </svg>
                </div>
                <p class="text-text-tertiary mt-0.5 line-clamp-2 text-xs leading-relaxed">
                  {p.tagline[currentLang]}
                </p>
              </div>
            </a>
          ))
        }
      </div>

      <!-- Categories — CSS columns for balanced heights -->
      <div class="border-border gap-x-6 border-t pt-5 [column-fill:balance] sm:columns-3">
        {
          grouped.map((group) => (
            <div class="mb-4 break-inside-avoid">
              <h4 class="text-text-tertiary mb-2.5 text-[11px] font-bold tracking-wider uppercase">
                <span class="text-accent mr-1">&#10095;</span>
                {group.label[currentLang]}
              </h4>
              <ul class="space-y-1">
                {group.projects
                  .filter((p) => p.status === "released")
                  .slice(0, 5)
                  .map((p) => (
                    <li>
                      <a
                        href={getProjectHref(p.slug)}
                        class="group/item text-text-secondary hover:text-text flex items-center gap-2 rounded-lg px-2.5 py-1.5 text-[13px] transition-colors hover:bg-white/[0.05]"
                      >
                        <span class="truncate">{p.name}</span>
                        <svg
                          class="text-text-tertiary group-hover/item:text-accent h-3 w-3 shrink-0 -translate-x-1 opacity-0 transition-all group-hover/item:translate-x-0 group-hover/item:opacity-100"
                          fill="none"
                          viewBox="0 0 24 24"
                          stroke="currentColor"
                          stroke-width="2"
                        >
                          <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"
                          />
                        </svg>
                      </a>
                    </li>
                  ))}
              </ul>
            </div>
          ))
        }

        <!-- Compare & links -->
        <div class="mb-4 break-inside-avoid">
          <h4 class="text-text-tertiary mb-2.5 text-[11px] font-bold tracking-wider uppercase">
            <span class="text-accent mr-1">&#10095;</span>{t["nav.compare"] ?? "Compare"}
          </h4>
          <ul class="space-y-1">
            <li>
              <a
                href={compareHref}
                class="group/item text-text-secondary hover:text-text flex items-center gap-2 rounded-lg px-2.5 py-1.5 text-[13px] transition-colors hover:bg-white/[0.05]"
              >
                <span>Framework Comparisons</span>
                <svg
                  class="text-text-tertiary group-hover/item:text-accent h-3 w-3 shrink-0 -translate-x-1 opacity-0 transition-all group-hover/item:translate-x-0 group-hover/item:opacity-100"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path></svg
                >
              </a>
            </li>
            <li>
              <a
                href={usecasesHref}
                class="group/item text-text-secondary hover:text-text flex items-center gap-2 rounded-lg px-2.5 py-1.5 text-[13px] transition-colors hover:bg-white/[0.05]"
              >
                <span>{t["nav.usecases"] ?? "Use Cases"}</span>
                <svg
                  class="text-text-tertiary group-hover/item:text-accent h-3 w-3 shrink-0 -translate-x-1 opacity-0 transition-all group-hover/item:translate-x-0 group-hover/item:opacity-100"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                  ><path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path></svg
                >
              </a>
            </li>
          </ul>
        </div>
      </div>

      <!-- View All Projects CTA -->
      <div class="border-border mt-5 border-t pt-4">
        <a
          href={projectsHref}
          class="bg-accent hover:bg-accent-hover hover:shadow-accent/20 group/all flex items-center justify-center gap-2 rounded-xl px-4 py-2.5 text-[13px] font-semibold text-white transition-all hover:shadow-lg"
        >
          {t["oss.projects.viewAll"] ?? "View All Projects"}
          <svg
            class="h-3.5 w-3.5 transition-transform group-hover/all:translate-x-0.5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
            ><path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"></path></svg
          >
        </a>
      </div>
    </div>
  </div>
</nav>

<!-- Mobile Sidebar -->
<div
  id="mobile-sidebar-overlay"
  class="fixed inset-0 z-50 hidden bg-black/20 backdrop-blur-md"
  aria-hidden="true"
>
  <div
    id="mobile-sidebar"
    class="force-dark fixed top-0 right-0 h-full w-72 translate-x-full border-l border-white/[0.08] bg-[#18181b] shadow-2xl transition-transform duration-200 ease-out"
  >
    <!-- Header -->
    <div class="border-border/50 flex h-14 items-center justify-between border-b px-4">
      <span class="text-sm font-semibold tracking-tight">Menu</span>
      <button
        id="mobile-menu-close"
        class="text-text-secondary hover:text-text hover:bg-surface-hover flex h-8 w-8 items-center justify-center rounded-lg transition-colors"
        aria-label="Close menu"
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"></path>
        </svg>
      </button>
    </div>
    <!-- Links -->
    <div class="flex flex-col gap-1 p-4">
      <a
        href={projectsHref}
        data-nav-section="projects"
        class:list={[
          "hover:bg-surface-hover flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm transition-colors",
          isProjects ? "text-accent" : "text-text-secondary hover:text-text",
        ]}
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M3.75 6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v2.25a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25V6ZM3.75 15.75A2.25 2.25 0 0 1 6 13.5h2.25a2.25 2.25 0 0 1 2.25 2.25V18a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 18v-2.25ZM13.5 6a2.25 2.25 0 0 1 2.25-2.25H18A2.25 2.25 0 0 1 20.25 6v2.25A2.25 2.25 0 0 1 18 10.5h-2.25a2.25 2.25 0 0 1-2.25-2.25V6ZM13.5 15.75a2.25 2.25 0 0 1 2.25-2.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-2.25a2.25 2.25 0 0 1-2.25-2.25v-2.25Z"
          ></path>
        </svg>
        {t["nav.projects"]}
      </a>
      <a
        href={blogHref}
        data-nav-section="blog"
        class:list={[
          "hover:bg-surface-hover flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm transition-colors",
          isBlog ? "text-accent" : "text-text-secondary hover:text-text",
        ]}
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"
          ></path>
        </svg>
        {t["nav.blog"]}
      </a>
      <a
        href={usecasesHref}
        data-nav-section="use-cases"
        class:list={[
          "hover:bg-surface-hover flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm transition-colors",
          isUseCases ? "text-accent" : "text-text-secondary hover:text-text",
        ]}
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M9.75 3.104v5.714a2.25 2.25 0 0 1-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 0 1 4.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0 1 12 15a9.065 9.065 0 0 0-6.23.693L5 14.5m14.8.8 1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0 1 12 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5"
          ></path>
        </svg>
        {t["nav.usecases"] ?? "Use Cases"}
      </a>
      <a
        href={guidesHref}
        data-nav-section="guides"
        class:list={[
          "hover:bg-surface-hover flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm transition-colors",
          isGuides ? "text-accent" : "text-text-secondary hover:text-text",
        ]}
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25"
          ></path>
        </svg>
        {t["nav.guides"] ?? "Guides"}
      </a>
      <a
        href={toolsHref}
        data-nav-section="tools"
        class:list={[
          "hover:bg-surface-hover flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm transition-colors",
          isTools ? "text-accent" : "text-text-secondary hover:text-text",
        ]}
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 0 0 4.486-6.336l-3.276 3.277a3.004 3.004 0 0 1-2.25-2.25l3.276-3.276a4.5 4.5 0 0 0-6.336 4.486c.049.58.025 1.193-.14 1.743"
          ></path>
        </svg>
        {t["nav.tools"] ?? "Free Tools"}
      </a>
      <a
        href={compareHref}
        data-nav-section="compare"
        class:list={[
          "hover:bg-surface-hover flex items-center gap-3 rounded-lg px-3 py-2.5 text-sm transition-colors",
          isCompare ? "text-accent" : "text-text-secondary hover:text-text",
        ]}
      >
        <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
