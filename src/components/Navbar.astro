<!-- Spacer so content isn't hidden behind fixed navbar + announcement bar -->
<div style="height: calc(5rem + var(--announcement-h, 0px))"></div>

<script is:inline>
  document.addEventListener("astro:page-load", function () {
    // Update active nav state based on current URL
    const path = window.location.pathname;
    document.querySelectorAll("[data-nav-section]").forEach(function (el) {
      const section = el.dataset.navSection;
      const active = path.includes("/" + section);
      el.classList.toggle("text-accent", active);
      el.classList.toggle("text-text-secondary", !active);
    });

    // Mobile menu
    const btn = document.getElementById("mobile-menu-btn");
    const closeBtn = document.getElementById("mobile-menu-close");
    const overlay = document.getElementById("mobile-sidebar-overlay");
    const sidebar = document.getElementById("mobile-sidebar");

    function openMobile() {
      overlay?.classList.remove("hidden");
      requestAnimationFrame(function () {
        sidebar?.classList.remove("translate-x-full");
      });
    }

    function closeMobile() {
      sidebar?.classList.add("translate-x-full");
      setTimeout(function () {
        overlay?.classList.add("hidden");
      }, 200);
    }

    btn?.addEventListener("click", openMobile);
    closeBtn?.addEventListener("click", closeMobile);
    overlay?.addEventListener("click", function (e) {
      if (e.target === overlay) closeMobile();
    });

    // Projects mega menu
    const trigger = document.getElementById("projects-dropdown-trigger");
    const menu = document.getElementById("projects-mega-menu");
    const chevron = document.getElementById("projects-chevron");
    if (!trigger || !menu) return;

    let openTimer = null;
    let closeTimer = null;

    function showMenu() {
      clearTimeout(closeTimer);
      openTimer = setTimeout(function () {
        menu.classList.remove("hidden");
        // Force layout flush so the browser sees the un-hidden state
        // before applying the open class — otherwise the animation skips.
        void menu.offsetHeight;
        menu.classList.add("mega-menu-open");
        if (chevron) chevron.style.transform = "rotate(180deg)";
        trigger.querySelector("button")?.setAttribute("aria-expanded", "true");
      }, 80);
    }

    function hideMenu() {
      clearTimeout(openTimer);
      closeTimer = setTimeout(function () {
        menu.classList.remove("mega-menu-open");
        if (chevron) chevron.style.transform = "";
        trigger.querySelector("button")?.setAttribute("aria-expanded", "false");
        setTimeout(function () {
          if (!menu.classList.contains("mega-menu-open")) {
            menu.classList.add("hidden");
          }
        }, 200);
      }, 150);
    }

    trigger.addEventListener("mouseenter", showMenu);
    trigger.addEventListener("mouseleave", hideMenu);
    menu.addEventListener("mouseenter", function () {
      clearTimeout(closeTimer);
    });
    menu.addEventListener("mouseleave", hideMenu);

    // Also handle click on trigger button to navigate
    trigger.querySelector("button")?.addEventListener("click", function () {
      if (menu.classList.contains("mega-menu-open")) {
        hideMenu();
      } else {
        showMenu();
      }
    });

    // Close on Escape
    document.addEventListener("keydown", function (e) {
      if (e.key === "Escape" && menu.classList.contains("mega-menu-open")) {
        hideMenu();
      }
    });

    // Close on click outside
    document.addEventListener("click", function (e) {
      if (!trigger.contains(e.target) && !menu.contains(e.target)) {
        clearTimeout(openTimer);
        menu.classList.remove("mega-menu-open");
        if (chevron) chevron.style.transform = "";
        menu.classList.add("hidden");
      }
    });
  });
</script>

<style>
  .mega-menu {
    opacity: 0;
    transform: translateY(-8px);
    transition:
      opacity 0.2s cubic-bezier(0.16, 1, 0.3, 1),
      transform 0.2s cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
  }

  .mega-menu.mega-menu-open {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }
</style>
