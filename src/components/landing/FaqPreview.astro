---
import type { Lang } from "../../i18n/translations";
import { faqItems } from "../../data/faq";

interface Props {
  t: Record<string, string>;
  lang?: Lang;
  category?: "template" | "deepagents" | "logfire";
}

const { t, lang = "en", category } = Astro.props;
const filteredItems = category ? faqItems.filter((item) => item.category === category) : faqItems;
const previewItems = filteredItems.slice(0, 5);
const faqHref = lang === "en" ? "/faq/" : `/${lang}/faq/`;
---

<section class="section-light-alt px-4 py-24 sm:px-6 sm:py-32 lg:px-8 lg:py-40">
  <div class="mx-auto max-w-4xl">
    <div class="reveal mb-10 text-center">
      <h2 class="heading-accent text-2xl font-bold tracking-tight sm:text-3xl">{t["faq.title"]}</h2>
      <p class="text-text-secondary mt-3">{t["faq.subtitle"]}</p>
    </div>

    <div class="reveal-group space-y-3">
      {
        previewItems.map((item) => (
          <details class="reveal group border-border bg-surface hover:border-accent/30 rounded-lg border transition-colors">
            <summary class="flex cursor-pointer items-center justify-between px-6 py-4 font-medium select-none">
              <span>{item.question[lang]}</span>
              <svg
                class="text-text-tertiary h-5 w-5 shrink-0 transition-transform group-open:rotate-180"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
              >
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="text-text-secondary px-6 pb-4 leading-relaxed">{item.answer[lang]}</div>
          </details>
        ))
      }
    </div>

    <div class="reveal mt-8 text-center">
      <a
        href={faqHref}
        class="text-accent hover:text-accent-hover inline-flex items-center gap-2 font-medium transition-colors"
      >
        {t["faq.seeAll"]}
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"></path>
        </svg>
      </a>
    </div>
  </div>
</section>
