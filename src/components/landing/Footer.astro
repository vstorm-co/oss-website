---
import type { translations } from '../../i18n/translations';

interface Props {
  t: typeof translations.en;
}

const { t } = Astro.props;
---

<!-- CTA Banner -->
<section class="section-stack reveal px-4 py-20 sm:px-6 sm:py-28 lg:px-8 lg:py-36">
  <div class="mx-auto max-w-2xl text-center">
    <h2 class="text-2xl font-bold tracking-[-0.02em] sm:text-3xl">
      {t["footer.cta.title"]}
    </h2>
    <p class="mt-4 text-text-secondary leading-relaxed">
      We're <a href="https://vstorm.co" target="_blank" rel="noopener noreferrer" class="font-semibold text-text hover:text-accent transition-colors">Vstorm</a> &mdash; {t["footer.cta.description"]}
    </p>
    <a
      href="https://vstorm.co/contact-us/"
      target="_blank"
      rel="noopener noreferrer"
      class="mt-8 inline-flex items-center gap-2 rounded-full bg-accent px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-accent-hover"
    >
      {t["footer.cta.button"]}
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
      </svg>
    </a>
  </div>
</section>

<!-- Footer -->
<footer class="px-4 pb-6 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-5xl rounded-2xl border border-border/50 bg-surface/50 px-6 py-5 sm:px-8">
    <div class="flex flex-col items-center justify-between gap-4 sm:flex-row">
      <p class="text-sm text-text-tertiary">
        {t["footer.built"]} <span class="text-accent">&hearts;</span> <a href="https://vstorm.co" target="_blank" rel="noopener noreferrer" class="font-medium text-text-secondary hover:text-text transition-colors">Vstorm</a>
      </p>

      <nav class="flex flex-wrap items-center justify-center gap-5 text-sm text-text-tertiary">
        <a href="/compare/" class="flex items-center gap-1.5 transition-colors hover:text-text-secondary">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 4.5h14.25M3 9h9.75M3 13.5h5.25m5.25-.75L17.25 9m0 0L21 12.75M17.25 9v12" /></svg>
          {t["nav.compare"] ?? "Compare"}
        </a>
        <a href="/changelog/" class="flex items-center gap-1.5 transition-colors hover:text-text-secondary">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
          {t["changelog.title"] ?? "Changelog"}
        </a>
        <a
          href="https://github.com/vstorm-co"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-1.5 transition-colors hover:text-text-secondary"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
          GitHub
        </a>
        <a
          href="https://pypi.org/user/kacperwlodarczyk-vstorm/"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-1.5 transition-colors hover:text-text-secondary"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m21 7.5-9-5.25L3 7.5m18 0-9 5.25m9-5.25v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25m0-9v9"/></svg>
          PyPI
        </a>
        <a
          href="https://www.linkedin.com/company/vstormco/posts/?feedView=all"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-1.5 transition-colors hover:text-text-secondary"
        >
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          LinkedIn
        </a>
        <a
          href="https://vstorm.co"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-1.5 transition-colors hover:text-text-secondary"
        >
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5a17.92 17.92 0 0 1-8.716-2.247m0 0A8.966 8.966 0 0 1 3 12c0-1.264.26-2.467.732-3.56"/></svg>
          vstorm.co
        </a>
      </nav>
    </div>
  </div>
</footer>
