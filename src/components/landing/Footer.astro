---
import { isPublished } from "@/lib/blog";
import type { translations } from "../../i18n/translations";
import { getCollection } from "astro:content";
import { projects } from "../../data/projects";
import { comparisonPages } from "../../data/compare-pages";

interface Props {
  t: typeof translations.en;
}

const { t } = Astro.props;

const getProjectHref = (slug: string) => `/projects/${slug}/`;
const blogHref = `/blog/`;
const usecasesHref = `/use-cases/`;
const guidesHref = `/guides/`;
const toolsHref = `/tools/`;
const compareHref = `/compare/`;
const aboutHref = `/about/`;

const allPosts = await getCollection("blog", ({ data }) => data.lang === "en" && isPublished(data));
const recentPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 5);

const releasedProjects = projects.filter((p) => p.status === "released");
const comparisons = comparisonPages.slice(0, 4);
---

<!-- Product Restatement CTA -->
<section class="reveal border-border border-t px-4 py-20 sm:px-6 sm:py-28 lg:px-8 lg:py-36">
  <div class="mx-auto max-w-3xl text-center">
    <h2 class="heading-accent text-3xl font-bold tracking-[-0.02em] sm:text-4xl">
      {t["footer.restatement.template.title"]}
    </h2>
    <p class="text-text-secondary mt-4 text-lg leading-relaxed">
      {t["footer.restatement.template.description"]}
    </p>
    <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
      <a
        href="/projects/full-stack-ai-agent-template/configurator/"
        class="bg-accent hover:bg-accent-hover hover:shadow-accent/25 inline-flex items-center rounded-full px-8 py-3.5 text-base font-semibold text-white transition-all hover:shadow-lg"
      >
        {t["footer.restatement.template.cta"]}
        <svg
          class="ml-2 h-4 w-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
        </svg>
      </a>
    </div>
  </div>
</section>

<!-- Big Footer -->
<footer class="border-border bg-surface/30 border-t">
  <!-- Top section: brand + consultancy CTA -->
  <div class="mx-auto max-w-[1400px] px-6 pt-16 pb-12 sm:px-8 lg:px-10">
    <div class="flex flex-col gap-10 lg:flex-row lg:justify-between lg:gap-16">
      <div class="max-w-sm">
        <a href="/" class="group flex items-center gap-3">
          <img
            src="/favicon.png"
            alt=""
            class="h-9 w-9 transition-transform group-hover:scale-110"
            width="36"
            height="36"
            loading="lazy"
            decoding="async"
          />
          <span class="text-xl font-bold tracking-tight">Vstorm OSS</span>
        </a>
        <p class="text-text-secondary mt-4 text-sm leading-relaxed">
          Open-source tools for building production AI agents with Python. 13 repos, 1,730+ stars,
          830K+ PyPI downloads.
        </p>
        <div class="mt-6 flex items-center gap-3">
          <a
            href="https://github.com/vstorm-co"
            target="_blank"
            rel="noopener noreferrer"
            class="border-border text-text-tertiary hover:text-text hover:border-border-hover hover:bg-surface flex h-9 w-9 items-center justify-center rounded-lg border transition-all"
            aria-label="GitHub"
          >
            <svg class="h-[18px] w-[18px]" viewBox="0 0 24 24" fill="currentColor"
              ><path
                d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"
              ></path></svg
            >
          </a>
          <a
            href="https://www.linkedin.com/company/vstormco/"
            target="_blank"
            rel="noopener noreferrer"
            class="border-border text-text-tertiary hover:text-text hover:border-border-hover hover:bg-surface flex h-9 w-9 items-center justify-center rounded-lg border transition-all"
            aria-label="LinkedIn"
          >
            <svg class="h-[18px] w-[18px]" viewBox="0 0 24 24" fill="currentColor"
              ><path
                d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
              ></path></svg
            >
          </a>
          <a
            href="https://pypi.org/user/kacperwlodarczyk-vstorm/"
            target="_blank"
            rel="noopener noreferrer"
            class="border-border text-text-tertiary hover:text-text hover:border-border-hover hover:bg-surface flex h-9 w-9 items-center justify-center rounded-lg border transition-all"
            aria-label="PyPI"
          >
            <svg
              class="h-[18px] w-[18px]"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="m21 7.5-9-5.25L3 7.5m18 0-9 5.25m9-5.25v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25m0-9v9"
              ></path></svg
            >
          </a>
          <a
            href="https://www.youtube.com/@vstorm-ai-consultancy"
            target="_blank"
            rel="noopener noreferrer"
            class="border-border text-text-tertiary hover:text-text hover:border-border-hover hover:bg-surface flex h-9 w-9 items-center justify-center rounded-lg border transition-all"
            aria-label="YouTube"
          >
            <svg class="h-[18px] w-[18px]" viewBox="0 0 24 24" fill="currentColor"
              ><path
                d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"
              ></path></svg
            >
          </a>
        </div>
      </div>
      <div class="max-w-xs lg:text-right">
        <p class="text-sm font-semibold">
          {t["footer.oss.cta.title"]}
        </p>
        <p class="text-text-tertiary mt-2 text-xs leading-relaxed">
          We're <a
            href="https://vstorm.co"
            target="_blank"
            rel="noopener noreferrer"
            class="text-text hover:text-accent font-semibold underline underline-offset-2 transition-colors"
            >Vstorm</a
          > &mdash; {t["footer.cta.description"]}
        </p>
        <a
          href="https://vstorm.co/contact-us/"
          target="_blank"
          rel="noopener noreferrer"
          class="border-border hover:border-accent/40 hover:bg-surface mt-4 inline-flex items-center gap-2 rounded-full border px-5 py-2 text-xs font-semibold transition-colors"
        >
          {t["footer.cta.button"]}
          <svg
            class="h-3.5 w-3.5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"
            ></path>
          </svg>
        </a>
      </div>
    </div>
  </div>

  <!-- Link columns -->
  <div class="border-border/50 border-t">
    <div class="mx-auto max-w-[1400px] px-6 py-12 sm:px-8 lg:px-10">
      <div class="grid grid-cols-2 gap-8 sm:grid-cols-3 lg:grid-cols-5">
        <div class="col-span-2 sm:col-span-1">
          <h3 class="text-text-tertiary mb-4 text-[11px] font-bold tracking-wider uppercase">
            {t["nav.projects"]}
          </h3>
          <ul class="space-y-2.5">
            {
              releasedProjects.map((p) => (
                <li>
                  <a
                    href={getProjectHref(p.slug)}
                    class="text-text-secondary hover:text-text text-sm transition-colors"
                  >
                    {p.name}
                  </a>
                </li>
              ))
            }
            <li>
              <a
                href={`/projects/`}
                class="text-accent hover:text-accent-hover text-sm font-medium transition-colors"
                >{t["nav.projects"]} &rarr;</a
              >
            </li>
          </ul>
        </div>
        <div>
          <h3 class="text-text-tertiary mb-4 text-[11px] font-bold tracking-wider uppercase">
            {t["nav.resources"] ?? "Resources"}
          </h3>
          <ul class="space-y-2.5">
            <li>
              <a
                href={usecasesHref}
                class="text-text-secondary hover:text-text text-sm transition-colors"
                >{t["nav.usecases"] ?? "Use Cases"}</a
              >
            </li>
            <li>
              <a
                href={guidesHref}
                class="text-text-secondary hover:text-text text-sm transition-colors"
                >{t["nav.guides"] ?? "Guides"}</a
              >
            </li>
            <li>
              <a
                href={toolsHref}
                class="text-text-secondary hover:text-text text-sm transition-colors"
                >{t["nav.tools"] ?? "Free Tools"}</a
              >
            </li>
            <li>
              <a
                href={compareHref}
                class="text-text-secondary hover:text-text text-sm transition-colors"
                >{t["nav.compare"] ?? "Compare"}</a
              >
            </li>
            <li>
              <a
                href="/glossary/"
                class="text-text-secondary hover:text-text text-sm transition-colors">Glossary</a
              >
            </li>
            <li>
              <a
                href={`/changelog/`}
                class="text-text-secondary hover:text-text text-sm transition-colors"
                >{t["changelog.title"] ?? "Changelog"}</a
              >
            </li>
          </ul>
        </div>
        <div>
          <h3 class="text-text-tertiary mb-4 text-[11px] font-bold tracking-wider uppercase">
            {t["nav.compare"] ?? "Compare"}
          </h3>
          <ul class="space-y-2.5">
            {
              comparisons.map((c) => (
                <li>
                  <a
                    href={`/compare/${c.slug}/`}
                    class="text-text-secondary hover:text-text text-sm transition-colors"
                  >
                    {c.product} vs {c.competitor}
                  </a>
                </li>
              ))
            }
            <li>
              <a
                href={compareHref}
                class="text-accent hover:text-accent-hover text-sm font-medium transition-colors"
                >{t["nav.compare"] ?? "Compare"} &rarr;</a
              >
            </li>
          </ul>
        </div>
        <div>
          <h3 class="text-text-tertiary mb-4 text-[11px] font-bold tracking-wider uppercase">
            {t["nav.blog"]}
          </h3>
          <ul class="space-y-2.5">
            {
              recentPosts.map((post) => (
                <li>
                  <a
                    href={`/blog/${post.data.translationKey}/`}
                    class="text-text-secondary hover:text-text line-clamp-2 text-sm leading-snug transition-colors"
                  >
                    {post.data.title}
                  </a>
                </li>
              ))
            }
            <li>
              <a
                href={blogHref}
                class="text-accent hover:text-accent-hover text-sm font-medium transition-colors"
                >{t["nav.blog"]} &rarr;</a
              >
            </li>
          </ul>
        </div>
        <div>
          <h3 class="text-text-tertiary mb-4 text-[11px] font-bold tracking-wider uppercase">
            {t["nav.about"]}
          </h3>
          <ul class="space-y-2.5">
            <li>
              <a
                href={aboutHref}
                class="text-text-secondary hover:text-text text-sm transition-colors"
                >{t["nav.about"]}</a
              >
            </li>
            <li>
              <a
                href="https://vstorm.co/contact-us/"
                target="_blank"
                rel="noopener noreferrer"
                class="text-text-secondary hover:text-text text-sm transition-colors"
                >{t["footer.cta.button"]}</a
              >
            </li>
            <li>
              <a
                href="https://github.com/vstorm-co"
                target="_blank"
                rel="noopener noreferrer"
                class="text-text-secondary hover:text-text text-sm transition-colors">GitHub</a
              >
            </li>
            <li>
              <a
                href="https://pypi.org/user/kacperwlodarczyk-vstorm/"
                target="_blank"
                rel="noopener noreferrer"
                class="text-text-secondary hover:text-text text-sm transition-colors">PyPI</a
              >
            </li>
            <li>
              <a
                href="https://www.linkedin.com/company/vstormco/"
                target="_blank"
                rel="noopener noreferrer"
                class="text-text-secondary hover:text-text text-sm transition-colors">LinkedIn</a
              >
            </li>
            <li>
              <a
                href="https://www.youtube.com/@vstorm-ai-consultancy"
                target="_blank"
                rel="noopener noreferrer"
                class="text-text-secondary hover:text-text text-sm transition-colors">YouTube</a
              >
            </li>
            <li>
              <a
                href="https://vstorm.co"
                target="_blank"
                rel="noopener noreferrer"
                class="text-text-secondary hover:text-text text-sm transition-colors">vstorm.co</a
              >
            </li>
            <li>
              <a
                href="/privacy/"
                class="text-text-secondary hover:text-text text-sm transition-colors"
                >Privacy Policy</a
              >
            </li>
            <li>
              <a
                href="/terms/"
                class="text-text-secondary hover:text-text text-sm transition-colors"
                >Terms of Service</a
              >
            </li>
          </ul>
        </div>
      </div>
    </div>
  </div>

  <!-- Bottom bar -->
  <div class="border-border/50 border-t">
    <div class="mx-auto max-w-[1400px] px-6 py-6 sm:px-8 lg:px-10">
      <div class="flex flex-col items-center justify-between gap-4 sm:flex-row">
        <p class="text-text-tertiary text-xs">
          &copy; {new Date().getFullYear()} Vstorm. {t["footer.built"]}
          <span class="text-accent">&hearts;</span>
          <a
            href="https://vstorm.co"
            target="_blank"
            rel="noopener noreferrer"
            class="text-text hover:text-accent underline underline-offset-2 transition-colors"
            >Vstorm</a
          >
        </p>
        <div class="flex items-center gap-4">
          <a
            href="https://github.com/vstorm-co"
            target="_blank"
            rel="noopener noreferrer"
            class="text-text-tertiary hover:text-text transition-colors"
            aria-label="GitHub"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"
              ><path
                d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"
              ></path></svg
            >
          </a>
          <a
            href="https://www.linkedin.com/company/vstormco/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-text-tertiary hover:text-text transition-colors"
            aria-label="LinkedIn"
          >
            <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor"
              ><path
                d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"
              ></path></svg
            >
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>
