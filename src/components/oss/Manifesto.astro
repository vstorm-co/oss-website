---
interface Props {
  t: Record<string, string>;
}

const { t } = Astro.props;

const principles = [
  {
    icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 0 1 6 3.75h2.25A2.25 2.25 0 0 1 10.5 6v2.25a2.25 2.25 0 0 1-2.25 2.25H6a2.25 2.25 0 0 1-2.25-2.25V6ZM3.75 15.75A2.25 2.25 0 0 1 6 13.5h2.25a2.25 2.25 0 0 1 2.25 2.25V18a2.25 2.25 0 0 1-2.25 2.25H6A2.25 2.25 0 0 1 3.75 18v-2.25ZM13.5 6a2.25 2.25 0 0 1 2.25-2.25H18A2.25 2.25 0 0 1 20.25 6v2.25A2.25 2.25 0 0 1 18 10.5h-2.25a2.25 2.25 0 0 1-2.25-2.25V6ZM13.5 15.75a2.25 2.25 0 0 1 2.25-2.25H18a2.25 2.25 0 0 1 2.25 2.25V18A2.25 2.25 0 0 1 18 20.25h-2.25a2.25 2.25 0 0 1-2.25-2.25v-2.25Z"/></svg>`,
    title: t["oss.manifesto.p1.title"],
    desc: t["oss.manifesto.p1.desc"],
  },
  {
    icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z"/></svg>`,
    title: t["oss.manifesto.p2.title"],
    desc: t["oss.manifesto.p2.desc"],
  },
  {
    icon: `<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 0 0 3.741-.479 3 3 0 0 0-4.682-2.72m.94 3.198.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0 1 12 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 0 1 6 18.719m12 0a5.971 5.971 0 0 0-.941-3.197m0 0A5.995 5.995 0 0 0 12 12.75a5.995 5.995 0 0 0-5.058 2.772m0 0a3 3 0 0 0-4.681 2.72 8.986 8.986 0 0 0 3.74.477m.94-3.197a5.971 5.971 0 0 0-.94 3.197M15 6.75a3 3 0 1 1-6 0 3 3 0 0 1 6 0Zm6 3a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Zm-13.5 0a2.25 2.25 0 1 1-4.5 0 2.25 2.25 0 0 1 4.5 0Z"/></svg>`,
    title: t["oss.manifesto.p3.title"],
    desc: t["oss.manifesto.p3.desc"],
  },
];
---

<section class="px-4 py-24 sm:px-6 sm:py-32 lg:px-8 lg:py-40" style="background: #111118;">
  <div class="mx-auto max-w-4xl">
    <div class="reveal text-center mb-12">
      <h2 class="text-3xl font-bold tracking-[-0.02em] sm:text-4xl heading-accent">{t["oss.manifesto.title"]}</h2>
    </div>

    <div class="reveal mx-auto max-w-3xl">
      <blockquote class="relative rounded-2xl border border-border bg-surface/50 px-8 py-8 sm:px-12 sm:py-10">
        <svg class="absolute top-6 left-6 h-8 w-8 text-accent/20 sm:top-8 sm:left-8" fill="currentColor" viewBox="0 0 24 24">
          <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10H14.017zM0 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151C7.546 6.068 5.983 8.789 5.983 11H10v10H0z"/>
        </svg>
        <p class="relative z-10 text-base leading-relaxed text-text-secondary sm:text-lg">
          {t["oss.manifesto.quote"]}
        </p>
        <footer class="mt-6 flex items-center gap-3">
          <div class="h-px flex-1 bg-border"></div>
          <span class="text-sm font-medium text-text-tertiary">{t["oss.manifesto.author"]}</span>
        </footer>
      </blockquote>
    </div>

    <div class="reveal-group mt-12 grid gap-6 sm:grid-cols-3">
      {principles.map((p) => (
        <div class="reveal flex flex-col items-center text-center rounded-2xl border border-border bg-surface/30 p-6 transition-colors hover:border-accent/30">
          <div class="flex h-10 w-10 items-center justify-center rounded-xl bg-accent/10 text-accent mb-4">
            <Fragment set:html={p.icon} />
          </div>
          <h3 class="text-sm font-semibold mb-2">{p.title}</h3>
          <p class="text-xs leading-relaxed text-text-secondary">{p.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>
