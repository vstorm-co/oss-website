---
import type { translations } from "../../i18n/translations";

interface Props {
  t: typeof translations.en;
}

const { t } = Astro.props;
---

<section
  class="relative flex min-h-[100svh] items-center justify-center overflow-hidden px-4 sm:px-6 lg:px-8"
>
  <!-- Gradient glow -->
  <div class="pointer-events-none absolute inset-0">
    <div
      class="bg-accent/[0.12] absolute top-[5%] left-1/2 h-[400px] w-[500px] -translate-x-1/2 rounded-full blur-[120px] sm:h-[800px] sm:w-[1000px] sm:blur-[200px]"
    >
    </div>
    <div
      class="absolute top-[10%] left-[30%] h-[300px] w-[350px] -translate-x-1/2 rounded-full bg-orange-500/[0.07] blur-[100px] sm:h-[600px] sm:w-[700px] sm:blur-[160px]"
    >
    </div>
    <div
      class="absolute top-[20%] right-[0%] h-[250px] w-[250px] rounded-full bg-rose-500/[0.05] blur-[80px] sm:h-[500px] sm:w-[500px] sm:blur-[140px]"
    >
    </div>
  </div>

  <!-- Bottom fade-out gradient -->
  <div
    class="from-bg pointer-events-none absolute inset-x-0 bottom-0 h-32 bg-gradient-to-t to-transparent"
  >
  </div>

  <div class="relative mx-auto max-w-4xl text-center">
    <!-- Badge -->
    <div
      class="border-accent/20 bg-accent/[0.06] text-text-secondary mb-8 inline-flex items-center rounded-full border px-4 py-1.5 text-sm"
    >
      <span class="bg-accent mr-2 inline-block h-1.5 w-1.5 animate-pulse rounded-full"></span>
      {t["oss.hero.badge"]}
    </div>

    <!-- Headline -->
    <h1 class="text-4xl font-bold tracking-[-0.02em] sm:text-5xl lg:text-6xl">
      {t["oss.hero.title.line1"]}{" "}
      <span class="from-accent bg-gradient-to-r to-orange-400 bg-clip-text text-transparent"
        >{t["oss.hero.title.highlight"]}</span
      >
      <br />
      {t["oss.hero.title.line2"]}
    </h1>

    <!-- Description -->
    <p class="text-text-secondary mx-auto mt-6 max-w-2xl text-lg leading-relaxed">
      {t["oss.hero.description"]}
    </p>

    <!-- CTA Buttons -->
    <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
      <a
        href="/projects/full-stack-ai-agent-template/configurator/"
        class="bg-accent hover:bg-accent-hover hover:shadow-accent/25 inline-flex items-center rounded-full px-8 py-3.5 text-base font-semibold text-white transition-all hover:shadow-lg"
      >
        {t["oss.hero.cta.configure"]}
        <svg
          class="ml-2 h-4 w-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
        </svg>
      </a>
      <a
        href="#projects"
        class="text-text inline-flex items-center rounded-full border border-white/[0.1] bg-white/[0.04] px-8 py-3.5 text-base font-semibold backdrop-blur-sm transition-all hover:border-white/[0.2] hover:bg-white/[0.08]"
      >
        {t["oss.hero.cta.explore"]}
        <svg
          class="ml-2 h-4 w-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3"
          ></path>
        </svg>
      </a>
    </div>

    <!-- Vstorm consultancy banner -->
    <div class="mx-auto mt-14 max-w-xl">
      <a
        href="https://vstorm.co/contact-us/"
        target="_blank"
        rel="noopener noreferrer"
        class="group hover:border-accent/30 block rounded-2xl border border-white/[0.08] bg-white/[0.03] p-5 backdrop-blur-sm transition-all hover:bg-white/[0.06] sm:p-6"
      >
        <p class="text-text text-sm font-semibold sm:text-base">
          {t["oss.hero.consultancy.title"]}
        </p>
        <p class="text-text-secondary mt-1.5 text-sm leading-relaxed">
          {t["oss.hero.consultancy.description"]}
        </p>
        <span
          class="text-accent mt-3 inline-flex items-center gap-1.5 text-sm font-medium transition-all group-hover:gap-2.5"
        >
          {t["footer.cta.button"]}
          <svg
            class="h-3.5 w-3.5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"
            ></path>
          </svg>
        </span>
      </a>
    </div>
  </div>

  <!-- Scroll arrow -->
  <button
    class="hero-scroll-arrow"
    aria-label="Scroll down"
    onclick="this.closest('section').nextElementSibling?.scrollIntoView({behavior:'smooth'})"
  >
    <svg
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
      stroke-linecap="round"
      stroke-linejoin="round"><path d="M7 10l5 5 5-5"></path></svg
    >
  </button>
</section>
