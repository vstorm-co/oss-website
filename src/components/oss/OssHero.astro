---
import type { translations } from '../../i18n/translations';

interface Props {
  t: typeof translations.en;
}

const { t } = Astro.props;
---

<section class="relative flex min-h-[100svh] items-center justify-center overflow-hidden px-4 sm:px-6 lg:px-8">
  <!-- Gradient glow -->
  <div class="pointer-events-none absolute inset-0">
    <div class="absolute top-[5%] left-1/2 h-[400px] w-[500px] sm:h-[800px] sm:w-[1000px] -translate-x-1/2 rounded-full bg-accent/[0.12] blur-[120px] sm:blur-[200px]"></div>
    <div class="absolute top-[10%] left-[30%] h-[300px] w-[350px] sm:h-[600px] sm:w-[700px] -translate-x-1/2 rounded-full bg-orange-500/[0.07] blur-[100px] sm:blur-[160px]"></div>
    <div class="absolute top-[20%] right-[0%] h-[250px] w-[250px] sm:h-[500px] sm:w-[500px] rounded-full bg-rose-500/[0.05] blur-[80px] sm:blur-[140px]"></div>
  </div>

  <!-- Bottom fade-out gradient -->
  <div class="pointer-events-none absolute inset-x-0 bottom-0 h-32 bg-gradient-to-t from-bg to-transparent"></div>

  <div class="relative mx-auto max-w-4xl text-center">
    <!-- Badge -->
    <div class="mb-8 inline-flex items-center rounded-full border border-accent/20 bg-accent/[0.06] px-4 py-1.5 text-sm text-text-secondary">
      <span class="mr-2 inline-block h-1.5 w-1.5 rounded-full bg-accent animate-pulse"></span>
      {t["oss.hero.badge"]}
    </div>

    <!-- Headline -->
    <h1 class="text-4xl font-bold tracking-[-0.02em] sm:text-5xl lg:text-6xl">
      {t["oss.hero.title.line1"]}{" "}
      <span class="bg-gradient-to-r from-accent to-orange-400 bg-clip-text text-transparent">{t["oss.hero.title.highlight"]}</span>
      <br />
      {t["oss.hero.title.line2"]}
    </h1>

    <!-- Description -->
    <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-text-secondary">
      {t["oss.hero.description"]}
    </p>

    <!-- CTA Buttons -->
    <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
      <a
        href="#projects"
        class="inline-flex items-center rounded-full bg-accent px-8 py-3.5 text-base font-semibold text-white transition-all hover:bg-accent-hover hover:shadow-lg hover:shadow-accent/25"
      >
        {t["oss.hero.cta.explore"]}
        <svg class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
        </svg>
      </a>
      <a
        href="https://github.com/vstorm-co"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center rounded-full border border-white/[0.1] bg-white/[0.04] backdrop-blur-sm px-8 py-3.5 text-base font-semibold text-text transition-all hover:border-white/[0.2] hover:bg-white/[0.08]"
      >
        <svg class="mr-2 h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
        </svg>
        {t["oss.hero.cta.github"]}
      </a>
    </div>

    <!-- Vstorm consultancy banner -->
    <div class="mt-14 mx-auto max-w-xl">
      <a
        href="https://vstorm.co/contact-us/"
        target="_blank"
        rel="noopener noreferrer"
        class="group block rounded-2xl border border-white/[0.08] bg-white/[0.03] backdrop-blur-sm p-5 sm:p-6 transition-all hover:border-accent/30 hover:bg-white/[0.06]"
      >
        <p class="text-sm font-semibold text-text sm:text-base">
          {t["oss.hero.consultancy.title"]}
        </p>
        <p class="mt-1.5 text-sm text-text-secondary leading-relaxed">
          {t["oss.hero.consultancy.description"]}
        </p>
        <span class="mt-3 inline-flex items-center gap-1.5 text-sm font-medium text-accent group-hover:gap-2.5 transition-all">
          {t["footer.cta.button"]}
          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </span>
      </a>
    </div>
  </div>

  <!-- Scroll arrow -->
  <button class="hero-scroll-arrow" aria-label="Scroll down" onclick="this.closest('section').nextElementSibling?.scrollIntoView({behavior:'smooth'})">
    <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M7 10l5 5 5-5"/></svg>
  </button>
</section>
