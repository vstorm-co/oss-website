---
import { isPublished } from "@/lib/blog";
import { getCollection } from "astro:content";

interface Props {
  t: Record<string, string>;
  lang: string;
}

const { t, lang } = Astro.props;
const blogHref = lang === "en" ? "/blog/" : `/${lang}/blog/`;

const posts = (await getCollection("blog", ({ data }) => data.lang === lang && isPublished(data)))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const formatDate = (date: Date) =>
  date.toLocaleDateString(lang, { year: "numeric", month: "short", day: "numeric" });

const postHref = (postId: string) => {
  const slug = postId.split("/").slice(1).join("/");
  return lang === "en" ? `/blog/${slug}/` : `/${lang}/blog/${slug}/`;
};
---

<section
  class="section-light border-t border-[#e5e7eb] px-4 py-24 sm:px-6 sm:py-32 lg:px-8 lg:py-40"
>
  <div class="mx-auto max-w-4xl">
    <div class="reveal mb-12 text-center">
      <h2 class="heading-accent text-3xl font-bold tracking-[-0.02em] sm:text-4xl">
        {t["oss.recentPosts.title"]}
      </h2>
      <p class="text-text-secondary mt-4 text-lg">{t["oss.recentPosts.subtitle"]}</p>
    </div>

    {
      posts.length > 0 && (
        <div class="reveal grid gap-6 sm:grid-cols-3">
          {posts.map((post) => (
            <a
              href={postHref(post.id)}
              class="border-border hover:border-accent/40 block rounded-xl border bg-white p-6 shadow-sm transition-all hover:shadow-md"
            >
              <time class="text-text-tertiary font-mono text-xs">
                {formatDate(post.data.pubDate)}
              </time>
              <h3 class="mt-3 text-base leading-snug font-semibold">{post.data.title}</h3>
              <p class="text-text-secondary mt-2 line-clamp-2 text-sm leading-relaxed">
                {post.data.description}
              </p>
            </a>
          ))}
        </div>
      )
    }

    <div class="reveal mt-8 text-center">
      <a
        href={blogHref}
        class="text-text-secondary hover:text-accent inline-flex items-center gap-2 text-sm font-medium transition-colors"
      >
        {t["oss.recentPosts.viewAll"]}
      </a>
    </div>
  </div>
</section>
