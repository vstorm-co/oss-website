---
interface Props {
  t: Record<string, string>;
}

const { t } = Astro.props;
---

<section class="reveal px-4 py-12 sm:px-6 sm:py-16 lg:px-8" style="background-color: #09090b;">
  <div class="mx-auto max-w-5xl text-center">
    <p class="text-xs font-medium uppercase tracking-[0.2em] text-text-tertiary mb-8">{t["oss.trustedby.title"]}</p>

    <div class="flex flex-wrap items-center justify-center gap-x-10 gap-y-4 sm:gap-x-14">
      <!-- LangChain -->
      <div class="flex items-center gap-2 text-text-secondary/70 hover:text-text-secondary transition-colors">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09Z"/></svg>
        <span class="text-sm font-semibold tracking-tight">LangChain</span>
        <span class="text-xs text-text-tertiary">492K</span>
      </div>

      <!-- Pydantic -->
      <div class="flex items-center gap-2 text-text-secondary/70 hover:text-text-secondary transition-colors">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
        <span class="text-sm font-semibold tracking-tight">Pydantic</span>
        <span class="text-xs text-text-tertiary">22K</span>
      </div>

      <!-- 600+ reactions -->
      <div class="flex items-center gap-2 text-text-secondary/70">
        <span class="text-sm font-semibold tracking-tight text-accent" data-count-up>612</span>
        <span class="text-xs text-text-tertiary">{t["oss.trustedby.reactions"]}</span>
      </div>

      <!-- 1,270+ stars -->
      <div class="flex items-center gap-2 text-text-secondary/70">
        <svg class="w-4 h-4 text-amber-400" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
        <span class="text-sm font-semibold tracking-tight" data-count-up>1,730+</span>
        <span class="text-xs text-text-tertiary">{t["oss.trustedby.stars"]}</span>
      </div>

      <!-- 285K+ downloads -->
      <div class="flex items-center gap-2 text-text-secondary/70">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3"/></svg>
        <span class="text-sm font-semibold tracking-tight" data-count-up>830K+</span>
        <span class="text-xs text-text-tertiary">{t["oss.trustedby.downloads"]}</span>
      </div>
    </div>
  </div>
</section>
