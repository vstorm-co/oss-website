---
import type { Lang } from '../../i18n/translations';
import { getProjectsByCategory } from '../../data/projects';
import ProjectCard from './ProjectCard.astro';

interface Props {
  lang: Lang;
  t: Record<string, string>;
}

const { lang, t } = Astro.props;
const grouped = getProjectsByCategory(lang);
---

<section id="projects" class="px-4 pt-28 pb-24 sm:px-6 sm:pt-36 sm:pb-32 lg:px-8 lg:pb-40">
  <div class="mx-auto max-w-6xl">
    <div class="reveal text-center mb-16">
      <h2 class="text-3xl font-bold tracking-[-0.02em] sm:text-4xl heading-accent">{t["oss.projects.title"]}</h2>
      <p class="mt-4 text-lg text-text-secondary max-w-2xl mx-auto">{t["oss.projects.subtitle"]}</p>
    </div>

    {grouped.map((group) => (
      <div class="mb-14 last:mb-0">
        <h3 class="reveal mb-6 text-sm font-bold uppercase tracking-wider text-text-secondary">
          <span class="text-accent mr-1.5">&#10095;</span>{group.label[lang]}
        </h3>
        <div class="reveal-group grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
          {group.projects.map((project) => (
            <div class="reveal h-full">
              <ProjectCard project={project} lang={lang} t={t} />
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</section>
