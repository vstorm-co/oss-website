---
interface Props {
  t: Record<string, string>;
}

const { t } = Astro.props;

const releases = [
  {
    date: "2026-03-05",
    version: "v0.3.0",
    project: "pydantic-deepagents",
    title: t["oss.changelog.1.title"],
    description: t["oss.changelog.1.desc"],
    tag: "framework",
  },
  {
    date: "2026-02-28",
    version: "v2.1.0",
    project: "fastapi-fullstack",
    title: t["oss.changelog.2.title"],
    description: t["oss.changelog.2.desc"],
    tag: "template",
  },
  {
    date: "2026-02-20",
    version: "v1.0.0",
    project: "logfire-assistant",
    title: t["oss.changelog.3.title"],
    description: t["oss.changelog.3.desc"],
    tag: "tool",
  },
];

const formatDate = (dateStr: string) => {
  const d = new Date(dateStr);
  return d.toLocaleDateString("en", { month: "short", day: "numeric" });
};
---

<section
  class="section-light border-t border-[#e5e7eb] px-4 py-24 sm:px-6 sm:py-32 lg:px-8 lg:py-40"
>
  <div class="mx-auto max-w-3xl">
    <div class="reveal mb-12 text-center">
      <h2 class="heading-accent text-3xl font-bold tracking-[-0.02em] sm:text-4xl">
        {t["oss.changelog.title"]}
      </h2>
      <p class="text-text-secondary mt-4 text-lg">{t["oss.changelog.subtitle"]}</p>
    </div>

    <div class="reveal space-y-0">
      {
        releases.map((release, i) => (
          <div class="relative flex gap-5 pb-8 last:pb-0">
            {/* Timeline line */}
            {i < releases.length - 1 && (
              <div class="bg-border absolute top-6 bottom-0 left-[11px] w-px" />
            )}

            {/* Dot */}
            <div class="border-accent bg-bg relative z-10 mt-1.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full border-2">
              <div class="bg-accent h-2 w-2 rounded-full" />
            </div>

            {/* Content */}
            <div class="glass-card flex-1 rounded-xl p-4 sm:p-5">
              <div class="mb-1.5 flex flex-wrap items-center gap-2">
                <span class="text-text-tertiary font-mono text-xs">{formatDate(release.date)}</span>
                <span class="bg-accent/10 text-accent rounded-full px-2 py-0.5 text-[11px] font-semibold">
                  {release.version}
                </span>
                <span class="border-border text-text-tertiary rounded-full border px-2 py-0.5 text-[11px]">
                  {release.project}
                </span>
              </div>
              <h3 class="text-sm font-semibold sm:text-base">{release.title}</h3>
              <p class="text-text-secondary mt-1 text-sm leading-relaxed">{release.description}</p>
            </div>
          </div>
        ))
      }
    </div>

    <div class="reveal mt-8 text-center">
      <a
        href="/changelog/"
        class="text-text-secondary hover:text-accent inline-flex items-center gap-2 text-sm font-medium transition-colors"
      >
        {t["oss.changelog.viewAll"]}
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"></path>
        </svg>
      </a>
    </div>
  </div>
</section>
