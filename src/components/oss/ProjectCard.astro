---
import type { Lang } from '../../i18n/translations';
import type { Project } from '../../data/projects';
import { categories } from '../../data/projects';

interface Props {
  project: Project;
  lang: Lang;
  t: Record<string, string>;
}

const { project, lang, t } = Astro.props;
const isComingSoon = project.status === "coming-soon";
const href = lang === "en" ? `/projects/${project.slug}/` : `/${lang}/projects/${project.slug}/`;
const cat = categories.find((c) => c.id === project.category);
const categoryLabel = cat ? cat.label[lang] : project.category;
---

<a
  href={href}
  class:list={[
    "group relative flex h-full flex-col rounded-2xl border bg-white p-7 sm:p-8 shadow-sm hover:shadow-lg card-hover",
    isComingSoon
      ? "border-border/50 opacity-60 pointer-events-none"
      : "border-border hover:border-accent/40",
  ]}
>
  {/* Category badge */}
  <div class="flex items-center gap-2 mb-4">
    <span class="rounded-full bg-accent/10 px-3 py-1 text-[11px] font-semibold text-accent uppercase tracking-wider badge-hover">
      {categoryLabel}
    </span>
    {isComingSoon && (
      <span class="rounded-full bg-surface-hover px-2.5 py-0.5 text-[11px] font-medium text-text-tertiary">
        {t["oss.card.comingSoon"]}
      </span>
    )}
  </div>

  <h3 class="text-lg font-bold group-hover:text-accent transition-colors">{project.name}</h3>
  <p class="mt-2 text-sm text-text-secondary leading-relaxed line-clamp-3">{project.tagline[lang]}</p>

  {/* Features */}
  {project.features[lang] && project.features[lang].length > 0 && (
    <div class="mt-4 flex flex-wrap gap-1.5">
      {project.features[lang].slice(0, 3).map((feat: string) => (
        <span class="rounded-md border border-border bg-surface/50 px-2 py-0.5 text-[11px] text-text-tertiary tag-hover">
          {feat}
        </span>
      ))}
    </div>
  )}

  <div class="flex-1"></div>

  {!isComingSoon && (
    <div class="mt-6 flex items-center text-sm font-medium text-accent arrow-slide">
      <span>{t["oss.card.viewProject"]}</span>
      <svg class="ml-1.5 w-4 h-4 transition-transform group-hover:translate-x-1.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3" />
      </svg>
    </div>
  )}
</a>
