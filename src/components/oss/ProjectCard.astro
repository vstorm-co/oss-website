---
import type { Lang } from "../../i18n/translations";
import type { Project } from "../../data/projects";
import { categories } from "../../data/projects";

interface Props {
  project: Project;
  lang: Lang;
  t: Record<string, string>;
}

const { project, lang, t } = Astro.props;
const isComingSoon = project.status === "coming-soon";
const href = lang === "en" ? `/projects/${project.slug}/` : `/${lang}/projects/${project.slug}/`;
const cat = categories.find((c) => c.id === project.category);
const categoryLabel = cat ? cat.label[lang] : project.category;
---

<a
  href={href}
  class:list={[
    "group card-hover relative flex h-full flex-col rounded-2xl border bg-white p-7 shadow-sm hover:shadow-lg sm:p-8",
    isComingSoon
      ? "border-border/50 pointer-events-none opacity-60"
      : "border-border hover:border-accent/40",
  ]}
>
  {/* Category badge */}
  <div class="mb-4 flex items-center gap-2">
    <span
      class="bg-accent/10 text-accent badge-hover rounded-full px-3 py-1 text-[11px] font-semibold tracking-wider uppercase"
    >
      {categoryLabel}
    </span>
    {
      isComingSoon && (
        <span class="bg-surface-hover text-text-tertiary rounded-full px-2.5 py-0.5 text-[11px] font-medium">
          {t["oss.card.comingSoon"]}
        </span>
      )
    }
  </div>

  <h3 class="group-hover:text-accent text-lg font-bold transition-colors">{project.name}</h3>
  <p class="text-text-secondary mt-2 line-clamp-3 text-sm leading-relaxed">
    {project.tagline[lang]}
  </p>

  {/* Features */}
  {
    project.features[lang] && project.features[lang].length > 0 && (
      <div class="mt-4 flex flex-wrap gap-1.5">
        {project.features[lang].slice(0, 3).map((feat: string) => (
          <span class="border-border bg-surface/50 text-text-tertiary tag-hover rounded-md border px-2 py-0.5 text-[11px]">
            {feat}
          </span>
        ))}
      </div>
    )
  }

  <div class="flex-1"></div>

  {
    !isComingSoon && (
      <div class="text-accent arrow-slide mt-6 flex items-center text-sm font-medium">
        <span>{t["oss.card.viewProject"]}</span>
        <svg
          class="ml-1.5 h-4 w-4 transition-transform group-hover:translate-x-1.5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"
          />
        </svg>
      </div>
    )
  }
</a>
