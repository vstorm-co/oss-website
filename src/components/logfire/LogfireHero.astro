---
import type { translations } from "../../i18n/translations";
import StarsBadge from "../shared/StarsBadge.astro";

interface Props {
  t: typeof translations.en;
}

const { t } = Astro.props;
const rawBase = import.meta.env.BASE_URL;
const base = rawBase.endsWith("/") ? rawBase : rawBase + "/";
---

<section
  class="relative overflow-hidden px-4 pt-32 pb-24 sm:px-6 sm:pt-40 sm:pb-28 lg:px-8 lg:pt-48 lg:pb-36"
>
  <!-- Gradient glow (pink/magenta — Logfire brand) -->
  <div class="pointer-events-none absolute inset-0 overflow-hidden">
    <div
      class="absolute top-[-10%] left-1/2 h-[400px] w-[400px] -translate-x-1/2 rounded-full bg-pink-500/[0.07] blur-[100px] sm:top-[-30%] sm:h-[800px] sm:w-[800px] sm:blur-[150px]"
    >
    </div>
    <div
      class="absolute top-[-5%] left-[40%] h-[300px] w-[300px] -translate-x-1/2 rounded-full bg-fuchsia-500/[0.05] blur-[80px] sm:top-[-20%] sm:h-[600px] sm:w-[600px] sm:blur-[130px]"
    >
    </div>
  </div>

  <div class="relative mx-auto max-w-5xl text-center">
    <!-- Badge -->
    <div
      class="border-border text-text-secondary mb-8 inline-flex items-center rounded-full border px-4 py-1.5 text-sm"
    >
      <span class="mr-2 inline-block h-1.5 w-1.5 rounded-full bg-pink-500"></span>
      {t["logfire.hero.badge"]}
    </div>

    <!-- Headline -->
    <h1 class="text-4xl font-bold tracking-[-0.02em] sm:text-5xl lg:text-6xl">
      {t["logfire.hero.title.line1"]}{" "}
      <span class="bg-gradient-to-r from-pink-500 to-fuchsia-500 bg-clip-text text-transparent"
        >{t["logfire.hero.title.highlight"]}</span
      >
      <br />
      {t["logfire.hero.title.line2"]}
    </h1>

    <!-- Description -->
    <p class="text-text-secondary mx-auto mt-6 max-w-2xl text-lg leading-relaxed">
      {t["logfire.hero.description"]}
    </p>

    <!-- CTA Buttons -->
    <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
      <a
        href="https://github.com/vstorm-co/logfire-assistant"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center rounded-full bg-pink-500 px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-pink-600"
      >
        {t["logfire.hero.cta.getStarted"]}
        <svg
          class="ml-2 h-4 w-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"></path>
        </svg>
      </a>
      <a
        href="https://vstorm-co.github.io/logfire-assistant/"
        target="_blank"
        rel="noopener noreferrer"
        class="border-border text-text hover:border-border-hover hover:bg-surface inline-flex items-center gap-2 rounded-full border px-8 py-3 text-base font-semibold transition-colors"
      >
        {t["logfire.hero.cta.docs"]}
        <StarsBadge repo="vstorm-co/logfire-assistant" />
      </a>
    </div>

    <!-- Hero Product Screenshot -->
    <div
      class="border-border mx-auto mt-16 overflow-hidden rounded-2xl border shadow-2xl shadow-black/20"
    >
      <img
        src={`${base}logfire/home-page.png`}
        alt="Logfire Assistant — Chrome extension sidebar next to Logfire dashboard"
        class="h-auto w-full"
        loading="eager"
      />
    </div>
  </div>

  <!-- Scroll arrow -->
  <button
    class="hero-scroll-arrow"
    aria-label="Scroll down"
    onclick="this.closest('section').nextElementSibling?.scrollIntoView({behavior:'smooth'})"
  >
    <svg
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
      stroke-linecap="round"
      stroke-linejoin="round"><path d="M7 10l5 5 5-5"></path></svg
    >
  </button>
</section>
