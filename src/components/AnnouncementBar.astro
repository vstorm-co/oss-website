---
const message = "We're open source — help us grow!";
const ctaText = "Star us on GitHub";
---

<div
  id="announcement-bar"
  class="announcement-bar fixed top-0 right-0 left-0 z-50 hidden"
  role="banner"
>
  <div
    class="announcement-bg relative flex items-center justify-center px-10 py-2 text-[13px] text-white sm:text-sm"
  >
    <!-- Animated shimmer overlay -->
    <div class="announcement-shimmer pointer-events-none absolute inset-0" aria-hidden="true"></div>

    <div class="relative flex items-center gap-2 sm:gap-3">
      <!-- Sparkle -->
      <svg
        class="announcement-sparkle h-3.5 w-3.5 shrink-0 sm:h-4 sm:w-4"
        fill="currentColor"
        viewBox="0 0 24 24"
      >
        <path
          d="M9.813 15.904L9 18.75l-.813-2.846a4.5 4.5 0 00-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 003.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 003.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 00-3.09 3.09zM18.259 8.715L18 9.75l-.259-1.035a3.375 3.375 0 00-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 002.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 002.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 00-2.456 2.456z"
        ></path>
      </svg>

      <span class="hidden sm:inline">{message}</span>

      <a
        href="https://github.com/vstorm-co"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-1.5 rounded-full bg-white/15 px-3 py-0.5 text-[12px] font-semibold text-white backdrop-blur-sm transition-all hover:bg-white/25 sm:text-[13px]"
      >
        <svg class="h-3.5 w-3.5" fill="currentColor" viewBox="0 0 24 24">
          <path
            d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
          ></path>
        </svg>
        <svg class="h-3 w-3" fill="currentColor" viewBox="0 0 24 24">
          <path
            d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"
          ></path>
        </svg>
        {ctaText}
      </a>
    </div>

    <!-- Close button -->
    <button
      id="announcement-close"
      class="absolute top-1/2 right-2 flex h-6 w-6 -translate-y-1/2 cursor-pointer items-center justify-center rounded-full text-white/60 transition-colors hover:bg-white/10 hover:text-white sm:right-3"
      aria-label="Close"
    >
      <svg
        class="h-3.5 w-3.5"
        fill="none"
        viewBox="0 0 24 24"
        stroke="currentColor"
        stroke-width="2.5"
      >
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"></path>
      </svg>
    </button>
  </div>
</div>

<script is:inline>
  document.addEventListener("astro:page-load", function () {
    let dismissed = false;
    try {
      dismissed = sessionStorage.getItem("announcement-dismissed") === "1";
    } catch (e) {}

    const bar = document.getElementById("announcement-bar");
    if (!bar) return;

    if (dismissed) {
      bar.classList.add("hidden");
      document.documentElement.style.setProperty("--announcement-h", "0px");
      return;
    }

    // Show the bar (no animation on subsequent navigations)
    bar.classList.remove("hidden");
    bar.style.opacity = "1";
    bar.style.transform = "translateY(0)";
    const h = bar.offsetHeight;
    document.documentElement.style.setProperty("--announcement-h", h + "px");

    // Entrance animation only on first load
    if (!bar.dataset.shown) {
      bar.dataset.shown = "1";
      bar.style.transform = "translateY(-100%)";
      // Force a synchronous layout flush so the browser commits the transform
      // before adding the transition — otherwise the slide-in is skipped.
      void bar.offsetHeight;
      bar.style.transition = "transform 0.4s cubic-bezier(0.16, 1, 0.3, 1)";
      bar.style.transform = "translateY(0)";
    }

    // Close handler (guard against double-bind)
    const closeBtn = document.getElementById("announcement-close");
    if (closeBtn && !closeBtn.dataset.bound) {
      closeBtn.dataset.bound = "1";
      closeBtn.addEventListener("click", function () {
        bar.style.transition = "transform 0.3s cubic-bezier(0.55, 0, 1, 0.45), opacity 0.3s";
        bar.style.transform = "translateY(-100%)";
        bar.style.opacity = "0";
        document.documentElement.style.setProperty("--announcement-h", "0px");
        try {
          sessionStorage.setItem("announcement-dismissed", "1");
        } catch (e) {}
        setTimeout(function () {
          bar.classList.add("hidden");
        }, 300);
      });
    }
  });
</script>

<style>
  .announcement-bg {
    background: linear-gradient(
      135deg,
      #dc2626 0%,
      #ef4444 40%,
      #f87171 60%,
      #ef4444 80%,
      #dc2626 100%
    );
    background-size: 200% 200%;
    animation: announcement-gradient 6s ease-in-out infinite;
  }

  @keyframes announcement-gradient {
    0%,
    100% {
      background-position: 0% 50%;
    }
    50% {
      background-position: 100% 50%;
    }
  }

  .announcement-shimmer {
    background: linear-gradient(
      110deg,
      transparent 20%,
      rgba(255, 255, 255, 0.08) 40%,
      rgba(255, 255, 255, 0.15) 50%,
      rgba(255, 255, 255, 0.08) 60%,
      transparent 80%
    );
    background-size: 200% 100%;
    animation: shimmer 3s ease-in-out infinite;
  }

  @keyframes shimmer {
    0% {
      background-position: 200% 0;
    }
    100% {
      background-position: -200% 0;
    }
  }

  .announcement-sparkle {
    animation: sparkle-pulse 2s ease-in-out infinite;
  }

  @keyframes sparkle-pulse {
    0%,
    100% {
      opacity: 1;
      transform: scale(1);
    }
    50% {
      opacity: 0.7;
      transform: scale(0.85);
    }
  }
</style>
