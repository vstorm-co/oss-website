---
import type { translations } from '../../i18n/translations';
import { Code } from 'astro-expressive-code/components';

interface Props {
  t: typeof translations.en;
}

const { t } = Astro.props;

const tabs = [
  { id: "basic", label: t["deepagents.code.tab.basic"], filename: "agent.py" },
  { id: "tools", label: t["deepagents.code.tab.tools"], filename: "custom_tools.py" },
  { id: "subagents", label: t["deepagents.code.tab.subagents"], filename: "delegation.py" },
];

const plainCode: Record<string, string> = {
  basic: `from pydantic_deep import create_deep_agent, DeepAgentDeps, StateBackend

agent = create_deep_agent(
    model="anthropic:claude-sonnet-4-20250514",
    instructions="You are a senior Python developer.",
)

deps = DeepAgentDeps(backend=StateBackend())

result = await agent.run(
    "Refactor the auth module to use JWT tokens",
    deps=deps,
)`,
  tools: `from pydantic_ai import RunContext
from pydantic_deep import create_deep_agent, DeepAgentDeps, StateBackend

async def analyze_logs(ctx: RunContext[DeepAgentDeps], path: str) -> str:
    """Analyze log files for errors and patterns."""
    return ctx.deps.backend.read(path)

agent = create_deep_agent(
    model="openai:gpt-4.1",
    instructions="You are a DevOps assistant.",
    tools=[analyze_logs],
)

deps = DeepAgentDeps(backend=StateBackend())
result = await agent.run("Find and fix recent errors", deps=deps)`,
  subagents: `from pydantic_deep import create_deep_agent, DeepAgentDeps, StateBackend
from pydantic_deep.types import SubAgentConfig

agent = create_deep_agent(
    model="anthropic:claude-sonnet-4-20250514",
    instructions="You are a tech lead. Delegate tasks to subagents.",
    subagents=[
        SubAgentConfig(
            name="code-reviewer",
            description="Reviews code for bugs and best practices",
            instructions="You are an expert code reviewer.",
        ),
    ],
)

deps = DeepAgentDeps(backend=StateBackend())
result = await agent.run("Review the PR changes", deps=deps)`,
};
---

<section class="section-light section-stack reveal px-4 py-20 sm:px-6 sm:py-28 lg:px-8 lg:py-36">
  <div class="mx-auto max-w-2xl">
    <div class="text-center">
      <h2 class="text-3xl font-bold tracking-[-0.02em] sm:text-4xl">{t["deepagents.code.title"]}</h2>
      <p class="mt-4 text-lg text-text-secondary">{t["deepagents.code.subtitle"]}</p>
    </div>

    <div class="mt-16">
      <!-- Tab buttons -->
      <div class="flex gap-1 rounded-t-xl border border-b-0 border-[#27272a] bg-[#18181b] px-2 pt-2" role="tablist">
        {tabs.map((tab, i) => (
          <button
            role="tab"
            aria-selected={i === 0 ? "true" : "false"}
            data-tab={tab.id}
            class:list={[
              "da-code-tab px-4 py-2 text-sm font-medium transition-colors rounded-t-lg",
              i === 0
                ? "text-[#ef4444] bg-[#09090b]"
                : "text-[#8b8b93] hover:text-[#a1a1aa] bg-transparent",
            ]}
          >
            {tab.label}
          </button>
        ))}
      </div>

      <!-- Tab panels -->
      <div id="da-panel-basic" role="tabpanel" class="da-code-panel">
        <Code code={plainCode.basic} lang="python" title={tabs[0].filename} />
      </div>

      <div id="da-panel-tools" role="tabpanel" class="da-code-panel hidden">
        <Code code={plainCode.tools} lang="python" title={tabs[1].filename} />
      </div>

      <div id="da-panel-subagents" role="tabpanel" class="da-code-panel hidden">
        <Code code={plainCode.subagents} lang="python" title={tabs[2].filename} />
      </div>
    </div>
  </div>
</section>

<style>
  /* Remove top border-radius from Expressive Code inside tabs */
  .da-code-panel :global(.expressive-code) {
    margin-top: 0;
  }
  .da-code-panel :global(.expressive-code .frame) {
    border-top-left-radius: 0;
    border-top-right-radius: 0;
  }
</style>

<script>
  document.querySelectorAll('.da-code-tab').forEach((btn) => {
    btn.addEventListener('click', () => {
      const tabId = (btn as HTMLElement).dataset.tab;
      document.querySelectorAll('.da-code-tab').forEach((t) => {
        t.setAttribute('aria-selected', 'false');
        t.classList.remove('text-[#ef4444]', 'bg-[#09090b]');
        t.classList.add('text-[#8b8b93]', 'bg-transparent');
      });
      document.querySelectorAll('.da-code-panel').forEach((p) => p.classList.add('hidden'));
      btn.setAttribute('aria-selected', 'true');
      btn.classList.add('text-[#ef4444]', 'bg-[#09090b]');
      btn.classList.remove('text-[#8b8b93]', 'bg-transparent');
      document.getElementById(`da-panel-${tabId}`)?.classList.remove('hidden');
    });
  });
</script>
