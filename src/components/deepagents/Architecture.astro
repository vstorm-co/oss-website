---
import type { translations } from "../../i18n/translations";

interface Props {
  t: typeof translations.en;
}

const { t } = Astro.props;
---

<section class="section-stack reveal px-4 py-20 sm:px-6 sm:py-28 lg:px-8 lg:py-36">
  <div class="mx-auto max-w-3xl">
    <div class="mb-16 text-center">
      <h2 class="text-3xl font-bold tracking-[-0.02em] sm:text-4xl">
        {t["deepagents.architecture.title"]}
      </h2>
      <p class="text-text-secondary mt-4 text-lg">{t["deepagents.architecture.subtitle"]}</p>
    </div>

    <div class="space-y-3">
      <!-- Layer 1: Your Application -->
      <div class="border-border bg-surface rounded-xl border p-4 text-center">
        <span class="text-text text-sm font-semibold">Your Application</span>
      </div>

      <!-- Arrow -->
      <div class="flex justify-center">
        <svg
          class="text-text-tertiary h-5 w-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M19.5 13.5 12 21m0 0-7.5-7.5M12 21V3"></path>
        </svg>
      </div>

      <!-- Layer 2: DeepAgent Orchestrator -->
      <div class="border-accent/40 bg-surface rounded-xl border p-5">
        <div class="mb-4 text-center">
          <span class="text-accent text-sm font-semibold">DeepAgent Orchestrator</span>
        </div>
        <div class="grid grid-cols-1 gap-3 sm:grid-cols-3">
          <div class="border-border bg-bg rounded-lg border p-3 text-center">
            <span class="text-text-secondary text-xs font-medium">Planning<br />Engine</span>
          </div>
          <div class="border-border bg-bg rounded-lg border p-3 text-center">
            <span class="text-text-secondary text-xs font-medium">Memory<br />Manager</span>
          </div>
          <div class="border-border bg-bg rounded-lg border p-3 text-center">
            <span class="text-text-secondary text-xs font-medium">Context<br />Compactor</span>
          </div>
        </div>
      </div>

      <!-- Arrow -->
      <div class="flex justify-center">
        <svg
          class="text-text-tertiary h-5 w-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M19.5 13.5 12 21m0 0-7.5-7.5M12 21V3"></path>
        </svg>
      </div>

      <!-- Layer 3: Middleware Stack -->
      <div class="border-border bg-surface rounded-xl border p-4">
        <div class="mb-3 text-center">
          <span class="text-text text-sm font-semibold">Middleware Stack</span>
        </div>
        <div class="flex flex-wrap justify-center gap-2">
          {
            ["Guardrails", "Cost Tracking", "Logging", "Permissions"].map((m) => (
              <span class="border-border bg-bg text-text-secondary rounded-full border px-3 py-1 text-xs">
                {m}
              </span>
            ))
          }
        </div>
      </div>

      <!-- Arrow -->
      <div class="flex justify-center">
        <svg
          class="text-text-tertiary h-5 w-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M19.5 13.5 12 21m0 0-7.5-7.5M12 21V3"></path>
        </svg>
      </div>

      <!-- Layer 4: Tool Registry -->
      <div class="border-border bg-surface rounded-xl border p-4">
        <div class="mb-3 text-center">
          <span class="text-text text-sm font-semibold">Tool Registry</span>
        </div>
        <div class="flex flex-wrap justify-center gap-2">
          {
            ["Filesystem", "Shell", "Web Search", "Sub-agents", "Custom"].map((tool) => (
              <span class="border-border bg-bg text-text-secondary rounded-full border px-3 py-1 font-mono text-xs">
                {tool}
              </span>
            ))
          }
        </div>
      </div>

      <!-- Arrow -->
      <div class="flex justify-center">
        <svg
          class="text-text-tertiary h-5 w-5"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M19.5 13.5 12 21m0 0-7.5-7.5M12 21V3"></path>
        </svg>
      </div>

      <!-- Layer 5: LLM Provider -->
      <div class="border-border bg-surface rounded-xl border p-4 text-center">
        <span class="text-text text-sm font-semibold">LLM Provider</span>
        <div class="mt-2 flex justify-center gap-4">
          {
            ["Claude", "OpenAI", "Gemini"].map((p) => (
              <span class="text-text-tertiary text-xs">{p}</span>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
