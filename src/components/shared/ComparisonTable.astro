---
import type { translations } from "../../i18n/translations";
import { type ComparisonData } from "../../data/comparisons";

interface Props {
  t: typeof translations.en;
  data: ComparisonData;
}

const { t, data } = Astro.props;
---

<section class="px-4 py-16 sm:px-6 sm:py-24 lg:px-8">
  <div class="mx-auto max-w-5xl">
    <div class="reveal mb-12 text-center">
      <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">{t["comparison.title"]}</h2>
      <p class="text-text-secondary mt-3">{t["comparison.subtitle"]}</p>
    </div>

    <div class="reveal border-border overflow-x-auto rounded-2xl border">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-border bg-surface border-b">
            <th class="text-text-secondary px-4 py-3 text-left font-medium"
              >{t["comparison.feature"]}</th
            >
            {
              data.columns.map((col, i) => (
                <th
                  class={`px-4 py-3 text-center font-semibold ${i === data.highlightColumn ? "bg-accent/10 text-accent border-accent border-t-2" : "text-text"}`}
                >
                  {col}
                </th>
              ))
            }
          </tr>
        </thead>
        <tbody>
          {
            data.rows.map((row, ri) => (
              <tr
                class={`border-border border-b last:border-0 ${ri % 2 === 0 ? "" : "bg-surface/50"}`}
              >
                <td class="px-4 py-3 font-medium">{row.feature}</td>
                {row.values.map((val, i) => (
                  <td
                    class={`px-4 py-3 text-center ${i === data.highlightColumn ? "bg-accent/5" : ""}`}
                  >
                    {val === true ? (
                      <span class="text-accent font-bold">&#10003;</span>
                    ) : val === false ? (
                      <span class="text-text-tertiary">&#10007;</span>
                    ) : (
                      <span class="text-text-secondary">{val}</span>
                    )}
                  </td>
                ))}
              </tr>
            ))
          }
        </tbody>
      </table>
    </div>
  </div>
</section>
