---
interface Props {
  repo: string;
}

const { repo } = Astro.props;

let stars: number | null = null;
try {
  const res = await fetch(`https://api.github.com/repos/${repo}`, {
    headers: {
      "Accept": "application/vnd.github.v3+json",
      "User-Agent": "vstorm-oss-website",
    },
  });
  if (res.ok) {
    const data = await res.json();
    stars = data.stargazers_count ?? null;
  }
} catch {
  // Fallback — no stars shown
}

function formatStars(n: number): string {
  if (n >= 1000) return (n / 1000).toFixed(1).replace(/\.0$/, "") + "k";
  return n.toString();
}
---

{stars !== null && (
  <span class="inline-flex items-center gap-1 rounded-full bg-surface border border-border px-2.5 py-0.5 text-xs font-medium text-text-secondary">
    <svg class="h-3.5 w-3.5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
    </svg>
    {formatStars(stars)}
  </span>
)}
