---
interface StatItem {
  value: string;
  label: string;
  suffix?: string;
}

interface Props {
  items: StatItem[];
}

const { items } = Astro.props;
---

<section class="border-border bg-surface/50 border-y py-12 sm:py-16">
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
    <div class="reveal grid grid-cols-2 gap-8 sm:grid-cols-4" id="stats-bar">
      {
        items.map((item) => (
          <div class="text-center">
            <div class="text-accent text-3xl font-bold tracking-tight sm:text-4xl">
              <span class="stat-number" data-target={item.value}>
                {item.value}
              </span>
              {item.suffix || ""}
            </div>
            <div class="text-text-secondary mt-2 text-sm">{item.label}</div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<script is:inline>
  document.addEventListener("astro:page-load", function () {
    const bar = document.getElementById("stats-bar");
    if (!bar || bar.dataset.animated) return;

    const observer = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            bar.dataset.animated = "1";
            const nums = bar.querySelectorAll(".stat-number");
            nums.forEach(function (el) {
              const target = el.getAttribute("data-target") || "";
              const match = target.match(/^(\d+)/);
              if (!match) return;
              const end = parseInt(match[1], 10);
              const duration = 1200;
              let startTime = null;
              const rest = target.slice(match[1].length);
              function animate(ts) {
                if (!startTime) startTime = ts;
                const progress = Math.min((ts - startTime) / duration, 1);
                const eased = 1 - Math.pow(1 - progress, 3);
                const current = Math.round(end * eased);
                el.textContent = current + rest;
                if (progress < 1) requestAnimationFrame(animate);
              }
              requestAnimationFrame(animate);
            });
            observer.disconnect();
          }
        });
      },
      { threshold: 0.3 },
    );

    observer.observe(bar);
  });
</script>
