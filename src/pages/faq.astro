---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import OssFooter from '../components/oss/OssFooter.astro';
import Breadcrumbs from '../components/shared/Breadcrumbs.astro';
import { translations, languages, defaultLang } from '../i18n/translations';
import { faqItems } from '../data/faq';
import { faqPageSchema } from '../lib/schemas';

const lang = defaultLang;
const t = translations[lang];

const alternates = [
  { lang: "en", href: "/faq/" },
  ...Object.keys(languages)
    .filter((l) => l !== defaultLang)
    .map((l) => ({ lang: l, href: `/${l}/faq/` })),
];

const categories = [
  { key: "template" as const, label: t["faq.category.template"] },
  { key: "deepagents" as const, label: t["faq.category.deepagents"] },
  { key: "logfire" as const, label: t["faq.category.logfire"] },
];
---

<Layout
  title={`${t["faq.title"]} — Vstorm OSS`}
  description={t["faq.subtitle"]}
  keywords="ai agent faq, pydantic ai questions, ai framework comparison, python ai tools, deepagents faq, logfire faq"
  lang={lang}
  alternates={alternates}
  schemas={[faqPageSchema({ questions: faqItems.map((item) => ({ question: item.question[lang], answer: item.answer[lang] })) })]}
>
  <Navbar currentLang={lang} />

  <Breadcrumbs items={[
    { label: "Home", href: "/" },
    { label: "FAQ" },
  ]} />

  <main class="mx-auto max-w-3xl px-4 py-16 sm:py-24">
    <div class="mb-12 text-center">
      <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">{t["faq.title"]}</h1>
      <p class="mt-4 text-text-secondary">{t["faq.subtitle"]}</p>
    </div>

    {categories.map((cat) => {
      const items = faqItems.filter((item) => item.category === cat.key);
      return items.length > 0 && (
        <div class="mb-10">
          <h2 class="mb-4 text-lg font-semibold text-accent">{cat.label}</h2>
          <div class="space-y-3">
            {items.map((item) => (
              <details class="group rounded-lg border border-border bg-surface transition-colors hover:border-border-hover">
                <summary class="flex cursor-pointer items-center justify-between px-6 py-4 font-medium select-none">
                  <span>{item.question[lang]}</span>
                  <svg
                    class="h-5 w-5 shrink-0 text-text-tertiary transition-transform group-open:rotate-180"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                  </svg>
                </summary>
                <div class="px-6 pb-4 text-text-secondary leading-relaxed">
                  {item.answer[lang]}
                </div>
              </details>
            ))}
          </div>
        </div>
      );
    })}
  </main>

  <OssFooter t={t} />
</Layout>
