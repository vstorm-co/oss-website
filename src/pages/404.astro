---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import { translations, defaultLang } from "../i18n/translations";

const lang = defaultLang;
const t = translations[lang];
---

<Layout
  title={`${t["404.title"]} — Vstorm OSS`}
  description={t["404.description"]}
  lang={lang}
  schemas={[]}
>
  <Navbar currentLang={lang} />

  <main
    class="relative flex min-h-[80vh] flex-col items-center justify-center overflow-hidden px-4 text-center"
  >
    <!-- Background glow -->
    <div class="pointer-events-none absolute inset-0 overflow-hidden">
      <div
        class="bg-accent/[0.08] absolute top-1/2 left-1/2 h-[600px] w-[600px] -translate-x-1/2 -translate-y-1/2 rounded-full blur-[180px]"
      >
      </div>
    </div>

    <div class="relative">
      <!-- Glitchy 404 number -->
      <p
        class="from-text/20 to-text/5 bg-gradient-to-b bg-clip-text text-[10rem] leading-none font-black tracking-tighter text-transparent select-none sm:text-[14rem]"
      >
        404
      </p>

      <!-- Overlay text -->
      <div class="absolute inset-0 flex items-center justify-center">
        <div>
          <h1 class="text-2xl font-bold tracking-tight sm:text-3xl">{t["404.title"]}</h1>
          <p class="text-text-secondary mt-3 max-w-md leading-relaxed">
            {t["404.description"]}
          </p>
        </div>
      </div>
    </div>

    <div class="mt-4 flex flex-col items-center gap-3 sm:flex-row">
      <a
        href="/"
        class="bg-accent hover:bg-accent-hover hover:shadow-accent/25 inline-flex items-center gap-2 rounded-full px-7 py-3 text-base font-semibold text-white transition-all hover:shadow-lg"
      >
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18"
          ></path>
        </svg>
        {t["404.back"]}
      </a>
      <a
        href="/blog/"
        class="text-text inline-flex items-center gap-2 rounded-full border border-white/[0.1] bg-white/[0.04] px-7 py-3 text-base font-semibold backdrop-blur-sm transition-all hover:border-white/[0.2] hover:bg-white/[0.08]"
      >
        Read our Blog
      </a>
    </div>

    <!-- English version link - shown dynamically via JS for localized 404s -->
    <div id="english-version-hint" class="mt-6 hidden">
      <a href="/" class="text-text-secondary hover:text-accent text-sm transition-colors">
        <svg
          class="mr-1 inline h-4 w-4"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"></path>
        </svg>
        Try English version
      </a>
    </div>
  </main>
</Layout>

<script is:inline>
  (function () {
    // Show English version hint if on a localized 404
    const path = window.location.pathname;
    const localizedMatch = path.match(/^\/(pl|de|es)\//);
    if (localizedMatch) {
      const lang = localizedMatch[1];
      const englishPath = path.replace(/^\/(pl|de|es)\//, "/");
      const hint = document.getElementById("english-version-hint");
      if (hint) {
        hint.classList.remove("hidden");
        const link = hint.querySelector("a");
        if (link) link.href = englishPath;
      }
    }
  })();
</script>
