---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import { translations, defaultLang } from '../i18n/translations';

const lang = defaultLang;
const t = translations[lang];
---

<Layout title={`${t["404.title"]} — Vstorm OSS`} description={t["404.description"]} lang={lang}>
  <Navbar currentLang={lang} />

  <main class="flex min-h-[60vh] flex-col items-center justify-center px-4 text-center">
    <p class="text-8xl font-bold text-accent">404</p>
    <h1 class="mt-4 text-3xl font-bold tracking-tight sm:text-4xl">{t["404.title"]}</h1>
    <p class="mt-4 max-w-md text-lg text-text-secondary leading-relaxed">
      {t["404.description"]}
    </p>
    <a
      href="/"
      class="mt-8 inline-flex items-center gap-2 rounded-full bg-accent px-8 py-3 text-base font-semibold text-white transition-colors hover:bg-accent-hover"
    >
      <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
      </svg>
      {t["404.back"]}
    </a>
  </main>

  <footer class="border-t border-border px-4 py-8 sm:px-6 lg:px-8">
    <div class="mx-auto flex max-w-6xl items-center justify-center">
      <p class="text-sm text-text-tertiary">
        Built with <span class="text-red-400">&hearts;</span> by <a href="https://vstorm.co" target="_blank" rel="noopener noreferrer" class="font-medium text-text-secondary hover:text-text transition-colors">Vstorm</a>
      </p>
    </div>
  </footer>
</Layout>
