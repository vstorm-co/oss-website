---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import OssFooter from "../../components/oss/OssFooter.astro";
import Breadcrumbs from "../../components/shared/Breadcrumbs.astro";
import { translations, defaultLang } from "../../i18n/translations";
import {
  getTermsGroupedByLetter,
  glossaryTerms,
  categoryLabels,
  categoryColors,
} from "../../data/glossary";
import { definedTermSetSchema, SITE_URL } from "../../lib/schemas";

const lang = defaultLang;
const t = translations[lang];

const grouped = getTermsGroupedByLetter();
const letters = Array.from(grouped.keys()).sort();

// Glossary is English-only - only show English in language switcher
const languageLinks = [{ lang: defaultLang, href: "/glossary/" }];
---

<Layout
  title="AI & ML Glossary — Vstorm OSS"
  description="A comprehensive glossary of AI, machine learning, LLM, RAG, and agent terminology. Technical definitions for developers building production AI systems."
  keywords="ai glossary, machine learning terms, llm terminology, rag glossary, ai agent definitions, deep learning glossary, nlp terms"
  lang={lang}
  alternates={[{ lang: "en", href: "/glossary/" }]}
  schemas={[
    definedTermSetSchema({
      name: "AI & ML Glossary",
      description:
        "A comprehensive glossary of AI, machine learning, LLM, RAG, and agent terminology for developers.",
      url: SITE_URL + "/glossary/",
      terms: glossaryTerms.map((t) => ({ name: t.term, url: SITE_URL + `/glossary/${t.slug}/` })),
    }),
  ]}
  theme="light"
>
  <Navbar currentLang={lang} languageLinks={languageLinks} />

  <Breadcrumbs items={[{ label: "Home", href: "/" }, { label: "Glossary" }]} />

  <main class="mx-auto max-w-4xl px-4 py-16 sm:py-24">
    <!-- Header -->
    <div class="reveal mb-12 text-center">
      <h1 class="heading-accent text-3xl font-bold tracking-tight sm:text-4xl">AI & ML Glossary</h1>
      <p class="text-text-secondary mx-auto mt-4 max-w-2xl text-lg">
        Technical definitions for developers building production AI systems — from fundamentals to
        advanced agent patterns.
      </p>
    </div>

    <!-- Search & Filter -->
    <div class="reveal mb-10">
      <div class="flex flex-col gap-3 sm:flex-row">
        <div class="relative flex-1">
          <svg
            class="text-text-tertiary pointer-events-none absolute top-1/2 left-3 h-4 w-4 -translate-y-1/2"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
          </svg>
          <input
            type="text"
            id="glossary-search"
            placeholder="Search terms..."
            class="border-border text-text placeholder:text-text-tertiary focus:border-accent focus:ring-accent w-full rounded-xl border bg-white py-2.5 pr-4 pl-10 text-sm focus:ring-1 focus:outline-none"
          />
        </div>
        <select
          id="glossary-filter"
          class="border-border text-text focus:border-accent focus:ring-accent rounded-xl border bg-white px-4 py-2.5 text-sm focus:ring-1 focus:outline-none"
        >
          <option value="all">All Categories</option>
          {
            Object.entries(categoryLabels).map(([key, label]) => (
              <option value={key}>{label}</option>
            ))
          }
        </select>
      </div>
    </div>

    <!-- Letter Navigation -->
    <div class="reveal mb-8 flex flex-wrap justify-center gap-1.5" id="letter-nav">
      {
        letters.map((letter) => (
          <a
            href={`#letter-${letter}`}
            class="border-border text-text-secondary hover:bg-accent hover:border-accent flex h-8 w-8 items-center justify-center rounded-lg border text-sm font-medium transition-colors hover:text-white"
          >
            {letter}
          </a>
        ))
      }
    </div>

    <!-- No results -->
    <div id="no-results" class="hidden py-16 text-center">
      <p class="text-text-secondary text-lg">No terms match your search.</p>
      <button
        id="clear-search"
        class="text-accent hover:text-accent-hover mt-4 text-sm transition-colors"
      >
        Clear search
      </button>
    </div>

    <!-- Term Groups -->
    <div id="glossary-list" class="reveal-group space-y-10">
      {
        letters.map((letter) => (
          <section id={`letter-${letter}`} data-letter-section>
            <div class="sticky top-0 z-10 -mx-4 bg-white/80 px-4 py-2 backdrop-blur-md">
              <h2 class="text-accent text-2xl font-bold">{letter}</h2>
            </div>
            <div class="mt-3 grid gap-3">
              {grouped.get(letter)!.map((term) => {
                const firstSentence = term.definition.split(". ")[0] + ".";
                return (
                  <a
                    href={`/glossary/${term.slug}/`}
                    class="glossary-card group glass-card hover:border-accent/30 relative block overflow-hidden rounded-xl p-5 transition-all"
                    data-term={term.term.toLowerCase()}
                    data-category={term.category}
                    data-definition={term.definition.toLowerCase()}
                  >
                    <div class="via-accent/0 group-hover:via-accent/50 absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent to-transparent transition-all duration-500" />
                    <div class="flex items-start justify-between gap-3">
                      <div class="min-w-0 flex-1">
                        <div class="mb-1.5 flex items-center gap-2">
                          <h3 class="text-text group-hover:text-accent truncate text-base font-semibold transition-colors">
                            {term.term}
                          </h3>
                          <span
                            class={`shrink-0 rounded-full px-2 py-0.5 text-[10px] font-medium ${categoryColors[term.category]}`}
                          >
                            {categoryLabels[term.category]}
                          </span>
                        </div>
                        <p class="text-text-secondary line-clamp-2 text-sm">{firstSentence}</p>
                      </div>
                      <svg
                        class="text-text-tertiary group-hover:text-accent mt-1 h-4 w-4 shrink-0 transition-colors"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        stroke-width="2"
                      >
                        <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                      </svg>
                    </div>
                  </a>
                );
              })}
            </div>
          </section>
        ))
      }
    </div>
  </main>

  <OssFooter t={t} />
</Layout>

<script is:inline>
  document.addEventListener("astro:page-load", function () {
    const searchInput = document.getElementById("glossary-search");
    const filterSelect = document.getElementById("glossary-filter");
    const cards = document.querySelectorAll(".glossary-card");
    const sections = document.querySelectorAll("[data-letter-section]");
    const noResults = document.getElementById("no-results");
    const glossaryList = document.getElementById("glossary-list");
    const clearBtn = document.getElementById("clear-search");
    const letterNav = document.getElementById("letter-nav");

    function filterCards() {
      const query = (searchInput?.value || "").toLowerCase().trim();
      const category = filterSelect?.value || "all";
      let visibleCount = 0;

      cards.forEach(function (card) {
        const term = card.getAttribute("data-term") || "";
        const cat = card.getAttribute("data-category") || "";
        const def = card.getAttribute("data-definition") || "";
        const matchSearch = !query || term.includes(query) || def.includes(query);
        const matchCat = category === "all" || cat === category;
        const visible = matchSearch && matchCat;
        card.style.display = visible ? "" : "none";
        if (visible) visibleCount++;
      });

      // Hide empty letter sections
      sections.forEach(function (section) {
        const visCards = section.querySelectorAll('.glossary-card:not([style*="display: none"])');
        section.style.display = visCards.length > 0 ? "" : "none";
      });

      if (noResults) noResults.style.display = visibleCount === 0 ? "" : "none";
      if (glossaryList) glossaryList.style.display = visibleCount === 0 ? "none" : "";
      if (letterNav) letterNav.style.display = query || category !== "all" ? "none" : "";
    }

    if (searchInput) searchInput.addEventListener("input", filterCards);
    if (filterSelect) filterSelect.addEventListener("change", filterCards);
    if (clearBtn) {
      clearBtn.addEventListener("click", function () {
        if (searchInput) searchInput.value = "";
        if (filterSelect) filterSelect.value = "all";
        filterCards();
      });
    }
  });
</script>
