---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import OssFooter from "../../components/oss/OssFooter.astro";
import Breadcrumbs from "../../components/shared/Breadcrumbs.astro";
import { Code } from "astro-expressive-code/components";
import { translations, languages, defaultLang } from "../../i18n/translations";
import {
  comparisonPages,
  getAllComparisonSlugs,
  getComparisonBySlug,
} from "../../data/compare-pages";
import { faqPageSchema, type JsonLdSchema } from "../../lib/schemas";

function detectLang(code: string): "python" | "bash" {
  for (const line of code.trim().split("\n").slice(0, 5)) {
    const t = line.trim();
    if (t.startsWith("from ") || t.startsWith("import ")) return "python";
  }
  return "bash";
}

export function getStaticPaths() {
  return getAllComparisonSlugs().map((slug) => ({ params: { slug } }));
}

const lang = defaultLang;
const t = translations[lang];
const { slug } = Astro.params;
const comparison = getComparisonBySlug(slug!)!;

const pageTitle = `${comparison.product} vs ${comparison.competitor} — Vstorm OSS`;
const pageDescription = comparison.verdict[lang];
const pageKeywords = `${comparison.product} vs ${comparison.competitor}, ${comparison.product} comparison, ${comparison.competitor} alternative, ai agent framework comparison`;

const alternates = [
  { lang: "en", href: `/compare/${slug}/` },
  ...Object.keys(languages)
    .filter((l) => l !== defaultLang)
    .map((l) => ({ lang: l, href: `/${l}/compare/${slug}/` })),
];

const productHref = `/projects/${comparison.productSlug}/`;

// FAQ schema
const schemas: JsonLdSchema[] =
  comparison.faq.length > 0
    ? [
        faqPageSchema({
          questions: comparison.faq.map((item) => ({
            question: item.question[lang],
            answer: item.answer[lang],
          })),
        }),
      ]
    : [];

// Related comparisons
const relatedComparisons = comparison.relatedSlugs
  .map((s) => getComparisonBySlug(s))
  .filter(Boolean);

function winnerColor(winner: string) {
  if (winner === "ours") return "text-green-400";
  if (winner === "theirs") return "text-blue-400";
  return "text-amber-400";
}

function winnerBorder(winner: string) {
  if (winner === "ours") return "border-green-400/30";
  if (winner === "theirs") return "border-blue-400/30";
  return "border-amber-400/30";
}

function winnerBg(winner: string) {
  if (winner === "ours") return "bg-green-400/5";
  if (winner === "theirs") return "bg-blue-400/5";
  return "bg-amber-400/5";
}
---

<Layout
  title={pageTitle}
  description={pageDescription}
  keywords={pageKeywords}
  lang={lang}
  alternates={alternates}
  schemas={schemas}
  theme="light"
>
  <Navbar currentLang={lang} />

  <Breadcrumbs
    items={[
      { label: "Home", href: "/" },
      { label: t["compare.index.title"] ?? "Compare", href: "/compare/" },
      { label: `${comparison.product} vs ${comparison.competitor}` },
    ]}
  />

  <!-- Hero -->
  <main class="mx-auto max-w-6xl px-4 py-16 sm:py-24">
    <div class="reveal mb-12 text-center">
      <h1 class="heading-accent text-3xl font-bold tracking-tight sm:text-4xl">
        {comparison.product} vs {comparison.competitor}
      </h1>
      <p class="text-text-secondary mx-auto mt-4 max-w-2xl text-lg">
        {comparison.verdict[lang]}
      </p>
    </div>

    <!-- Key Differences -->
    <section class="px-4 py-16 sm:px-6 sm:py-24 lg:px-8">
      <div class="mx-auto max-w-6xl">
        <div class="reveal mb-10 text-center">
          <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">
            {t["compare.highlights"] ?? "Key Differences"}
          </h2>
        </div>
        <div class="reveal-group grid gap-4 sm:grid-cols-3 sm:gap-6">
          {
            comparison.highlights.map((h) => (
              <div
                class={`glass-card rounded-2xl border p-5 sm:p-7 lg:p-8 ${winnerBorder(h.winner)} ${winnerBg(h.winner)} reveal`}
              >
                <div class="mb-3 flex items-center gap-2">
                  {h.winner === "ours" ? (
                    <svg
                      class="h-4 w-4 shrink-0 text-green-400 sm:h-5 sm:w-5"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      stroke-width="2"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"
                      />
                    </svg>
                  ) : h.winner === "theirs" ? (
                    <svg
                      class="h-4 w-4 shrink-0 text-blue-400 sm:h-5 sm:w-5"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      stroke-width="2"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"
                      />
                    </svg>
                  ) : (
                    <svg
                      class="h-4 w-4 shrink-0 text-amber-400 sm:h-5 sm:w-5"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      stroke-width="2"
                    >
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z"
                      />
                    </svg>
                  )}
                  <span
                    class={`text-[10px] font-semibold tracking-wider uppercase sm:text-xs ${winnerColor(h.winner)}`}
                  >
                    {h.winner === "ours"
                      ? (t["compare.winner.ours"] ?? "Advantage: {product}").replace(
                          "{product}",
                          comparison.product,
                        )
                      : h.winner === "theirs"
                        ? (t["compare.winner.theirs"] ?? "Advantage: {competitor}").replace(
                            "{competitor}",
                            comparison.competitor,
                          )
                        : (t["compare.winner.tie"] ?? "Tie")}
                  </span>
                </div>
                <h3 class="mb-2 text-lg font-semibold">{h.title[lang]}</h3>
                <p class="text-text-secondary text-sm leading-relaxed">{h.description[lang]}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Feature Comparison Table -->
    <section class="px-4 py-16 sm:px-6 sm:py-24 lg:px-8">
      <div class="mx-auto max-w-6xl">
        <div class="reveal mb-10 text-center">
          <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">
            {t["compare.table.title"] ?? "Feature Comparison"}
          </h2>
        </div>

        <div class="reveal border-border overflow-x-auto rounded-2xl border">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-border bg-surface border-b">
                <th
                  class="text-text-secondary px-3 py-3 text-left text-xs font-medium sm:px-4 sm:py-3.5 sm:text-[15px]"
                  >Feature</th
                >
                {
                  comparison.tableColumns.map((col, i) => (
                    <th
                      class={`px-3 py-3 text-center text-xs font-semibold sm:px-4 sm:py-3.5 sm:text-[15px] ${i === comparison.tableHighlight ? "bg-green-400/[0.08] text-green-400" : "text-text"}`}
                    >
                      {col}
                    </th>
                  ))
                }
              </tr>
            </thead>
            <tbody>
              {
                comparison.tableRows.map((row, ri) => (
                  <tr
                    class={`border-border border-b last:border-0 ${ri % 2 === 0 ? "" : "bg-surface/50"}`}
                  >
                    <td class="px-3 py-3 text-xs font-medium sm:px-4 sm:py-3.5 sm:text-sm">
                      {row.feature[lang]}
                    </td>
                    {row.values.map((val, i) => (
                      <td
                        class={`px-3 py-3 text-center text-xs sm:px-4 sm:py-3.5 sm:text-sm ${i === comparison.tableHighlight ? "bg-green-400/[0.04]" : ""}`}
                      >
                        {val === true ? (
                          <span class="font-bold text-green-400">&#10003;</span>
                        ) : val === false ? (
                          <span class="text-red-400/60">&#10007;</span>
                        ) : (
                          <span class="text-text-secondary">{val}</span>
                        )}
                      </td>
                    ))}
                  </tr>
                ))
              }
            </tbody>
          </table>
        </div>
      </div>
    </section>

    <!-- Code Comparison -->
    {
      comparison.codeOurs && (
        <section class="px-4 py-16 sm:px-6 sm:py-24 lg:px-8">
          <div class="mx-auto max-w-6xl">
            <div class="reveal mb-10 text-center">
              <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">
                {t["compare.code.title"] ?? "Code Comparison"}
              </h2>
            </div>

            <div class="reveal grid gap-6 lg:grid-cols-2">
              <div class="min-w-0 overflow-x-auto">
                <Code
                  code={comparison.codeOurs.code}
                  lang={detectLang(comparison.codeOurs.code)}
                  title={comparison.codeOurs.label}
                />
              </div>
              {comparison.codeTheirs && (
                <div class="min-w-0 overflow-x-auto">
                  <Code
                    code={comparison.codeTheirs.code}
                    lang={detectLang(comparison.codeTheirs.code)}
                    title={comparison.codeTheirs.label}
                  />
                </div>
              )}
            </div>
          </div>
        </section>
      )
    }

    <!-- When to Use Which -->
    <section class="px-4 py-16 sm:px-6 sm:py-24 lg:px-8">
      <div class="mx-auto max-w-6xl">
        <div class="reveal mb-10 text-center">
          <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">
            {t["compare.whenToUse"] ?? "When to Use Which"}
          </h2>
        </div>

        <div class="reveal grid gap-6 sm:grid-cols-2">
          <div class="glass-card rounded-2xl border-l-4 border-green-400/40 p-5 sm:p-7 lg:p-8">
            <h3 class="mb-4 flex items-center gap-2 text-lg font-semibold">
              <svg
                class="h-5 w-5 shrink-0 text-green-400"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"></path></svg
              >
              {
                (t["compare.whenToUse.ours"] ?? "Choose {product} when:").replace(
                  "{product}",
                  comparison.product,
                )
              }
            </h3>
            <ul class="text-text-secondary space-y-2 leading-relaxed">
              {
                comparison.whenOurs[lang]
                  .split("\n")
                  .filter((line: string) => line.trim())
                  .map((line: string) => (
                    <li class="flex items-start gap-2">
                      <svg
                        class="mt-0.5 h-4 w-4 shrink-0 text-green-400/60"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        stroke-width="2"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          d="M4.5 12.75l6 6 9-13.5"
                        />
                      </svg>
                      <span>{line.trim()}</span>
                    </li>
                  ))
              }
            </ul>
          </div>
          <div class="glass-card rounded-2xl border-l-4 border-blue-400/40 p-5 sm:p-7 lg:p-8">
            <h3 class="mb-4 flex items-center gap-2 text-lg font-semibold">
              <svg
                class="h-5 w-5 shrink-0 text-blue-400"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                stroke-width="2"
                ><path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"></path></svg
              >
              {
                (t["compare.whenToUse.theirs"] ?? "Choose {competitor} when:").replace(
                  "{competitor}",
                  comparison.competitor,
                )
              }
            </h3>
            <ul class="text-text-secondary space-y-2 leading-relaxed">
              {
                comparison.whenTheirs[lang]
                  .split("\n")
                  .filter((line: string) => line.trim())
                  .map((line: string) => (
                    <li class="flex items-start gap-2">
                      <svg
                        class="mt-0.5 h-4 w-4 shrink-0 text-blue-400/60"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke="currentColor"
                        stroke-width="2"
                      >
                        <path
                          stroke-linecap="round"
                          stroke-linejoin="round"
                          d="M4.5 12.75l6 6 9-13.5"
                        />
                      </svg>
                      <span>{line.trim()}</span>
                    </li>
                  ))
              }
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    {
      comparison.faq.length > 0 && (
        <section class="px-4 py-16 sm:px-6 sm:py-24 lg:px-8">
          <div class="mx-auto max-w-4xl">
            <div class="reveal mb-10 text-center">
              <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">
                {t["compare.faq.title"] ?? "Frequently Asked Questions"}
              </h2>
            </div>

            <div class="reveal-group space-y-3">
              {comparison.faq.map((item) => (
                <details class="reveal group border-border border-l-accent/30 bg-surface hover:border-accent/30 rounded-2xl border border-l-2 transition-colors">
                  <summary class="flex cursor-pointer items-center justify-between px-4 py-3 text-sm font-semibold select-none sm:px-6 sm:py-4 sm:text-base">
                    <span>{item.question[lang]}</span>
                    <svg
                      class="text-text-tertiary h-5 w-5 shrink-0 transition-transform group-open:rotate-180"
                      fill="none"
                      viewBox="0 0 24 24"
                      stroke="currentColor"
                      stroke-width="2"
                    >
                      <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                    </svg>
                  </summary>
                  <div class="text-text-secondary px-4 pb-3 text-sm leading-relaxed sm:px-6 sm:pb-4">
                    {item.answer[lang]}
                  </div>
                </details>
              ))}
            </div>
          </div>
        </section>
      )
    }

    <!-- Related Comparisons -->
    {
      relatedComparisons.length > 0 && (
        <section class="px-4 py-16 sm:px-6 sm:py-24 lg:px-8">
          <div class="mx-auto max-w-6xl">
            <div class="reveal mb-10 text-center">
              <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">
                {t["compare.relatedTitle"] ?? "Related Comparisons"}
              </h2>
            </div>

            <div class="reveal-group grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
              {relatedComparisons.map((rel) => (
                <a
                  href={`/compare/${rel!.slug}/`}
                  class="glass-card glow-card reveal group flex items-center justify-between gap-4 rounded-2xl p-6"
                >
                  <div>
                    <h3 class="group-hover:text-accent font-semibold transition-colors">
                      {rel!.product} vs {rel!.competitor}
                    </h3>
                    <p class="text-text-secondary mt-1 line-clamp-2 text-sm">
                      {rel!.verdict[lang]}
                    </p>
                  </div>
                  <svg
                    class="text-text-tertiary group-hover:text-accent h-5 w-5 shrink-0 transition-colors"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
                  </svg>
                </a>
              ))}
            </div>
          </div>
        </section>
      )
    }

    <!-- CTA -->
    <section class="px-4 py-20 sm:px-6 sm:py-28 lg:px-8 lg:py-36">
      <div class="reveal mx-auto max-w-3xl text-center">
        <div class="glass-card glow-card rounded-2xl p-6 sm:p-10 lg:p-14">
          <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">
            {
              (t["compare.cta.title"] ?? "Ready to try {product}?").replace(
                "{product}",
                comparison.product,
              )
            }
          </h2>
          <a
            href={productHref}
            class="bg-accent hover:bg-accent-hover mt-6 inline-flex items-center gap-2 rounded-full px-6 py-2.5 text-sm font-semibold text-white transition-colors sm:mt-8 sm:px-8 sm:py-3 sm:text-base"
          >
            {t["compare.cta.button"] ?? "Get Started"}
            <svg
              class="h-4 w-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"
              ></path>
            </svg>
          </a>
        </div>
      </div>
    </section>
  </main>

  <OssFooter t={t} />
</Layout>
