---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import OssFooter from '../../components/oss/OssFooter.astro';
import Breadcrumbs from '../../components/shared/Breadcrumbs.astro';
import { translations, languages, defaultLang } from '../../i18n/translations';
import { comparisonPages, getAllComparisonSlugs, getComparisonBySlug } from '../../data/compare-pages';

export function getStaticPaths() {
  return getAllComparisonSlugs().map((slug) => ({ params: { slug } }));
}

const lang = defaultLang;
const t = translations[lang];
const { slug } = Astro.params;
const comparison = getComparisonBySlug(slug!)!;

const pageTitle = `${comparison.product} vs ${comparison.competitor} — Vstorm OSS`;
const pageDescription = comparison.verdict[lang];
const pageKeywords = `${comparison.product} vs ${comparison.competitor}, ${comparison.product} comparison, ${comparison.competitor} alternative, ai agent framework comparison`;

const alternates = [
  { lang: "en", href: `/compare/${slug}/` },
  ...Object.keys(languages)
    .filter((l) => l !== defaultLang)
    .map((l) => ({ lang: l, href: `/${l}/compare/${slug}/` })),
];

const productHref = `/${comparison.productSlug}/`;

// FAQ schema
const faqSchema = comparison.faq.length > 0 ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: comparison.faq.map((item) => ({
    "@type": "Question",
    name: item.question[lang],
    acceptedAnswer: {
      "@type": "Answer",
      text: item.answer[lang],
    },
  })),
} : null;

// Related comparisons
const relatedComparisons = comparison.relatedSlugs
  .map((s) => getComparisonBySlug(s))
  .filter(Boolean);

function winnerColor(winner: string) {
  if (winner === "ours") return "text-green-400";
  if (winner === "theirs") return "text-blue-400";
  return "text-amber-400";
}

function winnerBorder(winner: string) {
  if (winner === "ours") return "border-green-400/30";
  if (winner === "theirs") return "border-blue-400/30";
  return "border-amber-400/30";
}

function winnerBg(winner: string) {
  if (winner === "ours") return "bg-green-400/5";
  if (winner === "theirs") return "bg-blue-400/5";
  return "bg-amber-400/5";
}
---

<Layout
  title={pageTitle}
  description={pageDescription}
  keywords={pageKeywords}
  lang={lang}
  alternates={alternates}
>
  <Navbar currentLang={lang} />

  {faqSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  )}

  <Breadcrumbs items={[
    { label: "Home", href: "/" },
    { label: t["compare.index.title"] ?? "Compare", href: "/compare/" },
    { label: `${comparison.product} vs ${comparison.competitor}` },
  ]} />

  <!-- Hero -->
  <section class="relative mx-auto max-w-4xl px-4 pt-28 pb-12 sm:px-6 sm:pt-36 sm:pb-16 lg:px-8 text-center">
    <div class="pointer-events-none absolute inset-0 -top-24 flex items-center justify-center" aria-hidden="true">
      <div class="h-[200px] w-[300px] sm:h-[340px] sm:w-[540px] rounded-full bg-accent/[0.07] blur-[60px] sm:blur-[100px]"></div>
    </div>
    <div class="reveal relative">
      <span class="inline-flex items-center rounded-full border border-border bg-surface px-3 py-1 text-xs font-medium text-text-secondary mb-6">
        {comparison.category}
      </span>
      <h1 class="text-3xl font-bold tracking-tight sm:text-4xl lg:text-5xl">
        {comparison.product} vs {comparison.competitor}
      </h1>
      <p class="mt-6 text-lg sm:text-xl text-text-secondary max-w-2xl mx-auto leading-relaxed">
        {comparison.verdict[lang]}
      </p>
    </div>
  </section>

  <!-- Key Differences -->
  <section class="section-stack px-4 py-16 sm:px-6 sm:py-24 lg:px-8">
    <div class="mx-auto max-w-5xl">
      <div class="mb-10 text-center reveal">
        <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">
          {t["compare.highlights"] ?? "Key Differences"}
        </h2>
      </div>
      <div class="grid gap-4 sm:gap-6 sm:grid-cols-3 reveal-group">
        {comparison.highlights.map((h) => (
          <div class={`glass-card rounded-2xl p-5 sm:p-7 lg:p-8 border ${winnerBorder(h.winner)} ${winnerBg(h.winner)} reveal`}>
            <div class="flex items-center gap-2 mb-3">
              {h.winner === "ours" ? (
                <svg class="w-4 h-4 sm:w-5 sm:h-5 text-green-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
              ) : h.winner === "theirs" ? (
                <svg class="w-4 h-4 sm:w-5 sm:h-5 text-blue-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
              ) : (
                <svg class="w-4 h-4 sm:w-5 sm:h-5 text-amber-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" /></svg>
              )}
              <span class={`text-[10px] sm:text-xs font-semibold uppercase tracking-wider ${winnerColor(h.winner)}`}>
                {h.winner === "ours"
                  ? (t["compare.winner.ours"] ?? "Advantage: {product}").replace("{product}", comparison.product)
                  : h.winner === "theirs"
                    ? (t["compare.winner.theirs"] ?? "Advantage: {competitor}").replace("{competitor}", comparison.competitor)
                    : (t["compare.winner.tie"] ?? "Tie")}
              </span>
            </div>
            <h3 class="text-lg font-semibold mb-2">{h.title[lang]}</h3>
            <p class="text-sm text-text-secondary leading-relaxed">{h.description[lang]}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Feature Comparison Table -->
  <section class="section-stack px-4 py-16 sm:px-6 sm:py-24 lg:px-8">
    <div class="mx-auto max-w-5xl">
      <div class="mb-10 text-center reveal">
        <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">
          {t["compare.table.title"] ?? "Feature Comparison"}
        </h2>
      </div>

      <div class="reveal overflow-x-auto rounded-2xl border border-border">
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-border bg-surface">
              <th class="px-3 py-3 sm:px-4 sm:py-3.5 text-left text-xs sm:text-[15px] font-medium text-text-secondary">Feature</th>
              {comparison.tableColumns.map((col, i) => (
                <th class={`px-3 py-3 sm:px-4 sm:py-3.5 text-center text-xs sm:text-[15px] font-semibold ${i === comparison.tableHighlight ? "bg-green-400/[0.08] text-green-400" : "text-text"}`}>
                  {col}
                </th>
              ))}
            </tr>
          </thead>
          <tbody>
            {comparison.tableRows.map((row, ri) => (
              <tr class={`border-b border-border last:border-0 ${ri % 2 === 0 ? "" : "bg-surface/50"}`}>
                <td class="px-3 py-3 sm:px-4 sm:py-3.5 text-xs sm:text-sm font-medium">{row.feature[lang]}</td>
                {row.values.map((val, i) => (
                  <td class={`px-3 py-3 sm:px-4 sm:py-3.5 text-center text-xs sm:text-sm ${i === comparison.tableHighlight ? "bg-green-400/[0.04]" : ""}`}>
                    {val === true ? (
                      <span class="text-green-400 font-bold">&#10003;</span>
                    ) : val === false ? (
                      <span class="text-red-400/60">&#10007;</span>
                    ) : (
                      <span class="text-text-secondary">{val}</span>
                    )}
                  </td>
                ))}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- Code Comparison -->
  {comparison.codeOurs && (
    <section class="section-stack px-4 py-16 sm:px-6 sm:py-24 lg:px-8">
      <div class="mx-auto max-w-5xl">
        <div class="mb-10 text-center reveal">
          <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">
            {t["compare.code.title"] ?? "Code Comparison"}
          </h2>
        </div>

        <div class="grid gap-6 sm:grid-cols-2 reveal">
          <div class="force-dark glass-card rounded-2xl overflow-hidden">
            <div class="px-4 py-2.5 border-b border-white/[0.06] text-xs font-mono text-green-400 bg-gradient-to-r from-green-400/[0.08] to-transparent">
              {comparison.codeOurs.label}
            </div>
            <pre class="p-4 overflow-x-auto text-xs leading-relaxed"><code class="font-mono text-text-secondary">{comparison.codeOurs.code}</code></pre>
          </div>
          {comparison.codeTheirs && (
            <div class="force-dark glass-card rounded-2xl overflow-hidden">
              <div class="px-4 py-2.5 border-b border-white/[0.06] text-xs font-mono text-blue-400 bg-gradient-to-r from-blue-400/[0.08] to-transparent">
                {comparison.codeTheirs.label}
              </div>
              <pre class="p-4 overflow-x-auto text-xs leading-relaxed"><code class="font-mono text-text-secondary">{comparison.codeTheirs.code}</code></pre>
            </div>
          )}
        </div>
      </div>
    </section>
  )}

  <!-- When to Use Which -->
  <section class="section-stack px-4 py-16 sm:px-6 sm:py-24 lg:px-8">
    <div class="mx-auto max-w-5xl">
      <div class="mb-10 text-center reveal">
        <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">
          {t["compare.whenToUse"] ?? "When to Use Which"}
        </h2>
      </div>

      <div class="grid gap-6 sm:grid-cols-2 reveal">
        <div class="glass-card rounded-2xl p-5 sm:p-7 lg:p-8 border-l-4 border-green-400/40">
          <h3 class="text-lg font-semibold mb-4 flex items-center gap-2">
            <svg class="w-5 h-5 text-green-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
            {(t["compare.whenToUse.ours"] ?? "Choose {product} when:").replace("{product}", comparison.product)}
          </h3>
          <ul class="space-y-2 text-text-secondary leading-relaxed">
            {comparison.whenOurs[lang].split("\n").filter((line: string) => line.trim()).map((line: string) => (
              <li class="flex items-start gap-2">
                <svg class="w-4 h-4 mt-0.5 text-green-400/60 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                <span>{line.trim()}</span>
              </li>
            ))}
          </ul>
        </div>
        <div class="glass-card rounded-2xl p-5 sm:p-7 lg:p-8 border-l-4 border-blue-400/40">
          <h3 class="text-lg font-semibold mb-4 flex items-center gap-2">
            <svg class="w-5 h-5 text-blue-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /></svg>
            {(t["compare.whenToUse.theirs"] ?? "Choose {competitor} when:").replace("{competitor}", comparison.competitor)}
          </h3>
          <ul class="space-y-2 text-text-secondary leading-relaxed">
            {comparison.whenTheirs[lang].split("\n").filter((line: string) => line.trim()).map((line: string) => (
              <li class="flex items-start gap-2">
                <svg class="w-4 h-4 mt-0.5 text-blue-400/60 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
                <span>{line.trim()}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  {comparison.faq.length > 0 && (
    <section class="section-stack px-4 py-16 sm:px-6 sm:py-24 lg:px-8">
      <div class="mx-auto max-w-4xl">
        <div class="mb-10 text-center reveal">
          <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">
            {t["compare.faq.title"] ?? "Frequently Asked Questions"}
          </h2>
        </div>

        <div class="space-y-3 reveal-group">
          {comparison.faq.map((item) => (
            <details class="reveal group rounded-2xl border border-border border-l-2 border-l-accent/30 bg-surface transition-colors hover:border-accent/30">
              <summary class="flex cursor-pointer items-center justify-between px-4 py-3 sm:px-6 sm:py-4 text-sm sm:text-base font-semibold select-none">
                <span>{item.question[lang]}</span>
                <svg
                  class="h-5 w-5 shrink-0 text-text-tertiary transition-transform group-open:rotate-180"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <div class="px-4 pb-3 sm:px-6 sm:pb-4 text-sm text-text-secondary leading-relaxed">
                {item.answer[lang]}
              </div>
            </details>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Related Comparisons -->
  {relatedComparisons.length > 0 && (
    <section class="section-stack px-4 py-16 sm:px-6 sm:py-24 lg:px-8">
      <div class="mx-auto max-w-5xl">
        <div class="mb-10 text-center reveal">
          <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">
            {t["compare.relatedTitle"] ?? "Related Comparisons"}
          </h2>
        </div>

        <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 reveal-group">
          {relatedComparisons.map((rel) => (
            <a
              href={`/compare/${rel!.slug}/`}
              class="glass-card glow-card rounded-2xl p-6 flex items-center justify-between gap-4 reveal group"
            >
              <div>
                <h3 class="font-semibold group-hover:text-accent transition-colors">
                  {rel!.product} vs {rel!.competitor}
                </h3>
                <p class="text-sm text-text-secondary mt-1 line-clamp-2">{rel!.verdict[lang]}</p>
              </div>
              <svg class="w-5 h-5 shrink-0 text-text-tertiary group-hover:text-accent transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
              </svg>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <section class="relative section-stack px-4 py-20 sm:px-6 sm:py-28 lg:px-8 lg:py-36">
    <div class="pointer-events-none absolute inset-0 flex items-center justify-center" aria-hidden="true">
      <div class="h-[180px] w-[300px] sm:h-[280px] sm:w-[480px] rounded-full bg-accent/[0.06] blur-[60px] sm:blur-[90px]"></div>
    </div>
    <div class="mx-auto max-w-3xl text-center reveal relative">
      <div class="glass-card glow-card rounded-2xl p-6 sm:p-10 lg:p-14">
        <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">
          {(t["compare.cta.title"] ?? "Ready to try {product}?").replace("{product}", comparison.product)}
        </h2>
        <a
          href={productHref}
          class="mt-6 sm:mt-8 inline-flex items-center gap-2 rounded-full bg-accent px-6 py-2.5 sm:px-8 sm:py-3 text-sm sm:text-base font-semibold text-white transition-colors hover:bg-accent-hover"
        >
          {t["compare.cta.button"] ?? "Get Started"}
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <OssFooter t={t} />
</Layout>
