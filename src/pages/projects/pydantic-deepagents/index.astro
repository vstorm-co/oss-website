---
import Layout from "../../../layouts/Layout.astro";
import Navbar from "../../../components/Navbar.astro";
import DeepAgentsHero from "../../../components/deepagents/DeepAgentsHero.astro";
import DeepAgentsFeatures from "../../../components/deepagents/DeepAgentsFeatures.astro";
import DeepAgentsHowItWorks from "../../../components/deepagents/DeepAgentsHowItWorks.astro";
import Architecture from "../../../components/deepagents/Architecture.astro";
import CodeExamples from "../../../components/deepagents/CodeExamples.astro";
import UseCases from "../../../components/deepagents/UseCases.astro";
import Showcase from "../../../components/deepagents/Showcase.astro";
import OssFooter from "../../../components/oss/OssFooter.astro";
import BeforeAfter from "../../../components/shared/BeforeAfter.astro";
import ComparisonTable from "../../../components/shared/ComparisonTable.astro";
import StarsBadge from "../../../components/shared/StarsBadge.astro";
import FaqPreview from "../../../components/landing/FaqPreview.astro";
import Breadcrumbs from "../../../components/shared/Breadcrumbs.astro";
import { translations, languages, defaultLang } from "../../../i18n/translations";
import { getProjectBySlug } from "../../../data/projects";
import { getDeepagentsComparison } from "../../../data/comparisons";
import { softwareApplicationSchema, faqPageSchema, SITE_URL } from "../../../lib/schemas";

const lang = defaultLang;
const t = translations[lang];
const project = getProjectBySlug("pydantic-deepagents")!;

const alternates = [
  { lang: "en", href: "/projects/pydantic-deepagents/" },
  ...Object.keys(languages)
    .filter((l) => l !== defaultLang)
    .map((l) => ({ lang: l, href: `/${l}/projects/pydantic-deepagents/` })),
];

const deepagentsFaqItems = [
  {
    question: "What is Pydantic DeepAgents?",
    answer:
      "Production-grade Python framework for building autonomous AI agents on top of Pydantic AI. Implements the deep agent pattern: planning, filesystem ops, sandboxed execution, subagent delegation, context compression, and human-in-the-loop.",
  },
  {
    question: "How is it different from LangChain Deep Agents?",
    answer:
      "Built on Pydantic AI (not LangGraph), full type safety, modular architecture with independently usable packages. Same capabilities but with Pydantic's developer experience.",
  },
  {
    question: "Does it support human-in-the-loop?",
    answer:
      "Yes, via Pydantic AI's DeferredToolRequests. Tools can require approval before execution, with configurable permission presets (DEFAULT, PERMISSIVE, READONLY, STRICT).",
  },
  {
    question: "Can agents delegate to sub-agents?",
    answer:
      "Yes, the subagents package supports sync, async, and auto-mode delegation with background task management, cancellation, and inter-agent messaging.",
  },
  {
    question: "What models does it support?",
    answer:
      "Any model supported by Pydantic AI: OpenAI, Anthropic, Google Gemini, Mistral, Ollama (local), and more via OpenRouter.",
  },
];
---

<Layout
  theme="dark"
  title="Pydantic DeepAgents — Autonomous AI Agent Framework for Python"
  description={t["deepagents.meta.description"]}
  keywords="pydantic deepagents, ai agent framework, claude code alternative, python ai agents, autonomous agents, deep agents python, pydantic ai"
  lang={lang}
  alternates={alternates}
  schemas={[
    softwareApplicationSchema({
      name: "Pydantic DeepAgents",
      description: t["deepagents.meta.description"],
      url: SITE_URL + "/projects/pydantic-deepagents/",
      github: "vstorm-co/pydantic-deepagents",
      pypi: "pydantic-deepagents",
    }),
    faqPageSchema({ questions: deepagentsFaqItems }),
  ]}
>
  <Navbar currentLang={lang} project={project} pathSuffix="projects/pydantic-deepagents/" />
  <Breadcrumbs
    items={[
      { label: "Home", href: "/" },
      { label: t["oss.projects.title"], href: "/projects/" },
      { label: "Pydantic DeepAgents" },
    ]}
  />
  <DeepAgentsHero t={t} />
  <BeforeAfter
    title={t["beforeafter.title"]}
    beforeTitle={t["beforeafter.deepagents.before.title"]}
    afterTitle={t["beforeafter.deepagents.after.title"]}
    beforeItems={[
      t["beforeafter.deepagents.before.1"],
      t["beforeafter.deepagents.before.2"],
      t["beforeafter.deepagents.before.3"],
      t["beforeafter.deepagents.before.4"],
      t["beforeafter.deepagents.before.5"],
    ]}
    afterItems={[
      t["beforeafter.deepagents.after.1"],
      t["beforeafter.deepagents.after.2"],
      t["beforeafter.deepagents.after.3"],
      t["beforeafter.deepagents.after.4"],
      t["beforeafter.deepagents.after.5"],
    ]}
  />
  <DeepAgentsHowItWorks t={t} />
  <DeepAgentsFeatures t={t} />
  <ComparisonTable t={t} data={getDeepagentsComparison(t)} />
  <Architecture t={t} />
  <CodeExamples t={t} />
  <UseCases t={t} />
  <Showcase t={t} />
  <FaqPreview t={t} lang={lang} category="deepagents" />

  <!-- FAQ -->
  <section class="px-4 py-16 sm:px-6 sm:py-24 lg:px-8">
    <div class="mx-auto max-w-3xl">
      <h2 class="mb-10 text-center text-2xl font-bold tracking-tight sm:text-3xl">
        Frequently Asked Questions
      </h2>
      <div class="space-y-3">
        {
          deepagentsFaqItems.map((item) => (
            <details class="glass-card group rounded-xl p-5">
              <summary class="text-text flex cursor-pointer items-center justify-between font-semibold">
                {item.question}
                <svg
                  class="text-text-tertiary h-5 w-5 shrink-0 transition-transform group-open:rotate-180"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <p class="text-text-secondary mt-3 text-sm leading-relaxed">{item.answer}</p>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <OssFooter t={t} variant="deepagents" />
</Layout>
