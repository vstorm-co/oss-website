---
import Layout from "../../../layouts/Layout.astro";
import Navbar from "../../../components/Navbar.astro";
import Hero from "../../../components/landing/Hero.astro";
import FrameworkLogos from "../../../components/landing/FrameworkLogos.astro";
import Features from "../../../components/landing/Features.astro";
import Presets from "../../../components/landing/Presets.astro";
import TemplateHowItWorks from "../../../components/landing/TemplateHowItWorks.astro";
import QuickStart from "../../../components/landing/QuickStart.astro";
import FaqPreview from "../../../components/landing/FaqPreview.astro";
import Footer from "../../../components/landing/Footer.astro";
import BeforeAfter from "../../../components/shared/BeforeAfter.astro";
import ComparisonTable from "../../../components/shared/ComparisonTable.astro";
import StarsBadge from "../../../components/shared/StarsBadge.astro";
import Breadcrumbs from "../../../components/shared/Breadcrumbs.astro";
import { translations, languages, defaultLang } from "../../../i18n/translations";
import { getProjectBySlug } from "../../../data/projects";
import { getTemplateComparison } from "../../../data/comparisons";
import { softwareApplicationSchema, faqPageSchema, SITE_URL } from "../../../lib/schemas";

const lang = defaultLang;
const t = translations[lang];
const project = getProjectBySlug("full-stack-ai-agent-template")!;
const basePath = "/projects/full-stack-ai-agent-template/";

const alternates = [
  { lang: "en", href: "/projects/full-stack-ai-agent-template/" },
  ...Object.keys(languages)
    .filter((l) => l !== defaultLang)
    .map((l) => ({ lang: l, href: `/${l}/projects/full-stack-ai-agent-template/` })),
];

const templateFaqItems = [
  {
    question: "What is the Full-Stack AI Agent Template?",
    answer:
      "Open-source project generator for production AI apps with FastAPI + Next.js. 5 AI frameworks, 75+ options, 3 presets. 1,730+ stars.",
  },
  {
    question: "Which AI frameworks does it support?",
    answer:
      "Pydantic AI, LangChain, LangGraph, CrewAI, and DeepAgents. Switch frameworks without changing your backend or frontend code.",
  },
  {
    question: "Does it include RAG?",
    answer:
      "Yes, v0.2.2 includes a full RAG pipeline: 4 vector stores (Milvus, Qdrant, ChromaDB, pgvector), hybrid search with BM25 + RRF, Cohere/CrossEncoder reranking, 4 embedding providers.",
  },
  {
    question: "Is it free?",
    answer:
      "Yes, MIT licensed. No signup required. Use the CLI (pip install fastapi-fullstack) or the web configurator.",
  },
  {
    question: "Can I use it in production?",
    answer:
      "Yes, battle-tested across 30+ production deployments. Includes Docker, Kubernetes, CI/CD, auth, observability, and background tasks out of the box.",
  },
];
---

<Layout
  theme="dark"
  title="Full-Stack AI Agent Template — Ship Production AI Apps In Minutes"
  description={t["meta.description"]}
  keywords="fastapi template, nextjs ai, ai agent template, python fullstack, pydantic ai template, production ai app, ai starter kit"
  lang={lang}
  alternates={alternates}
  schemas={[
    softwareApplicationSchema({
      name: "Full-Stack AI Agent Template",
      description: t["meta.description"],
      url: SITE_URL + "/projects/full-stack-ai-agent-template/",
      programmingLanguage: ["Python", "TypeScript"],
      github: "vstorm-co/full-stack-ai-agent-template",
      pypi: "fastapi-fullstack",
    }),
    faqPageSchema({ questions: templateFaqItems }),
  ]}
>
  <Navbar
    currentLang={lang}
    project={project}
    pathSuffix="projects/full-stack-ai-agent-template/"
  />
  <Breadcrumbs
    items={[
      { label: "Home", href: "/" },
      { label: t["oss.projects.title"], href: "/projects/" },
      { label: "Full-Stack AI Agent Template" },
    ]}
  />
  <Hero t={t} basePath={basePath} />
  <FrameworkLogos t={t} />
  <BeforeAfter
    title={t["beforeafter.title"]}
    beforeTitle={t["beforeafter.template.before.title"]}
    afterTitle={t["beforeafter.template.after.title"]}
    beforeItems={[
      t["beforeafter.template.before.1"],
      t["beforeafter.template.before.2"],
      t["beforeafter.template.before.3"],
      t["beforeafter.template.before.4"],
      t["beforeafter.template.before.5"],
    ]}
    afterItems={[
      t["beforeafter.template.after.1"],
      t["beforeafter.template.after.2"],
      t["beforeafter.template.after.3"],
      t["beforeafter.template.after.4"],
      t["beforeafter.template.after.5"],
    ]}
  />
  <TemplateHowItWorks t={t} />
  <Features t={t} />
  <ComparisonTable t={t} data={getTemplateComparison(t)} />
  <Presets t={t} basePath={basePath} />
  <QuickStart t={t} basePath={basePath} />
  <FaqPreview t={t} lang={lang} category="template" />

  <!-- FAQ -->
  <section class="px-4 py-16 sm:px-6 sm:py-24 lg:px-8">
    <div class="mx-auto max-w-3xl">
      <h2 class="mb-10 text-center text-2xl font-bold tracking-tight sm:text-3xl">
        Frequently Asked Questions
      </h2>
      <div class="space-y-3">
        {
          templateFaqItems.map((item) => (
            <details class="glass-card group rounded-xl p-5">
              <summary class="text-text flex cursor-pointer items-center justify-between font-semibold">
                {item.question}
                <svg
                  class="text-text-tertiary h-5 w-5 shrink-0 transition-transform group-open:rotate-180"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                  stroke-width="2"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
                </svg>
              </summary>
              <p class="text-text-secondary mt-3 text-sm leading-relaxed">{item.answer}</p>
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <Footer t={t} />
</Layout>
