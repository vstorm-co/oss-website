---
import Layout from "../../../layouts/Layout.astro";
import Navbar from "../../../components/Navbar.astro";
import ConfiguratorApp from "../../../components/configurator/ConfiguratorApp";
import Breadcrumbs from "../../../components/shared/Breadcrumbs.astro";
import { getProjectBySlug } from "../../../data/projects";
import { languages, defaultLang } from "../../../i18n/translations";

const url = new URL(Astro.request.url);
const preset = url.searchParams.get("preset") || undefined;
const project = getProjectBySlug("full-stack-ai-agent-template")!;

const alternates = [
  { lang: "en", href: "/projects/full-stack-ai-agent-template/configurator/" },
  ...Object.keys(languages)
    .filter((l) => l !== defaultLang)
    .map((l) => ({ lang: l, href: `/${l}/projects/full-stack-ai-agent-template/configurator/` })),
];
---

<Layout
  theme="dark"
  title="Configure Your Project — Vstorm OSS"
  description="Configure and download a production-ready FastAPI + Next.js AI project. Choose from 5 AI frameworks, databases, auth, and 75+ options."
  alternates={alternates}
  schemas={[]}
>
  <Navbar showLang={false} project={project} pathSuffix="projects/full-stack-ai-agent-template/" />
  <Breadcrumbs
    items={[
      { label: "Home", href: "/" },
      { label: "Projects", href: "/projects/" },
      { label: "Full-Stack AI Agent Template", href: "/projects/full-stack-ai-agent-template/" },
      { label: "Configurator" },
    ]}
  />
  <div class="mx-auto max-w-7xl px-4 py-8">
    <h1 class="sr-only">Configure Your Full-Stack AI Agent Template Project</h1>
    <ConfiguratorApp client:only="react" initialPreset={preset} />
  </div>
</Layout>
