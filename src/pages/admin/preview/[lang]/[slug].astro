---
import { getCollection, render } from 'astro:content';
import BlogLayout from '../../../../layouts/BlogLayout.astro';
import type { Lang } from '../../../../i18n/translations';

export async function getStaticPaths() {
  // Preview route is dev-only. Return empty in production so these pages don't ship.
  if (!import.meta.env.DEV) return [];
  const posts = await getCollection('blog');
  return posts.map((post) => {
    const slug = post.id.split('/').slice(1).join('/');
    return {
      params: { lang: post.data.lang, slug },
      props: { post },
    };
  });
}

const { post } = Astro.props;
const lang = post.data.lang as Lang;
const { Content, headings } = await render(post);
const readingTime = post.body ? Math.max(1, Math.ceil(post.body.split(/\s+/).length / 200)) : undefined;

const allPosts = await getCollection('blog', ({ data }) =>
  data.translationKey === post.data.translationKey
);
const allTranslations = allPosts.map((p) => ({
  lang: p.data.lang as Lang,
  slug: p.id.split('/').slice(1).join('/'),
}));
---

<BlogLayout
  title={post.data.title}
  seoTitle={post.data.seoTitle}
  description={post.data.description}
  pubDate={post.data.pubDate}
  updatedDate={post.data.updatedDate}
  author={post.data.author}
  tags={post.data.tags}
  lang={lang}
  translationKey={post.data.translationKey}
  headings={headings}
  allTranslations={allTranslations}
  readingTime={readingTime}
  category={post.data.category}
>
  <Content />
</BlogLayout>

<script is:inline>
  // Preserve scroll position across reloads driven by the admin panel or Vite HMR.
  const saved = sessionStorage.getItem('admin-preview-scroll');
  if (saved) {
    window.scrollTo(0, parseInt(saved, 10));
    sessionStorage.removeItem('admin-preview-scroll');
  }
  window.addEventListener('beforeunload', () => {
    sessionStorage.setItem('admin-preview-scroll', String(window.scrollY));
  });
</script>
