---
import { isPublished } from "@/lib/blog";
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/landing/Footer.astro";
import BlogCard from "../../components/blog/BlogCard.astro";
import Pagination from "../../components/blog/Pagination.astro";
import { getCollection } from "astro:content";
import Breadcrumbs from "../../components/shared/Breadcrumbs.astro";
import BlogSearch from "../../components/blog/BlogSearch.astro";
import { translations, languages, defaultLang } from "../../i18n/translations";
import { collectionPageSchema, SITE_URL } from "../../lib/schemas";

export async function getStaticPaths({ paginate }: { paginate: Function }) {
  const allPosts = (
    await getCollection("blog", ({ data }) => data.lang === "en" && isPublished(data))
  ).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

  return paginate(allPosts, { pageSize: 20 });
}

const lang = defaultLang;
const t = translations[lang];
const { page } = Astro.props;
const categories = ["open-source", "tutorial", "article", "news"] as const;

const alternates = [
  { lang: "en", href: "/blog/" },
  ...Object.keys(languages)
    .filter((l) => l !== defaultLang)
    .map((l) => ({ lang: l, href: `/${l}/blog/` })),
];
---

<Layout
  title={`${t["blog.title"]}${page.currentPage > 1 ? ` — Page ${page.currentPage}` : ""} — Vstorm OSS`}
  description={t["blog.subtitle"]}
  keywords="ai agent blog, pydantic ai tutorials, python ai guides, ai framework comparison, llm engineering"
  lang={lang}
  alternates={alternates}
  noindex={page.currentPage > 1}
  schemas={[
    collectionPageSchema({
      name: t["blog.title"],
      description: t["blog.subtitle"],
      url: SITE_URL + "/blog/",
    }),
  ]}
>
  <Navbar currentLang={lang} languageLinks={alternates} />
  <Breadcrumbs items={[{ label: "Home", href: "/" }, { label: t["nav.blog"] }]} />

  <main class="mx-auto max-w-3xl px-4 py-16 sm:py-24">
    <div class="reveal mb-12 text-center">
      <h1 class="heading-accent text-3xl font-bold tracking-tight sm:text-4xl">
        {t["blog.title"]}
      </h1>
      <p class="text-text-secondary mx-auto mt-4 max-w-2xl text-lg">{t["blog.subtitle"]}</p>
    </div>

    <!-- Category filter tabs -->
    <div class="mb-8 flex flex-wrap justify-center gap-2" id="category-filter">
      <button
        data-category="all"
        class="category-tab active cursor-pointer rounded-full px-4 py-1.5 text-sm font-medium transition-colors"
      >
        {t["blog.allCategories"]}
      </button>
      {
        categories.map((cat) => (
          <button
            data-category={cat}
            class="category-tab cursor-pointer rounded-full px-4 py-1.5 text-sm font-medium transition-colors"
          >
            {t[`blog.category.${cat}` as keyof typeof t]}
          </button>
        ))
      }
    </div>

    <BlogSearch placeholder={t["blog.search"]} />

    {
      page.data.length === 0 ? (
        <p class="text-text-secondary text-center">{t["blog.noPosts"]}</p>
      ) : (
        <div class="space-y-4" id="blog-list">
          {page.data.map((post) => {
            const slug = post.id.split("/").slice(1).join("/");
            return (
              <div data-post-category={post.data.category || "open-source"}>
                <BlogCard
                  title={post.data.title}
                  description={post.data.description}
                  pubDate={post.data.pubDate}
                  href={`/blog/${slug}/`}
                  tags={post.data.tags}
                  lang={lang}
                  category={post.data.category}
                  author={post.data.author}
                />
              </div>
            );
          })}
        </div>
      )
    }

    <p id="no-filtered-posts" class="text-text-secondary py-8 text-center" style="display:none;">
      {t["blog.noPosts"]}
    </p>

    <Pagination currentPage={page.currentPage} lastPage={page.lastPage} basePath="/blog" t={t} />
  </main>

  <Footer t={t} />
</Layout>

<style>
  .category-tab {
    color: var(--color-text-secondary);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
  }
  .category-tab:hover {
    color: var(--color-text);
    border-color: var(--color-border-hover);
  }
  .category-tab.active {
    color: var(--color-accent);
    background: color-mix(in srgb, var(--color-accent) 10%, transparent);
    border-color: var(--color-accent);
  }
</style>

<script>
  function initCategoryFilter() {
    const tabs = document.querySelectorAll(".category-tab");
    const posts = document.querySelectorAll("[data-post-category]");
    const pagination = document.querySelector(".pagination-nav");
    const noPosts = document.getElementById("no-filtered-posts");

    tabs.forEach((tab) => {
      tab.addEventListener("click", () => {
        tabs.forEach((t) => t.classList.remove("active"));
        tab.classList.add("active");

        const cat = tab.dataset.category;
        let visible = 0;
        posts.forEach((post) => {
          if (cat === "all" || post.dataset.postCategory === cat) {
            post.style.display = "";
            visible++;
          } else {
            post.style.display = "none";
          }
        });

        if (pagination) pagination.style.display = cat === "all" ? "" : "none";
        if (noPosts) noPosts.style.display = visible === 0 ? "" : "none";
      });
    });
  }

  initCategoryFilter();
  document.addEventListener("astro:page-load", initCategoryFilter);
</script>
