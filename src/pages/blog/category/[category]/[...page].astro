---
import Layout from '../../../../layouts/Layout.astro';
import Navbar from '../../../../components/Navbar.astro';
import Footer from '../../../../components/landing/Footer.astro';
import BlogCard from '../../../../components/blog/BlogCard.astro';
import Pagination from '../../../../components/blog/Pagination.astro';
import { getCollection } from 'astro:content';
import Breadcrumbs from '../../../../components/shared/Breadcrumbs.astro';
import BlogSearch from '../../../../components/blog/BlogSearch.astro';
import { translations, defaultLang } from '../../../../i18n/translations';
import { collectionPageSchema, SITE_URL } from '../../../../lib/schemas';

export async function getStaticPaths({ paginate }: { paginate: Function }) {
  const allPosts = (
    await getCollection('blog', ({ data }) => data.lang === 'en' && !data.draft)
  ).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

  const categories = ["open-source", "tutorial", "article", "news"] as const;

  return categories.flatMap((cat) => {
    const filtered = allPosts.filter((p) => p.data.category === cat);
    return paginate(filtered, {
      pageSize: 20,
      params: { category: cat },
    });
  });
}

const lang = defaultLang;
const t = translations[lang];
const { page } = Astro.props;
const { category } = Astro.params;
const categories = ["open-source", "tutorial", "article", "news"] as const;

const categoryKey = `blog.category.${category}` as keyof typeof t;
const categoryLabel = t[categoryKey] || category;

// Blog category pages are English-only - only show English in language switcher
const languageLinks = [{ lang: defaultLang, href: `/blog/category/${category}/` }];
---

<Layout
  title={`${categoryLabel} — ${t["blog.title"]} — Vstorm OSS`}
  description={t["blog.subtitle"]}
  keywords="ai agent blog, pydantic ai tutorials, python ai guides, ai framework comparison"
  lang={lang}
  schemas={[collectionPageSchema({ name: `${categoryLabel} — ${t["blog.title"]}`, description: t["blog.subtitle"], url: SITE_URL + `/blog/category/${category}/` })]}
  theme="light"
  noindex={true}
>
  <Navbar currentLang={lang} languageLinks={languageLinks} />

  <Breadcrumbs items={[
    { label: "Home", href: "/" },
    { label: t["blog.title"], href: "/blog/" },
    { label: categoryLabel },
  ]} />

  <main class="mx-auto max-w-3xl px-4 py-16 sm:py-24">
    <div class="mb-12 text-center reveal">
      <h1 class="text-3xl font-bold tracking-tight sm:text-4xl heading-accent">{t["blog.title"]}</h1>
      <p class="mt-4 text-lg text-text-secondary max-w-2xl mx-auto">{t["blog.subtitle"]}</p>
    </div>

    <!-- Category filter tabs -->
    <div class="mb-8 flex flex-wrap justify-center gap-2">
      <a
        href="/blog/"
        class="category-tab rounded-full px-4 py-1.5 text-sm font-medium transition-colors"
      >
        {t["blog.allCategories"]}
      </a>
      {categories.map((cat) => (
        <a
          href={`/blog/category/${cat}/`}
          class:list={["category-tab rounded-full px-4 py-1.5 text-sm font-medium transition-colors", cat === category && "active"]}
        >
          {t[`blog.category.${cat}` as keyof typeof t]}
        </a>
      ))}
    </div>

    {page.data.length === 0 ? (
      <p class="text-center text-text-secondary">{t["blog.noPosts"]}</p>
    ) : (
      <div class="space-y-4">
        {page.data.map((post) => {
          const slug = post.id.split('/').slice(1).join('/');
          return (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              href={`/blog/${slug}/`}
              tags={post.data.tags}
              lang={lang}
              category={post.data.category}
              author={post.data.author}
            />
          );
        })}
      </div>
    )}

    <Pagination
      currentPage={page.currentPage}
      lastPage={page.lastPage}
      basePath={`/blog/category/${category}`}
      t={t}
    />
  </main>

  <Footer t={t} />
</Layout>

<style>
  .category-tab {
    color: var(--color-text-secondary);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
  }
  .category-tab:hover {
    color: var(--color-text);
    border-color: var(--color-border-hover);
  }
  .category-tab.active {
    color: var(--color-accent);
    background: color-mix(in srgb, var(--color-accent) 10%, transparent);
    border-color: var(--color-accent);
  }
</style>
