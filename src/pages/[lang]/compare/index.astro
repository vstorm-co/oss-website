---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar.astro';
import OssFooter from '../../../components/oss/OssFooter.astro';
import Breadcrumbs from '../../../components/shared/Breadcrumbs.astro';
import { translations, languages, defaultLang, type Lang } from '../../../i18n/translations';
import { comparisonPages } from '../../../data/compare-pages';
import { collectionPageSchema, SITE_URL } from '../../../lib/schemas';

export function getStaticPaths() {
  return Object.keys(languages)
    .filter((lang) => lang !== defaultLang)
    .map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const t = translations[lang];

const alternates = [
  { lang: "en", href: "/compare/" },
  ...Object.keys(languages)
    .filter((l) => l !== defaultLang)
    .map((l) => ({ lang: l, href: `/${l}/compare/` })),
];
---

<Layout
  title={`${t["compare.index.title"] ?? "Compare"} — Vstorm OSS`}
  description={t["compare.index.subtitle"] ?? "Side-by-side comparisons of AI agent frameworks, templates, and tools."}
  keywords="ai framework comparison, pydantic ai vs langchain, ai agent template comparison, python ai tools"
  lang={lang}
  alternates={alternates}
  schemas={[collectionPageSchema({ name: t["compare.index.title"] ?? "Compare", description: t["compare.index.subtitle"] ?? "Side-by-side comparisons of AI agent frameworks, templates, and tools.", url: SITE_URL + `/${lang}/compare/` })]}
>
  <Navbar currentLang={lang} />

  <Breadcrumbs items={[
    { label: "Home", href: `/${lang}/` },
    { label: t["compare.index.title"] ?? "Compare" },
  ]} />

  <main class="mx-auto max-w-3xl px-4 py-16 sm:py-24">
    <!-- Hero -->
    <div class="mb-12 text-center reveal">
      <h1 class="text-3xl font-bold tracking-tight sm:text-4xl heading-accent">
        {t["compare.index.title"] ?? "Compare"}
      </h1>
      <p class="mt-4 text-lg text-text-secondary max-w-2xl mx-auto">
        {t["compare.index.subtitle"] ?? "Side-by-side comparisons of AI agent frameworks, templates, and tools."}
      </p>
    </div>

    <!-- List -->
    <div class="space-y-4 reveal-group">
      {comparisonPages.map((page) => (
        <a
          href={`/${lang}/compare/${page.slug}/`}
          class="group block glass-card rounded-xl p-6 hover:border-accent/30 relative overflow-hidden"
        >
          <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-accent/0 to-transparent group-hover:via-accent/50 transition-all duration-500"></div>
          <div class="flex items-center gap-3 text-sm text-text-tertiary">
            <span class="rounded-full bg-accent/10 px-2.5 py-0.5 text-xs font-medium text-accent">
              {page.category}
            </span>
            <span>&middot;</span>
            <span>{page.highlights.length} key differences</span>
            <span>&middot;</span>
            <span>{page.tableRows.length} features compared</span>
          </div>
          <h2 class="mt-2 text-lg font-semibold text-text group-hover:text-accent transition-colors">
            {page.product} vs {page.competitor}
          </h2>
          <p class="mt-2 text-sm text-text-secondary line-clamp-2">{page.verdict[lang]}</p>
        </a>
      ))}
    </div>
  </main>

  <OssFooter t={t} lang={lang} />
</Layout>
