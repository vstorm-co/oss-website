---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar.astro';
import OssFooter from '../../../components/oss/OssFooter.astro';
import Breadcrumbs from '../../../components/shared/Breadcrumbs.astro';
import { translations, languages, defaultLang, type Lang } from '../../../i18n/translations';
import { useCasePages } from '../../../data/use-case-pages';
import { collectionPageSchema, SITE_URL } from '../../../lib/schemas';

export function getStaticPaths() {
  return Object.keys(languages)
    .filter((lang) => lang !== defaultLang)
    .map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const t = translations[lang];

const alternates = [
  { lang: "en", href: "/use-cases/" },
  ...Object.keys(languages)
    .filter((l) => l !== defaultLang)
    .map((l) => ({ lang: l, href: `/${l}/use-cases/` })),
];

function difficultyColor(d: string) {
  if (d === "beginner") return "text-green-400 bg-green-400/10";
  if (d === "intermediate") return "text-amber-400 bg-amber-400/10";
  return "text-red-400 bg-red-400/10";
}
---

<Layout
  title={`${t["usecases.index.title"] ?? "Use Cases"} — Vstorm OSS`}
  description={t["usecases.index.subtitle"] ?? "Real-world use cases with working code examples — research agents, RAG chatbots, SQL agents, and more."}
  keywords="ai agent use cases, python ai examples, rag chatbot tutorial, research agent, text to sql agent, code review agent"
  lang={lang}
  alternates={alternates}
  schemas={[collectionPageSchema({ name: t["usecases.index.title"] ?? "Use Cases", description: t["usecases.index.subtitle"] ?? "Real-world use cases with working code examples — research agents, RAG chatbots, SQL agents, and more.", url: SITE_URL + `/${lang}/use-cases/` })]}
>
  <Navbar currentLang={lang} />

  <Breadcrumbs items={[
    { label: "Home", href: `/${lang}/` },
    { label: t["usecases.index.title"] ?? "Use Cases" },
  ]} />

  <main class="mx-auto max-w-4xl px-4 py-16 sm:py-24">
    <div class="mb-12 text-center reveal">
      <h1 class="text-3xl font-bold tracking-tight sm:text-4xl heading-accent">
        {t["usecases.index.title"] ?? "Use Cases"}
      </h1>
      <p class="mt-4 text-lg text-text-secondary max-w-2xl mx-auto">
        {t["usecases.index.subtitle"] ?? "Real-world use cases with working code examples — research agents, RAG chatbots, SQL agents, and more."}
      </p>
    </div>

    <div class="grid gap-6 sm:grid-cols-2 reveal-group">
      {useCasePages.map((page) => (
        <a
          href={`/${lang}/use-cases/${page.slug}/`}
          class="group glass-card rounded-2xl p-6 hover:border-accent/30 transition-all relative overflow-hidden flex flex-col"
        >
          <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-accent/0 to-transparent group-hover:via-accent/50 transition-all duration-500"></div>
          <div class="flex items-center gap-2 text-xs">
            <span class={`rounded-full px-2.5 py-0.5 font-medium ${difficultyColor(page.difficulty)}`}>
              {page.difficulty}
            </span>
            <span class="text-text-tertiary">{page.timeToComplete}</span>
          </div>
          <h2 class="mt-3 text-lg font-semibold text-text group-hover:text-accent transition-colors">
            {page.title[lang]}
          </h2>
          <p class="mt-2 text-sm text-text-secondary line-clamp-3 flex-1">{page.description[lang]}</p>
          <div class="mt-4 flex flex-wrap gap-1.5">
            {page.tags.map((tag) => (
              <span class="rounded-full border border-border px-2 py-0.5 text-[10px] text-text-tertiary">{tag}</span>
            ))}
          </div>
        </a>
      ))}
    </div>
  </main>

  <OssFooter t={t} lang={lang} />
</Layout>
