---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar.astro';
import OssFooter from '../../../components/oss/OssFooter.astro';
import Breadcrumbs from '../../../components/shared/Breadcrumbs.astro';
import ArchitectureQuiz from '../../../components/tools/ArchitectureQuiz';
import { translations, languages, defaultLang, type Lang } from '../../../i18n/translations';
import { softwareApplicationSchema, SITE_URL } from '../../../lib/schemas';

export function getStaticPaths() {
  return Object.keys(languages)
    .filter((lang) => lang !== defaultLang)
    .map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const t = translations[lang];

const alternates = [
  { lang: "en", href: "/tools/architecture-quiz/" },
  ...Object.keys(languages)
    .filter((l) => l !== defaultLang)
    .map((l) => ({ lang: l, href: `/${l}/tools/architecture-quiz/` })),
];

const architectures = [
  { name: "Simple ReAct Agent", description: t["tools.quiz.arch.simple"] ?? "Single agent with tool loop — great for chatbots and Q&A." },
  { name: "RAG Pipeline", description: t["tools.quiz.arch.rag"] ?? "Retrieval-augmented generation for knowledge-heavy tasks." },
  { name: "Pipeline Agent", description: t["tools.quiz.arch.pipeline"] ?? "Sequential multi-step processing for content and data workflows." },
  { name: "Multi-Agent System", description: t["tools.quiz.arch.multi"] ?? "Multiple specialized agents collaborating on complex tasks." },
  { name: "Hierarchical Agents", description: t["tools.quiz.arch.hierarchical"] ?? "Orchestrator + specialists for enterprise-grade automation." },
];
---

<Layout
  title={`${t["tools.quiz.title"] ?? "Agent Architecture Quiz"} — Vstorm OSS`}
  description={t["tools.quiz.subtitle"] ?? "Take a free 5-question quiz to discover the best AI agent architecture for your project."}
  keywords="ai agent architecture, agent design patterns, react agent pattern, rag pipeline architecture, multi agent system, hierarchical agents, ai agent quiz"
  lang={lang}
  alternates={alternates}
  schemas={[softwareApplicationSchema({ name: "Agent Architecture Quiz", description: t["tools.quiz.subtitle"] ?? "Free interactive quiz to find the best AI agent architecture for your use case — from simple ReAct to hierarchical multi-agent systems.", url: SITE_URL + "/tools/architecture-quiz/", operatingSystem: "Web" })]}
>
  <Navbar currentLang={lang} />

  <Breadcrumbs items={[
    { label: "Home", href: `/${lang}/` },
    { label: t["tools.index.title"] ?? "Free Tools", href: `/${lang}/tools/` },
    { label: t["tools.quiz.title"] ?? "Architecture Quiz" },
  ]} />

  <!-- Hero -->
  <section class="relative mx-auto max-w-4xl px-4 pt-28 pb-12 sm:px-6 sm:pt-36 sm:pb-16 lg:px-8 text-center">
    <div class="pointer-events-none absolute inset-0 -top-24 flex items-center justify-center" aria-hidden="true">
      <div class="h-[200px] w-[300px] sm:h-[340px] sm:w-[540px] rounded-full bg-accent/[0.07] blur-[60px] sm:blur-[100px]"></div>
    </div>
    <div class="reveal relative">
      <span class="inline-flex items-center rounded-full border border-green-500/30 bg-green-500/10 px-3 py-1 text-xs font-medium text-green-400 mb-6">
        {t["tools.badge.quiz"] ?? "Free Quiz — 5 Questions"}
      </span>
      <h1 class="text-3xl font-bold tracking-tight sm:text-4xl lg:text-5xl heading-accent">
        {t["tools.quiz.title"] ?? "Agent Architecture Quiz"}
      </h1>
      <p class="mt-6 text-lg sm:text-xl text-text-secondary max-w-2xl mx-auto leading-relaxed">
        {t["tools.quiz.subtitle"] ?? "Answer 5 quick questions about your project and discover the ideal agent architecture pattern — with a framework recommendation and next steps."}
      </p>
    </div>
  </section>

  <!-- Quiz -->
  <section class="section-stack px-4 py-16 sm:px-6 sm:py-24 lg:px-8">
    <div class="mx-auto max-w-2xl force-dark">
      <ArchitectureQuiz client:only="react" />
    </div>
  </section>

  <!-- Architecture Patterns Overview -->
  <section class="section-stack px-4 py-16 sm:px-6 sm:py-24 lg:px-8">
    <div class="mx-auto max-w-4xl">
      <div class="mb-10 text-center reveal">
        <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">
          {t["tools.quiz.patterns.title"] ?? "Architecture Patterns We Evaluate"}
        </h2>
      </div>
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3 reveal-group">
        {architectures.map((arch) => (
          <div class="reveal glass-card rounded-xl p-5">
            <h3 class="font-semibold text-sm">{arch.name}</h3>
            <p class="mt-1 text-xs text-text-secondary leading-relaxed">{arch.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative section-stack px-4 py-20 sm:px-6 sm:py-28 lg:px-8 lg:py-36">
    <div class="pointer-events-none absolute inset-0 flex items-center justify-center" aria-hidden="true">
      <div class="h-[180px] w-[300px] sm:h-[280px] sm:w-[480px] rounded-full bg-accent/[0.06] blur-[60px] sm:blur-[90px]"></div>
    </div>
    <div class="mx-auto max-w-3xl text-center reveal relative">
      <div class="glass-card glow-card rounded-2xl p-6 sm:p-10 lg:p-14">
        <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">
          {t["tools.quiz.cta.title"] ?? "Know your architecture — now pick a framework"}
        </h2>
        <p class="mt-4 text-text-secondary">
          {t["tools.quiz.cta.description"] ?? "Use our framework comparison calculator to find the best framework for your chosen architecture."}
        </p>
        <div class="mt-6 sm:mt-8 flex flex-wrap items-center justify-center gap-3">
          <a
            href={`/${lang}/tools/framework-comparison/`}
            class="inline-flex items-center gap-2 rounded-full bg-accent px-6 py-2.5 sm:px-8 sm:py-3 text-sm sm:text-base font-semibold text-white transition-colors hover:bg-accent-hover"
          >
            {t["tools.quiz.cta.button"] ?? "Compare Frameworks"}
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
          <a
            href={`/${lang}/tools/ai-agent-configurator/`}
            class="inline-flex items-center gap-2 rounded-full border border-border px-6 py-2.5 sm:px-8 sm:py-3 text-sm sm:text-base font-medium text-text-secondary transition-colors hover:text-text hover:border-text-secondary"
          >
            {t["tools.configurator.openButton"] ?? "Generate a project"}
          </a>
        </div>
      </div>
    </div>
  </section>

  <OssFooter t={t} lang={lang} />
</Layout>
