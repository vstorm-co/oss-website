---
import Layout from "../../../layouts/Layout.astro";
import Navbar from "../../../components/Navbar.astro";
import OssFooter from "../../../components/oss/OssFooter.astro";
import Breadcrumbs from "../../../components/shared/Breadcrumbs.astro";
import FrameworkComparison from "../../../components/tools/FrameworkComparison";
import { translations, languages, defaultLang, type Lang } from "../../../i18n/translations";
import { softwareApplicationSchema, SITE_URL } from "../../../lib/schemas";

export function getStaticPaths() {
  return Object.keys(languages)
    .filter((lang) => lang !== defaultLang)
    .map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const t = translations[lang];

const alternates = [
  { lang: "en", href: "/tools/framework-comparison/" },
  ...Object.keys(languages)
    .filter((l) => l !== defaultLang)
    .map((l) => ({ lang: l, href: `/${l}/tools/framework-comparison/` })),
];
---

<Layout
  title={`${t["tools.comparison.title"] ?? "AI Framework Comparison Calculator"} — Vstorm OSS`}
  description={t["tools.comparison.subtitle"] ??
    "Compare Pydantic AI, LangChain, LangGraph, CrewAI, and Deep Agents. Answer 6 questions and get a personalized framework recommendation."}
  keywords="ai framework comparison, pydantic ai vs langchain, langgraph vs crewai, best python ai framework, ai agent framework comparison"
  lang={lang}
  alternates={alternates}
  schemas={[
    softwareApplicationSchema({
      name: "AI Framework Comparison Calculator",
      description:
        t["tools.comparison.subtitle"] ??
        "Free interactive tool to compare Python AI agent frameworks. Answer 6 questions and get a personalized recommendation.",
      url: SITE_URL + `/${lang}/tools/framework-comparison/`,
      operatingSystem: "Web",
    }),
  ]}
  theme="light"
>
  <Navbar currentLang={lang} />

  <Breadcrumbs
    items={[
      { label: "Home", href: `/${lang}/` },
      { label: t["tools.index.title"] ?? "Free Tools", href: `/${lang}/tools/` },
      { label: t["tools.comparison.title"] ?? "Framework Comparison" },
    ]}
  />

  <!-- Hero -->
  <section class="mx-auto max-w-4xl px-4 py-16 sm:py-24">
    <div class="reveal mb-12 text-center">
      <h1 class="heading-accent heading-accent text-3xl font-bold tracking-tight sm:text-4xl">
        {t["tools.comparison.title"] ?? "AI Framework Comparison Calculator"}
      </h1>
      <p class="text-text-secondary mx-auto mt-4 max-w-2xl text-lg">
        {
          t["tools.comparison.subtitle"] ??
            "Answer 6 questions about your project and get a scored recommendation across 5 Python AI agent frameworks."
        }
      </p>
    </div>
  </section>

  <!-- Calculator -->
  <section class="px-4 py-16 sm:px-6 sm:py-24 lg:px-8">
    <div class="mx-auto max-w-3xl">
      <FrameworkComparison client:only="react" />
    </div>
  </section>

  <!-- Frameworks Overview -->
  <section class="px-4 py-16 sm:px-6 sm:py-24 lg:px-8">
    <div class="mx-auto max-w-4xl">
      <div class="reveal mb-10 text-center">
        <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">
          {t["tools.comparison.frameworks.title"] ?? "Frameworks We Compare"}
        </h2>
      </div>
      <div class="reveal-group grid gap-3 sm:grid-cols-5">
        <a
          href={`/${lang}/guides/customer-support-chatbot-with-pydantic-ai/`}
          class="reveal glass-card group rounded-xl p-4 text-center"
        >
          <span class="group-hover:text-accent text-sm font-semibold transition-colors"
            >Pydantic AI</span
          >
          <p class="text-text-tertiary mt-1 text-[11px]">Type-safe agents</p>
        </a>
        <a
          href={`/${lang}/guides/customer-support-chatbot-with-langchain/`}
          class="reveal glass-card group rounded-xl p-4 text-center"
        >
          <span class="group-hover:text-accent text-sm font-semibold transition-colors"
            >LangChain</span
          >
          <p class="text-text-tertiary mt-1 text-[11px]">Huge ecosystem</p>
        </a>
        <a
          href={`/${lang}/guides/customer-support-chatbot-with-langgraph/`}
          class="reveal glass-card group rounded-xl p-4 text-center"
        >
          <span class="group-hover:text-accent text-sm font-semibold transition-colors"
            >LangGraph</span
          >
          <p class="text-text-tertiary mt-1 text-[11px]">Graph workflows</p>
        </a>
        <a
          href={`/${lang}/guides/customer-support-chatbot-with-crewai/`}
          class="reveal glass-card group rounded-xl p-4 text-center"
        >
          <span class="group-hover:text-accent text-sm font-semibold transition-colors">CrewAI</span
          >
          <p class="text-text-tertiary mt-1 text-[11px]">Multi-agent crews</p>
        </a>
        <a
          href={`/${lang}/guides/customer-support-chatbot-with-deepagents/`}
          class="reveal glass-card group rounded-xl p-4 text-center"
        >
          <span class="group-hover:text-accent text-sm font-semibold transition-colors"
            >Deep Agents</span
          >
          <p class="text-text-tertiary mt-1 text-[11px]">Modular + Claude Code arch</p>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="px-4 py-20 sm:px-6 sm:py-28 lg:px-8 lg:py-36">
    <div class="reveal mx-auto max-w-3xl text-center">
      <div class="glass-card glow-card rounded-2xl p-6 sm:p-10 lg:p-14">
        <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">
          {t["tools.comparison.cta.title"] ?? "Want a deeper comparison?"}
        </h2>
        <p class="text-text-secondary mt-4">
          {
            t["tools.comparison.cta.description"] ??
              "Check our detailed side-by-side comparisons with feature tables, code examples, and migration guides."
          }
        </p>
        <div class="mt-6 flex flex-wrap items-center justify-center gap-3 sm:mt-8">
          <a
            href={`/${lang}/compare/`}
            class="bg-accent hover:bg-accent-hover inline-flex items-center gap-2 rounded-full px-6 py-2.5 text-sm font-semibold text-white transition-colors sm:px-8 sm:py-3 sm:text-base"
          >
            {t["tools.comparison.cta.button"] ?? "See Detailed Comparisons"}
            <svg
              class="h-4 w-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"
              ></path>
            </svg>
          </a>
          <a
            href={`/${lang}/tools/architecture-quiz/`}
            class="border-border text-text-secondary hover:text-text hover:border-text-secondary inline-flex items-center gap-2 rounded-full border px-6 py-2.5 text-sm font-medium transition-colors sm:px-8 sm:py-3 sm:text-base"
          >
            {t["tools.quiz.title"] ?? "Take Architecture Quiz"}
          </a>
        </div>
      </div>
    </div>
  </section>

  <OssFooter t={t} lang={lang} />
</Layout>
