---
import Layout from '../../../layouts/Layout.astro';
import Navbar from '../../../components/Navbar.astro';
import OssFooter from '../../../components/oss/OssFooter.astro';
import Breadcrumbs from '../../../components/shared/Breadcrumbs.astro';
import { translations, languages, defaultLang, type Lang } from '../../../i18n/translations';
import { softwareApplicationSchema, SITE_URL } from '../../../lib/schemas';

export function getStaticPaths() {
  return Object.keys(languages)
    .filter((lang) => lang !== defaultLang)
    .map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const t = translations[lang];

const alternates = [
  { lang: "en", href: "/tools/ai-agent-configurator/" },
  ...Object.keys(languages)
    .filter((l) => l !== defaultLang)
    .map((l) => ({ lang: l, href: `/${l}/tools/ai-agent-configurator/` })),
];

const features = [
  { icon: "🤖", title: "5 AI Frameworks", description: t["tools.configurator.feat.frameworks"] ?? "Pydantic AI, LangChain, LangGraph, CrewAI, or Deep Agents — pick the one that fits." },
  { icon: "🗄️", title: "4 Databases", description: t["tools.configurator.feat.databases"] ?? "PostgreSQL, MongoDB, SQLite, or none. With async drivers and migrations pre-configured." },
  { icon: "🔐", title: "Auth", description: t["tools.configurator.feat.auth"] ?? "JWT tokens, API keys, or both. OAuth2 support included." },
  { icon: "📡", title: "Streaming", description: t["tools.configurator.feat.streaming"] ?? "Real-time AI responses with Server-Sent Events or WebSocket support." },
  { icon: "📊", title: "Observability", description: t["tools.configurator.feat.observability"] ?? "Pydantic Logfire, Sentry, and Prometheus metrics — ready from day one." },
  { icon: "🐳", title: "Docker & K8s", description: t["tools.configurator.feat.docker"] ?? "Multi-stage Dockerfiles, docker-compose, and Kubernetes manifests included." },
];

const steps = [
  { num: "1", title: t["tools.configurator.step1"] ?? "Choose your options", description: t["tools.configurator.step1.desc"] ?? "Select AI framework, database, auth, integrations, and infrastructure across 9 configuration steps." },
  { num: "2", title: t["tools.configurator.step2"] ?? "Preview your project", description: t["tools.configurator.step2.desc"] ?? "See a live preview of your project structure, dependencies, and configuration as you build." },
  { num: "3", title: t["tools.configurator.step3"] ?? "Download & run", description: t["tools.configurator.step3.desc"] ?? "Download as ZIP or copy the CLI command. Your project runs locally in under 2 minutes." },
];
---

<Layout
  title={`${t["tools.configurator.title"] ?? "AI Agent Project Configurator"} — Vstorm OSS`}
  description={t["tools.configurator.subtitle"] ?? "Configure and download a production-ready FastAPI + Next.js AI agent project with 75+ options. Free, no signup required."}
  keywords="ai agent generator, ai project configurator, fastapi ai template, nextjs ai template, python ai project generator, free ai tool"
  lang={lang}
  alternates={alternates}
  schemas={[softwareApplicationSchema({ name: "AI Agent Project Configurator", description: t["tools.configurator.subtitle"] ?? "Free online tool to configure and download a production-ready FastAPI + Next.js AI agent project with 75+ options.", url: SITE_URL + "/tools/ai-agent-configurator/", operatingSystem: "Web", featureList: "5 AI frameworks, 4 databases, JWT/API key auth, streaming, Docker, Kubernetes, observability" })]}
>
  <Navbar currentLang={lang} />

  <Breadcrumbs items={[
    { label: "Home", href: `/${lang}/` },
    { label: t["tools.index.title"] ?? "Free Tools", href: `/${lang}/tools/` },
    { label: t["tools.configurator.title"] ?? "AI Agent Configurator" },
  ]} />

  <!-- Hero -->
  <section class="relative mx-auto max-w-4xl px-4 pt-28 pb-12 sm:px-6 sm:pt-36 sm:pb-16 lg:px-8 text-center">
    <div class="pointer-events-none absolute inset-0 -top-24 flex items-center justify-center" aria-hidden="true">
      <div class="h-[200px] w-[300px] sm:h-[340px] sm:w-[540px] rounded-full bg-accent/[0.07] blur-[60px] sm:blur-[100px]"></div>
    </div>
    <div class="reveal relative">
      <span class="inline-flex items-center rounded-full border border-green-500/30 bg-green-500/10 px-3 py-1 text-xs font-medium text-green-400 mb-6">
        Free — No Signup Required
      </span>
      <h1 class="text-3xl font-bold tracking-tight sm:text-4xl lg:text-5xl heading-accent">
        {t["tools.configurator.title"] ?? "AI Agent Project Configurator"}
      </h1>
      <p class="mt-6 text-lg sm:text-xl text-text-secondary max-w-2xl mx-auto leading-relaxed">
        {t["tools.configurator.subtitle"] ?? "Configure a production-ready FastAPI + Next.js AI agent project with 75+ options. Download as ZIP or CLI — runs locally in under 2 minutes."}
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        <a
          href={`/${lang}/projects/full-stack-ai-agent-template/configurator/`}
          class="inline-flex items-center gap-2 rounded-full bg-accent px-6 py-2.5 sm:px-8 sm:py-3 text-sm sm:text-base font-semibold text-white transition-colors hover:bg-accent-hover"
        >
          {t["tools.configurator.openButton"] ?? "Open Configurator"}
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
      </div>
      <div class="mt-6 flex flex-wrap items-center justify-center gap-4 text-sm text-text-tertiary">
        <span>5 AI Frameworks</span>
        <span class="h-1 w-1 rounded-full bg-border"></span>
        <span>75+ Options</span>
        <span class="h-1 w-1 rounded-full bg-border"></span>
        <span>FastAPI + Next.js</span>
        <span class="h-1 w-1 rounded-full bg-border"></span>
        <span>100% Open Source</span>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section class="section-stack px-4 py-16 sm:px-6 sm:py-24 lg:px-8">
    <div class="mx-auto max-w-4xl">
      <div class="mb-10 text-center reveal">
        <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">
          {t["tools.configurator.features.title"] ?? "What you can configure"}
        </h2>
      </div>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 reveal-group">
        {features.map((f) => (
          <div class="reveal glass-card rounded-xl p-5">
            <div class="text-2xl mb-3">{f.icon}</div>
            <h3 class="font-semibold text-sm">{f.title}</h3>
            <p class="mt-1 text-xs text-text-secondary leading-relaxed">{f.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section class="section-stack px-4 py-16 sm:px-6 sm:py-24 lg:px-8">
    <div class="mx-auto max-w-4xl">
      <div class="mb-10 text-center reveal">
        <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">
          {t["tools.configurator.howItWorks"] ?? "How It Works"}
        </h2>
      </div>
      <div class="space-y-6 reveal-group">
        {steps.map((step) => (
          <div class="reveal glass-card rounded-2xl p-6 sm:p-8 flex gap-5">
            <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-full bg-accent/10 text-accent font-bold text-lg">
              {step.num}
            </div>
            <div>
              <h3 class="text-lg font-semibold">{step.title}</h3>
              <p class="mt-2 text-sm text-text-secondary leading-relaxed">{step.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative section-stack px-4 py-20 sm:px-6 sm:py-28 lg:px-8 lg:py-36">
    <div class="pointer-events-none absolute inset-0 flex items-center justify-center" aria-hidden="true">
      <div class="h-[180px] w-[300px] sm:h-[280px] sm:w-[480px] rounded-full bg-accent/[0.06] blur-[60px] sm:blur-[90px]"></div>
    </div>
    <div class="mx-auto max-w-3xl text-center reveal relative">
      <div class="glass-card glow-card rounded-2xl p-6 sm:p-10 lg:p-14">
        <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">
          {t["tools.configurator.cta.title"] ?? "Ready to build your AI agent project?"}
        </h2>
        <p class="mt-4 text-text-secondary">
          {t["tools.configurator.cta.description"] ?? "Open the configurator, choose your stack, and download a production-ready project in minutes."}
        </p>
        <a
          href={`/${lang}/projects/full-stack-ai-agent-template/configurator/`}
          class="mt-6 sm:mt-8 inline-flex items-center gap-2 rounded-full bg-accent px-6 py-2.5 sm:px-8 sm:py-3 text-sm sm:text-base font-semibold text-white transition-colors hover:bg-accent-hover"
        >
          {t["tools.configurator.openButton"] ?? "Open Free Configurator"}
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </a>
      </div>
    </div>
  </section>

  <OssFooter t={t} lang={lang} />
</Layout>
