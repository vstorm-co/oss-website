---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import OssFooter from '../../components/oss/OssFooter.astro';
import Breadcrumbs from '../../components/shared/Breadcrumbs.astro';
import { translations, languages, defaultLang, type Lang } from '../../i18n/translations';
import { organizationSchema } from '../../lib/schemas';

export function getStaticPaths() {
  return Object.keys(languages)
    .filter((lang) => lang !== defaultLang)
    .map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const t = translations[lang];

const alternates = [
  { lang: "en", href: "/about/" },
  ...Object.keys(languages)
    .filter((l) => l !== defaultLang)
    .map((l) => ({ lang: l, href: `/${l}/about/` })),
];

---

<Layout
  title={`${t["about.title"]} — Vstorm OSS`}
  description={t["about.meta.description"]}
  keywords="vstorm, ai consultancy, pydantic ai, open source ai, agentic ai, ai agent framework, python ai tools"
  lang={lang}
  alternates={alternates}
  schemas={[organizationSchema({ foundingDate: "2017", numberOfEmployees: 25 })]}
>
  <Navbar currentLang={lang} />

  <Breadcrumbs items={[
    { label: "Home", href: `/${lang}/` },
    { label: t["nav.about"] },
  ]} />

  <main class="mx-auto max-w-4xl px-4 py-16 sm:py-24">
    <!-- Hero -->
    <div class="mb-12 text-center reveal">
      <h1 class="text-3xl font-bold tracking-tight sm:text-4xl heading-accent">{t["about.title"]}</h1>
      <p class="mt-4 text-lg text-text-secondary max-w-2xl mx-auto">{t["about.subtitle"]}</p>
    </div>

    <!-- Company -->
    <section class="mb-16 reveal">
      <h2 class="text-2xl font-bold tracking-tight mb-4">{t["about.company.title"]}</h2>
      <p class="text-text-secondary leading-relaxed mb-4">{t["about.company.description"]}</p>
      <p class="text-text-secondary leading-relaxed">{t["about.company.details"]}</p>
    </section>

    <!-- Numbers -->
    <section class="mb-16 reveal">
      <h2 class="text-2xl font-bold tracking-tight mb-8">{t["about.numbers.title"]}</h2>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-6">
        <div class="text-center p-6 rounded-xl border border-border bg-surface">
          <div class="text-3xl font-bold text-accent">1,270+</div>
          <div class="mt-1 text-sm text-text-secondary">{t["about.numbers.stars"]}</div>
        </div>
        <div class="text-center p-6 rounded-xl border border-border bg-surface">
          <div class="text-3xl font-bold text-accent">285K+</div>
          <div class="mt-1 text-sm text-text-secondary">{t["about.numbers.downloads"]}</div>
        </div>
        <div class="text-center p-6 rounded-xl border border-border bg-surface">
          <div class="text-3xl font-bold text-accent">20</div>
          <div class="mt-1 text-sm text-text-secondary">{t["about.numbers.repos"]}</div>
        </div>
        <div class="text-center p-6 rounded-xl border border-border bg-surface">
          <div class="text-3xl font-bold text-accent">90+</div>
          <div class="mt-1 text-sm text-text-secondary">{t["about.numbers.projects"]}</div>
        </div>
      </div>
    </section>

    <!-- Partners -->
    <section class="mb-16 reveal">
      <h2 class="text-2xl font-bold tracking-tight mb-4">{t["about.partners.title"]}</h2>
      <p class="text-text-secondary leading-relaxed mb-6">{t["about.partners.description"]}</p>
      <div class="flex flex-wrap gap-3">
        <span class="px-4 py-2 rounded-lg border border-border bg-surface text-sm font-medium">Pydantic AI</span>
        <span class="px-4 py-2 rounded-lg border border-border bg-surface text-sm font-medium">LangChain</span>
        <span class="px-4 py-2 rounded-lg border border-border bg-surface text-sm font-medium">Agentic AI Foundation</span>
        <span class="px-4 py-2 rounded-lg border border-border bg-surface text-sm font-medium">Linux Foundation</span>
      </div>
    </section>

    <!-- Philosophy -->
    <section class="mb-16 reveal">
      <h2 class="text-2xl font-bold tracking-tight mb-4">{t["about.philosophy.title"]}</h2>
      <p class="text-text-secondary leading-relaxed">{t["about.philosophy.description"]}</p>
    </section>

    <!-- Links -->
    <section class="reveal">
      <h2 class="text-2xl font-bold tracking-tight mb-6">{t["about.links.title"]}</h2>
      <div class="flex flex-wrap gap-4">
        <a
          href="https://github.com/vstorm-co"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg border border-border bg-surface hover:bg-surface-hover transition-colors text-sm font-medium"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/></svg>
          GitHub
        </a>
        <a
          href="https://vstorm.co"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg border border-border bg-surface hover:bg-surface-hover transition-colors text-sm font-medium"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5a17.92 17.92 0 0 1-8.716-2.247m0 0A8.966 8.966 0 0 1 3 12c0-1.264.26-2.467.732-3.56"/></svg>
          vstorm.co
        </a>
        <a
          href="https://www.linkedin.com/company/vstormco/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg border border-border bg-surface hover:bg-surface-hover transition-colors text-sm font-medium"
        >
          <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          LinkedIn
        </a>
        <a
          href="https://pypi.org/user/kacperwlodarczyk-vstorm/"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg border border-border bg-surface hover:bg-surface-hover transition-colors text-sm font-medium"
        >
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m21 7.5-9-5.25L3 7.5m18 0-9 5.25m9-5.25v9l-9 5.25M3 7.5l9 5.25M3 7.5v9l9 5.25m0-9v9"/></svg>
          PyPI
        </a>
      </div>
    </section>
  </main>

  <OssFooter t={t} lang={lang} />
</Layout>
