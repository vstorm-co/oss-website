---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import OssHero from '../../components/oss/OssHero.astro';
import ProjectGrid from '../../components/oss/ProjectGrid.astro';
import OssFooter from '../../components/oss/OssFooter.astro';
import CommunityRecognition from '../../components/oss/CommunityRecognition.astro';
import TrustedBy from '../../components/oss/TrustedBy.astro';
import HowWeWork from '../../components/oss/HowWeWork.astro';
import FaqPreview from '../../components/landing/FaqPreview.astro';
import Changelog from '../../components/oss/Changelog.astro';
import Contributors from '../../components/oss/Contributors.astro';
import RecentPosts from '../../components/oss/RecentPosts.astro';
import { translations, languages, defaultLang, type Lang } from '../../i18n/translations';

export function getStaticPaths() {
  return Object.keys(languages)
    .filter((lang) => lang !== defaultLang)
    .map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const t = translations[lang];

const alternates = [
  { lang: "en", href: "/" },
  ...Object.keys(languages)
    .filter((l) => l !== defaultLang)
    .map((l) => ({ lang: l, href: `/${l}/` })),
];
---

<Layout
  title={t["oss.meta.title"]}
  description={t["oss.meta.description"]}
  lang={lang}
  alternates={alternates}
>
  <Navbar currentLang={lang} />
  <OssHero t={t} />
  <TrustedBy t={t} />
  <ProjectGrid lang={lang} t={t} />
  <HowWeWork t={t} />
  <CommunityRecognition t={t} />
  <FaqPreview t={t} lang={lang} />
  <Changelog t={t} />
  <Contributors t={t} />
  <RecentPosts t={t} lang={lang} />
  <OssFooter t={t} />
</Layout>
