---
import Layout from '../../../../layouts/Layout.astro';
import Navbar from '../../../../components/Navbar.astro';
import Footer from '../../../../components/landing/Footer.astro';
import BlogCard from '../../../../components/blog/BlogCard.astro';
import Breadcrumbs from '../../../../components/shared/Breadcrumbs.astro';
import { getCollection } from 'astro:content';
import { translations, languages, defaultLang, type Lang } from '../../../../i18n/translations';
import { collectionPageSchema, SITE_URL } from '../../../../lib/schemas';

export async function getStaticPaths() {
  const nonDefaultLocales = Object.keys(languages).filter((l) => l !== defaultLang);
  const paths = [];

  for (const locale of nonDefaultLocales) {
    const posts = await getCollection('blog', ({ data }) => data.lang === locale && !data.draft);

    const tagMap = new Map<string, typeof posts>();
    for (const post of posts) {
      for (const tag of post.data.tags ?? []) {
        if (!tagMap.has(tag)) tagMap.set(tag, []);
        tagMap.get(tag)!.push(post);
      }
    }

    for (const [tag, tagPosts] of tagMap) {
      paths.push({
        params: { lang: locale, tag },
        props: {
          tag,
          posts: tagPosts.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
        },
      });
    }
  }

  return paths;
}

const { tag, posts } = Astro.props;
const lang = Astro.params.lang as Lang;
const t = translations[lang];

const pageTitle = t["blog.tag.title"].replace("{tag}", tag);
const postCount = t["blog.tag.postCount"].replace("{count}", String(posts.length));

// alternates already computed above - pass to Navbar to limit language switcher to languages that actually have this tag

const allBlogPosts = await getCollection('blog', ({ data }) => !data.draft);
const alternates = Object.keys(languages)
  .filter((locale) => allBlogPosts.some((p) => p.data.lang === locale && (p.data.tags ?? []).includes(tag)))
  .map((locale) => ({
    lang: locale,
    href: locale === defaultLang ? `/blog/tag/${tag}/` : `/${locale}/blog/tag/${tag}/`,
  }));
---

<Layout
  title={`${pageTitle} — Vstorm OSS`}
  description={`Browse ${postCount} tagged "${tag}" — tutorials, guides, and deep dives on building production AI agents with Python.`}
  lang={lang}
  alternates={alternates}
  schemas={[collectionPageSchema({ name: pageTitle, description: `Browse ${postCount} tagged "${tag}" — tutorials, guides, and deep dives on building production AI agents with Python.`, url: SITE_URL + `/${lang}/blog/tag/${tag}/` })]}
>
  <Navbar currentLang={lang} languageLinks={alternates} />
  <Breadcrumbs items={[
    { label: "Home", href: `/${lang}/` },
    { label: t["nav.blog"], href: `/${lang}/blog/` },
    { label: pageTitle },
  ]} />

  <main class="mx-auto max-w-3xl px-4 py-16 sm:py-24">
    <div class="mb-12 text-center">
      <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">{pageTitle}</h1>
      <p class="mt-4 text-text-secondary">{postCount}</p>
    </div>

    {posts.length === 0 ? (
      <p class="text-center text-text-secondary">{t["blog.noPosts"]}</p>
    ) : (
      <div class="space-y-4">
        {posts.map((post) => {
          const slug = post.id.split('/').slice(1).join('/');
          return (
            <BlogCard
              title={post.data.title}
              description={post.data.description}
              pubDate={post.data.pubDate}
              href={`/${lang}/blog/${slug}/`}
              tags={post.data.tags}
              lang={lang}
              category={post.data.category}
                author={post.data.author}
            />
          );
        })}
      </div>
    )}
  </main>

  <Footer t={t} />
</Layout>
