---
import Layout from "../../../layouts/Layout.astro";
import Navbar from "../../../components/Navbar.astro";
import OssFooter from "../../../components/oss/OssFooter.astro";
import Breadcrumbs from "../../../components/shared/Breadcrumbs.astro";
import { translations, languages, defaultLang, type Lang } from "../../../i18n/translations";
import { seoFrameworks, seoUseCases } from "../../../data/seo-guides";
import { collectionPageSchema, SITE_URL } from "../../../lib/schemas";

export function getStaticPaths() {
  return Object.keys(languages)
    .filter((lang) => lang !== defaultLang)
    .map((lang) => ({ params: { lang } }));
}

const lang = Astro.params.lang as Lang;
const t = translations[lang];

const alternates = [
  { lang: "en", href: "/guides/" },
  ...Object.keys(languages)
    .filter((l) => l !== defaultLang)
    .map((l) => ({ lang: l, href: `/${l}/guides/` })),
];
---

<Layout
  title={`${t["guides.index.title"] ?? "Guides"} — Vstorm OSS`}
  description={t["guides.index.subtitle"] ??
    "Learn how to build AI agents with different frameworks — step-by-step tutorials with working code."}
  keywords="ai agent tutorial, python ai framework, pydantic ai tutorial, langchain tutorial, langgraph guide, crewai example, deep agents guide"
  lang={lang}
  alternates={alternates}
  schemas={[
    collectionPageSchema({
      name: t["guides.index.title"] ?? "Guides",
      description:
        t["guides.index.subtitle"] ??
        "Learn how to build AI agents with different frameworks — step-by-step tutorials with working code.",
      url: SITE_URL + `/${lang}/guides/`,
    }),
  ]}
>
  <Navbar currentLang={lang} />

  <Breadcrumbs
    items={[{ label: "Home", href: `/${lang}/` }, { label: t["guides.index.title"] ?? "Guides" }]}
  />

  <main class="mx-auto max-w-5xl px-4 py-16 sm:py-24">
    <div class="reveal mb-12 text-center">
      <h1 class="heading-accent text-3xl font-bold tracking-tight sm:text-4xl">
        {t["guides.index.title"] ?? "Guides"}
      </h1>
      <p class="text-text-secondary mx-auto mt-4 max-w-2xl text-lg">
        {
          t["guides.index.subtitle"] ??
            "Learn how to build AI agents with different frameworks — step-by-step tutorials with working code."
        }
      </p>
    </div>

    {
      seoUseCases.map((uc) => (
        <div class="reveal mb-12">
          <h2 class="mb-4 flex items-center gap-2 text-xl font-semibold">
            <span class="bg-border h-px flex-1" />
            <span class="px-3">
              {uc.pageTitle[lang]
                .replace("{framework}", "")
                .replace(" with ", "")
                .replace(" z ", "")
                .replace(" mit ", "")
                .replace(" con ", "")
                .trim()}
            </span>
            <span class="bg-border h-px flex-1" />
          </h2>
          <div class="grid gap-3 sm:grid-cols-5">
            {seoFrameworks.map((fw) => (
              <a
                href={`/${lang}/guides/${uc.slug}-with-${fw.slug}/`}
                class="group glass-card hover:border-accent/30 rounded-xl p-4 text-center transition-all"
              >
                <span class="text-text group-hover:text-accent text-sm font-semibold transition-colors">
                  {fw.name}
                </span>
                <div class="mt-1 flex flex-wrap justify-center gap-1">
                  {uc.tags.slice(0, 2).map((tag) => (
                    <span class="border-border text-text-tertiary rounded-full border px-1.5 py-0.5 text-[9px]">
                      {tag}
                    </span>
                  ))}
                </div>
              </a>
            ))}
          </div>
        </div>
      ))
    }
  </main>

  <OssFooter t={t} lang={lang} />
</Layout>
