---
import Layout from "../../layouts/Layout.astro";
import Navbar from "../../components/Navbar.astro";
import OssFooter from "../../components/oss/OssFooter.astro";
import Breadcrumbs from "../../components/shared/Breadcrumbs.astro";
import { translations, languages, defaultLang } from "../../i18n/translations";
import { collectionPageSchema, SITE_URL } from "../../lib/schemas";

const lang = defaultLang;
const t = translations[lang];

const alternates = [
  { lang: "en", href: "/tools/" },
  ...Object.keys(languages)
    .filter((l) => l !== defaultLang)
    .map((l) => ({ lang: l, href: `/${l}/tools/` })),
];

const tools = [
  {
    slug: "ai-agent-configurator",
    icon: "⚙️",
    title: t["tools.configurator.title"] ?? "AI Agent Project Configurator",
    description:
      t["tools.configurator.description"] ??
      "Configure and download a production-ready FastAPI + Next.js AI agent project. Choose from 5 frameworks, 4 databases, and 75+ options — no signup required.",
    badge: "Interactive",
  },
  {
    slug: "framework-comparison",
    icon: "📊",
    title: t["tools.comparison.title"] ?? "AI Framework Comparison Calculator",
    description:
      t["tools.comparison.description"] ??
      "Answer 6 quick questions about your project requirements and get a personalized AI framework recommendation with scored results.",
    badge: "Calculator",
  },
  {
    slug: "architecture-quiz",
    icon: "🧩",
    title: t["tools.quiz.title"] ?? "Agent Architecture Quiz",
    description:
      t["tools.quiz.description"] ??
      "Take a 5-question quiz to discover the best agent architecture pattern for your use case — from simple ReAct to hierarchical multi-agent systems.",
    badge: "Quiz",
  },
];
---

<Layout
  title={`${t["tools.index.title"] ?? "Free AI Agent Tools"} — Vstorm OSS`}
  description={t["tools.index.subtitle"] ??
    "Free interactive tools to help you choose the right AI framework, architecture, and project setup."}
  keywords="ai agent tools, free ai tools, ai framework comparison, agent architecture, project configurator, python ai agent generator"
  lang={lang}
  alternates={alternates}
  schemas={[
    collectionPageSchema({
      name: t["tools.index.title"] ?? "Free AI Agent Tools",
      description:
        t["tools.index.subtitle"] ??
        "Free interactive tools to help you choose the right AI framework, architecture, and project setup.",
      url: SITE_URL + "/tools/",
    }),
  ]}
>
  <Navbar currentLang={lang} />

  <Breadcrumbs
    items={[{ label: "Home", href: "/" }, { label: t["tools.index.title"] ?? "Free Tools" }]}
  />

  <main class="mx-auto max-w-4xl px-4 py-16 sm:py-24">
    <div class="reveal mb-12 text-center">
      <h1 class="heading-accent text-3xl font-bold tracking-tight sm:text-4xl">
        {t["tools.index.title"] ?? "Free AI Agent Tools"}
      </h1>
      <p class="text-text-secondary mx-auto mt-4 max-w-2xl text-lg">
        {
          t["tools.index.subtitle"] ??
            "Interactive tools to help you choose the right AI framework, architecture, and project setup — no signup required."
        }
      </p>
    </div>

    <div class="reveal-group grid gap-6 sm:grid-cols-1">
      {
        tools.map((tool) => (
          <a
            href={`/tools/${tool.slug}/`}
            class="reveal glass-card glow-card group hover:border-accent/30 rounded-2xl p-6 transition-all sm:p-8"
          >
            <div class="flex items-start gap-5">
              <div class="bg-accent/10 flex h-14 w-14 shrink-0 items-center justify-center rounded-xl text-2xl">
                {tool.icon}
              </div>
              <div class="flex-1">
                <div class="mb-2 flex items-center gap-3">
                  <h2 class="group-hover:text-accent text-xl font-bold transition-colors">
                    {tool.title}
                  </h2>
                  <span class="border-accent/30 bg-accent/10 text-accent rounded-full border px-2.5 py-0.5 text-[10px] font-semibold tracking-wider uppercase">
                    {tool.badge}
                  </span>
                </div>
                <p class="text-text-secondary text-sm leading-relaxed">{tool.description}</p>
                <div class="text-accent mt-4 inline-flex items-center gap-1.5 text-sm font-medium transition-all group-hover:gap-2.5">
                  Try it free
                  <svg
                    class="h-4 w-4"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke="currentColor"
                    stroke-width="2"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M13 7l5 5m0 0l-5 5m5-5H6"
                    />
                  </svg>
                </div>
              </div>
            </div>
          </a>
        ))
      }
    </div>
  </main>

  <OssFooter t={t} />
</Layout>
