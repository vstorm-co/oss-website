---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import OssFooter from '../../components/oss/OssFooter.astro';
import Breadcrumbs from '../../components/shared/Breadcrumbs.astro';
import FrameworkComparison from '../../components/tools/FrameworkComparison';
import { translations, languages, defaultLang } from '../../i18n/translations';
import { softwareApplicationSchema, SITE_URL } from '../../lib/schemas';

const lang = defaultLang;
const t = translations[lang];

const alternates = [
  { lang: "en", href: "/tools/framework-comparison/" },
  ...Object.keys(languages)
    .filter((l) => l !== defaultLang)
    .map((l) => ({ lang: l, href: `/${l}/tools/framework-comparison/` })),
];

---

<Layout
  title="AI Framework Comparison Calculator — Find the Best Python AI Framework"
  description="Compare Pydantic AI, LangChain, LangGraph, CrewAI, and Deep Agents. Answer 6 questions about your project and get a personalized framework recommendation."
  keywords="ai framework comparison, pydantic ai vs langchain, langgraph vs crewai, best python ai framework, ai agent framework comparison, which ai framework to use"
  lang={lang}
  alternates={alternates}
  schemas={[softwareApplicationSchema({ name: "AI Framework Comparison Calculator", description: "Free interactive tool to compare Python AI agent frameworks. Answer 6 questions and get a personalized recommendation.", url: SITE_URL + "/tools/framework-comparison/", operatingSystem: "Web" })]}
  theme="light"
>
  <Navbar currentLang={lang} />

  <Breadcrumbs items={[
    { label: "Home", href: "/" },
    { label: t["tools.index.title"] ?? "Free Tools", href: "/tools/" },
    { label: t["tools.comparison.title"] ?? "Framework Comparison" },
  ]} />

  <!-- Hero -->
  <main class="mx-auto max-w-4xl px-4 py-16 sm:py-24">
    <div class="mb-12 text-center reveal">
      <h1 class="text-3xl font-bold tracking-tight sm:text-4xl heading-accent">
        {t["tools.comparison.title"] ?? "AI Framework Comparison Calculator"}
      </h1>
      <p class="mt-4 text-lg text-text-secondary max-w-2xl mx-auto">
        {t["tools.comparison.subtitle"] ?? "Answer 6 questions about your project and get a scored recommendation across 5 Python AI agent frameworks."}
      </p>
    </div>

  <!-- Calculator -->
  <section class="px-4 py-16 sm:px-6 sm:py-24 lg:px-8">
    <div class="mx-auto max-w-3xl">
      <FrameworkComparison client:only="react" />
    </div>
  </section>

  <!-- Frameworks Overview -->
  <section class="px-4 py-16 sm:px-6 sm:py-24 lg:px-8">
    <div class="mx-auto max-w-4xl">
      <div class="mb-10 text-center reveal">
        <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">
          {t["tools.comparison.frameworks.title"] ?? "Frameworks We Compare"}
        </h2>
      </div>
      <div class="grid gap-3 sm:grid-cols-5 reveal-group">
        <a href="/guides/customer-support-chatbot-with-pydantic-ai/" class="reveal glass-card rounded-xl p-4 text-center group">
          <span class="font-semibold text-sm group-hover:text-accent transition-colors">Pydantic AI</span>
          <p class="mt-1 text-[11px] text-text-tertiary">Type-safe agents</p>
        </a>
        <a href="/guides/customer-support-chatbot-with-langchain/" class="reveal glass-card rounded-xl p-4 text-center group">
          <span class="font-semibold text-sm group-hover:text-accent transition-colors">LangChain</span>
          <p class="mt-1 text-[11px] text-text-tertiary">Huge ecosystem</p>
        </a>
        <a href="/guides/customer-support-chatbot-with-langgraph/" class="reveal glass-card rounded-xl p-4 text-center group">
          <span class="font-semibold text-sm group-hover:text-accent transition-colors">LangGraph</span>
          <p class="mt-1 text-[11px] text-text-tertiary">Graph workflows</p>
        </a>
        <a href="/guides/customer-support-chatbot-with-crewai/" class="reveal glass-card rounded-xl p-4 text-center group">
          <span class="font-semibold text-sm group-hover:text-accent transition-colors">CrewAI</span>
          <p class="mt-1 text-[11px] text-text-tertiary">Multi-agent crews</p>
        </a>
        <a href="/guides/customer-support-chatbot-with-deepagents/" class="reveal glass-card rounded-xl p-4 text-center group">
          <span class="font-semibold text-sm group-hover:text-accent transition-colors">Deep Agents</span>
          <p class="mt-1 text-[11px] text-text-tertiary">Modular + Claude Code arch</p>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="px-4 py-20 sm:px-6 sm:py-28 lg:px-8 lg:py-36">
    <div class="mx-auto max-w-3xl text-center reveal">
      <div class="glass-card glow-card rounded-2xl p-6 sm:p-10 lg:p-14">
        <h2 class="text-2xl font-bold tracking-tight sm:text-3xl">
          {t["tools.comparison.cta.title"] ?? "Want a deeper comparison?"}
        </h2>
        <p class="mt-4 text-text-secondary">
          {t["tools.comparison.cta.description"] ?? "Check our detailed side-by-side comparisons with feature tables, code examples, and migration guides."}
        </p>
        <div class="mt-6 sm:mt-8 flex flex-wrap items-center justify-center gap-3">
          <a
            href="/compare/"
            class="inline-flex items-center gap-2 rounded-full bg-accent px-6 py-2.5 sm:px-8 sm:py-3 text-sm sm:text-base font-semibold text-white transition-colors hover:bg-accent-hover"
          >
            See Detailed Comparisons
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </a>
          <a
            href="/tools/architecture-quiz/"
            class="inline-flex items-center gap-2 rounded-full border border-border px-6 py-2.5 sm:px-8 sm:py-3 text-sm sm:text-base font-medium text-text-secondary transition-colors hover:text-text hover:border-text-secondary"
          >
            Take Architecture Quiz
          </a>
        </div>
      </div>
    </div>
  </section>
  </main>

  <OssFooter t={t} />
</Layout>
