---
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import OssFooter from "../components/oss/OssFooter.astro";
import Breadcrumbs from "../components/shared/Breadcrumbs.astro";
import { translations, languages, defaultLang } from "../i18n/translations";
import { changelog } from "../data/changelog";
import { webPageSchema, SITE_URL } from "../lib/schemas";

const lang = defaultLang;
const t = translations[lang];

const alternates = [
  { lang: "en", href: "/changelog/" },
  ...Object.keys(languages)
    .filter((l) => l !== defaultLang)
    .map((l) => ({ lang: l, href: `/${l}/changelog/` })),
];

const formatDate = (dateStr: string) => {
  const d = new Date(dateStr);
  return d.toLocaleDateString("en", { month: "short", day: "numeric", year: "numeric" });
};

const tagColors: Record<string, string> = {
  framework: "bg-accent/10 text-accent",
  template: "bg-blue-400/10 text-blue-400",
  tool: "bg-green-400/10 text-green-400",
  resource: "bg-amber-400/10 text-amber-400",
};
---

<Layout
  title={`${t["changelog.title"]} — Vstorm OSS`}
  description={t["changelog.subtitle"]}
  keywords="vstorm changelog, ai agent releases, pydantic deepagents changelog, open source ai updates"
  lang={lang}
  alternates={alternates}
  schemas={[
    webPageSchema({
      name: t["changelog.title"],
      description: t["changelog.subtitle"],
      url: SITE_URL + "/changelog/",
    }),
  ]}
>
  <Navbar currentLang={lang} />

  <Breadcrumbs items={[{ label: "Home", href: "/" }, { label: t["changelog.title"] }]} />

  <main class="mx-auto max-w-3xl px-4 pt-28 pb-16 sm:px-6 sm:pt-36 sm:pb-24 lg:px-8">
    <div class="reveal mb-12 text-center">
      <h1 class="heading-accent text-3xl font-bold tracking-tight sm:text-4xl">
        {t["changelog.title"]}
      </h1>
      <p class="text-text-secondary mt-4 text-lg">{t["changelog.subtitle"]}</p>
    </div>

    <div class="reveal space-y-0">
      {
        changelog.map((entry, i) => (
          <div class="relative flex gap-5 pb-8 last:pb-0">
            {/* Timeline line */}
            {i < changelog.length - 1 && (
              <div class="bg-border absolute top-6 bottom-0 left-[11px] w-px" />
            )}

            {/* Dot */}
            <div class="border-accent bg-bg relative z-10 mt-1.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full border-2">
              <div class="bg-accent h-2 w-2 rounded-full" />
            </div>

            {/* Content */}
            <div class="glass-card flex-1 rounded-xl p-4 sm:p-5">
              <div class="mb-1.5 flex flex-wrap items-center gap-2">
                <span class="text-text-tertiary font-mono text-xs">{formatDate(entry.date)}</span>
                <span class="bg-accent/10 text-accent rounded-full px-2 py-0.5 text-[11px] font-semibold">
                  {entry.version}
                </span>
                <span class="border-border text-text-tertiary rounded-full border px-2 py-0.5 text-[11px]">
                  {entry.project}
                </span>
                <span
                  class={`rounded-full px-2 py-0.5 text-[11px] font-medium ${tagColors[entry.tag]}`}
                >
                  {entry.tag}
                </span>
                {entry.breaking && (
                  <span class="rounded-full bg-red-500/10 px-2 py-0.5 text-[11px] font-semibold text-red-400">
                    BREAKING
                  </span>
                )}
              </div>
              <h3 class="text-sm font-semibold sm:text-base">{entry.title[lang]}</h3>
              <p class="text-text-secondary mt-1 text-sm leading-relaxed">
                {entry.description[lang]}
              </p>
            </div>
          </div>
        ))
      }
    </div>
  </main>

  <OssFooter t={t} />
</Layout>
