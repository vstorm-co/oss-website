---
import Layout from "./Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/landing/Footer.astro";
import TableOfContents from "../components/blog/TableOfContents.astro";
import TranslationLinks from "../components/blog/TranslationLinks.astro";
import ShareButtons from "../components/blog/ShareButtons.astro";
import RelatedPosts from "../components/blog/RelatedPosts.astro";
import StickyCTA from "../components/blog/StickyCTA.astro";
import Breadcrumbs from "../components/shared/Breadcrumbs.astro";
import type { Lang } from "../i18n/translations";
import { translations, languages, defaultLang } from "../i18n/translations";
import {
  blogPostingSchema,
  howToSchema as buildHowToSchema,
  type JsonLdSchema,
} from "../lib/schemas";
import { getAuthor } from "../data/authors";
import "../styles/prose.css";

interface Props {
  title: string;
  seoTitle?: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  author: string;
  tags: string[];
  lang: Lang;
  translationKey: string;
  headings: { depth: number; slug: string; text: string }[];
  allTranslations?: { lang: Lang; slug: string }[];
  readingTime?: number;
  category?: string;
}

const {
  title,
  seoTitle,
  description,
  pubDate,
  updatedDate,
  author,
  tags,
  lang,
  translationKey,
  headings,
  allTranslations = [],
  readingTime,
  category,
} = Astro.props;

const t = translations[lang];
const blogHref = lang === defaultLang ? "/blog/" : `/${lang}/blog/`;

// Build language links for the language switcher - only show languages that have actual translations
const languageLinks = allTranslations.map((tr) => ({
  lang: tr.lang,
  href: tr.lang === defaultLang ? `/blog/${tr.slug}/` : `/${tr.lang}/blog/${tr.slug}/`,
}));

const alternates = allTranslations.map((tr) => ({
  lang: tr.lang,
  href: tr.lang === defaultLang ? `/blog/${tr.slug}/` : `/${tr.lang}/blog/${tr.slug}/`,
}));

const formatDate = (date: Date) =>
  date.toLocaleDateString(lang, { year: "numeric", month: "long", day: "numeric" });

// Find the English slug for the OG image (all languages share the same OG via translationKey)
const enTranslation = allTranslations.find((tr) => tr.lang === defaultLang);
const ogSlug = enTranslation?.slug ?? translationKey;
const siteUrl = Astro.site?.origin ?? "https://oss.vstorm.co";
const ogImage = new URL(`/og/${ogSlug}.svg`, siteUrl).href;

// Resolve author Person data
const authorData = getAuthor(author);
const authorSameAs = [authorData.linkedIn, authorData.github, authorData.twitter].filter(
  Boolean,
) as string[];

// Build JSON-LD schemas
const schemas: JsonLdSchema[] = [
  blogPostingSchema({
    title,
    description,
    pubDate,
    updatedDate,
    authorPerson: {
      name: authorData.name,
      jobTitle: authorData.jobTitle,
      url: authorData.url,
      sameAs: authorSameAs,
    },
    url: Astro.url.href,
    lang,
    image: ogImage,
    keywords: tags,
    articleSection: category,
  }),
];

if (category === "tutorial" && headings.length > 0) {
  schemas.push(
    buildHowToSchema({
      name: title,
      description,
      steps: headings
        .filter((h) => h.depth === 2)
        .map((h) => ({
          name: h.text,
          url: `${Astro.url.href}#${h.slug}`,
        })),
    }),
  );
}
---

<Layout
  title={`${seoTitle ?? title} — Vstorm OSS`}
  description={description}
  keywords={tags.join(", ")}
  lang={lang}
  alternates={alternates}
  ogImage={ogImage}
  ogType="article"
  articleDates={{ published: pubDate.toISOString(), modified: updatedDate?.toISOString() }}
  schemas={schemas}
>
  <!-- Scroll progress bar -->
  <div
    id="scroll-progress"
    class="bg-accent fixed top-0 left-0 z-50 h-0.5 transition-none"
    style="width: 0%"
  >
  </div>

  <Navbar currentLang={lang} languageLinks={languageLinks} />
  <Breadcrumbs
    items={[
      { label: "Home", href: lang === defaultLang ? "/" : `/${lang}/` },
      { label: t["nav.blog"], href: blogHref },
      { label: title },
    ]}
  />

  <main class="mx-auto max-w-7xl px-4 py-16 sm:py-24">
    <div class="flex gap-10">
      <!-- Article -->
      <article class="max-w-3xl min-w-0 flex-1">
        <a
          href={blogHref}
          class="text-text-secondary hover:text-accent mb-6 inline-flex items-center gap-1 text-sm transition-colors"
        >
          <svg
            class="h-4 w-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7"></path>
          </svg>
          {t["blog.backToBlog"]}
        </a>

        <header class="mb-10">
          {
            category && (
              <span class="bg-accent/10 text-accent mb-3 inline-block rounded-full px-3 py-1 text-xs font-medium">
                {t[`blog.category.${category}` as keyof typeof t] || category}
              </span>
            )
          }
          <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">{title}</h1>
          <div class="text-text-secondary mt-4 flex flex-wrap items-center gap-x-4 gap-y-2 text-sm">
            <span>{author}</span>
            <span>&middot;</span>
            <time datetime={pubDate.toISOString()}>
              {formatDate(pubDate)}
            </time>
            {
              readingTime && (
                <>
                  <span>&middot;</span>
                  <span>{t["blog.readingTime"].replace("{min}", String(readingTime))}</span>
                </>
              )
            }
            {
              updatedDate && (
                <>
                  <span>&middot;</span>
                  <span>
                    {t["blog.updatedOn"]} {formatDate(updatedDate)}
                  </span>
                </>
              )
            }
          </div>

          {
            tags.length > 0 && (
              <div class="mt-4 flex flex-wrap gap-2">
                {tags.map((tag) => (
                  <a
                    href={lang === defaultLang ? `/blog/tag/${tag}/` : `/${lang}/blog/tag/${tag}/`}
                    class="bg-surface text-text-secondary hover:text-accent hover:bg-accent/10 rounded-full px-3 py-1 text-xs font-medium transition-colors"
                  >
                    {tag}
                  </a>
                ))}
              </div>
            )
          }

          {
            allTranslations.length > 1 && (
              <TranslationLinks
                translations={allTranslations}
                currentLang={lang}
                label={t["blog.availableIn"]}
              />
            )
          }
        </header>

        {
          headings.length > 0 && (
            <details class="glass-card mb-8 rounded-xl p-4 lg:hidden">
              <summary class="cursor-pointer text-sm font-semibold">
                {t["blog.tableOfContents"]}
              </summary>
              <TableOfContents headings={headings} label="" />
            </details>
          )
        }

        <div class="prose">
          <slot />
        </div>

        <ShareButtons title={title} url={Astro.url.href} t={t} />

        <RelatedPosts currentSlug={Astro.url.pathname} currentTags={tags} lang={lang} t={t} />
      </article>

      <!-- Sidebar TOC (desktop only) -->
      {
        headings.length > 0 && (
          <aside class="hidden w-64 shrink-0 lg:block">
            <div class="sticky top-24">
              <TableOfContents headings={headings} label={t["blog.tableOfContents"]} />
            </div>
          </aside>
        )
      }
    </div>
  </main>

  <Footer t={t} lang={lang} />
  <StickyCTA t={t} />

  <script is:inline>
    (function () {
      const bar = document.getElementById("scroll-progress");
      if (!bar) return;
      window.addEventListener(
        "scroll",
        function () {
          const h = document.documentElement.scrollHeight - window.innerHeight;
          const p = h > 0 ? (window.scrollY / h) * 100 : 0;
          bar.style.width = p + "%";
        },
        { passive: true },
      );
    })();
  </script>
</Layout>
